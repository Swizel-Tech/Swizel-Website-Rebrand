---
import MainLayout from '../../layouts/MainLayout.astro';
import CaseStudy from '../../components/sections/CaseStudy.astro';
import { featuredProjects, projects } from '../../data/projects';

export async function getStaticPaths() {
	return featuredProjects.map((p) => {
		// "others" = the other featured case studies, for the Next card
		const others = featuredProjects.filter((o) => o.slug !== p.slug);
		return { params: { slug: p.slug }, props: { project: p, others } };
	});
}

const { project, others } = Astro.props;

const seoTitle = `${project.name} Case Study | Swizel Technologies`;
const seoDesc = project.tagline || project.caseStudy?.intro || '';
---

<MainLayout title={seoTitle} description={seoDesc} image={project.img}>
	<CaseStudy project={project} others={others} />

	<!-- Fallback for the other worlds: a simple summary + link out. -->
	<div class="alt-view-only" style="max-width:48rem;margin:0 auto;padding:5rem 1.5rem;">
		<a href="/portfolio" style="font-size:.9rem;font-weight:600;">← All work</a>
		<h1 style="font-size:2.2rem;font-weight:800;margin:1.5rem 0 1rem;">{project.name}</h1>
		<p style="font-size:1.1rem;line-height:1.6;opacity:.75;">{project.caseStudy?.intro}</p>
		{project.caseStudy?.liveUrl && (
			<p style="margin-top:1.5rem;"><a href={project.caseStudy.liveUrl} target="_blank" rel="noopener" style="font-weight:700;">Visit live site →</a></p>
		)}
	</div>
</MainLayout>
