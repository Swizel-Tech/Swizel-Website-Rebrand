---
import { getCollection } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';

export async function getStaticPaths() {
	const posts = (await getCollection('blog', ({ data }) => data.draft !== true)).sort(
		(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
	);

	return posts.map((post, i) => {
		const sameCat = posts.filter(
			(p) => p.slug !== post.slug && p.data.category === post.data.category
		);
		const others = posts.filter(
			(p) => p.slug !== post.slug && p.data.category !== post.data.category
		);
		return {
			params: { slug: post.slug },
			props: {
				post,
				prev: posts[i - 1] ?? null, // newer
				next: posts[i + 1] ?? null, // older
				related: [...sameCat, ...others].slice(0, 3),
			},
		};
	});
}

const { post, prev, next, related } = Astro.props;
const { Content } = await post.render();
---

<BlogPost post={post} prev={prev} next={next} related={related}>
	<Content />
</BlogPost>
