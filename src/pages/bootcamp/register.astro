---
import { Icon } from 'astro-icon/components';
import MainLayout from '../../layouts/MainLayout.astro';
import { bootCampForm } from '../../consts';

const SEO_TITLE = 'Register for the Free Swizel Bootcamp | Swizel Technologies';
const SEO_DESC =
	"Sign up for Swizel's free 3-month tech bootcamp. Pick software development, design or digital marketing, learn by building, and qualify for a paid internship.";
---

<MainLayout title={SEO_TITLE} description={SEO_DESC} image="/images/bootcamp.jpg">
	<article class="bdbody bc rf">
		<header class="rf-hero">
			<a class="rf-back" href="/bootcamp"><Icon width={16} name="mdi:arrow-left" /> Back to the bootcamp</a>
			<span class="bc-eyebrow"><span class="bc-dot"></span> Cohort '26 · Free to join</span>
			<h1 class="rf-title">Reserve your <span class="bc-grad">seat.</span></h1>
			<p class="rf-lead">
				Fill in a few details and we will send you everything: your start date, your
				coaches and an invite to the free Q&amp;A webinar. It takes about a minute.
			</p>
		</header>

		<form id="bootcamp-register" class="rf-card">
			<div class="rf-grid">
				{
					bootCampForm.map((f) => (
						<label class="rf-field">
							<span class="rf-label">
								{f.label}
								{f.isRequired && <em aria-hidden="true">*</em>}
							</span>
							<input
								type={(f as any).type ?? 'text'}
								name={f.name}
								placeholder={f.placeholder}
								required={f.isRequired}
								autocomplete="on"
							/>
						</label>
					))
				}

				<label class="rf-field rf-field--full">
					<span class="rf-label">Which track? <em aria-hidden="true">*</em></span>
					<div class="rf-select">
						<select name="package" required>
							<option value="">Choose a track</option>
							<option value="Software Development">Software Development</option>
							<option value="Visual Design">Visual Design</option>
							<option value="Digital Marketing">Digital Marketing</option>
						</select>
						<Icon class="rf-select-caret" width={20} name="mdi:chevron-down" />
					</div>
				</label>

				<label class="rf-field rf-field--full">
					<span class="rf-label">Anything else? <span class="rf-opt">(optional)</span></span>
					<textarea
						name="message"
						rows="4"
						placeholder="Tell us a little about yourself, or ask us a question."
					></textarea>
				</label>
			</div>

			<button type="submit" class="rf-submit">
				Submit registration
				<Icon width={18} name="mdi:arrow-right" />
			</button>
			<p class="rf-fine">
				<Icon width={15} name="mdi:lock-outline" />
				Free to join. You only pay an affordable fee for the certification exam at the end.
			</p>
		</form>
	</article>
</MainLayout>

<style>
	.bc {
		--bd-accent: #28a6ec;
		--bd-ink: #f4f6fb;
		--bd-muted: rgba(244, 246, 251, 0.62);
		--bd-glass: linear-gradient(160deg, rgba(255, 255, 255, 0.07), rgba(255, 255, 255, 0.02) 55%);
		--bd-glass-border: rgba(255, 255, 255, 0.1);
		--bd-shadow: 0 34px 80px -34px rgba(0, 0, 0, 0.8);
		--rf-input: rgba(255, 255, 255, 0.04);
	}
	:global(html:not(.dark)) .bc {
		--bd-ink: #14162a;
		--bd-muted: rgba(20, 22, 40, 0.64);
		--bd-glass: linear-gradient(160deg, rgba(255, 255, 255, 0.82), rgba(255, 255, 255, 0.55) 55%);
		--bd-glass-border: rgba(20, 22, 40, 0.1);
		--bd-shadow: 0 30px 70px -34px rgba(20, 22, 40, 0.25);
		--rf-input: rgba(255, 255, 255, 0.7);
	}

	.rf-hero { max-width: 42rem; margin: 0 auto; text-align: center; padding-top: clamp(0.5rem, 2vw, 1.5rem); }
	.rf-back { display: inline-flex; align-items: center; gap: 0.4rem; font-size: 0.85rem; font-weight: 700; color: var(--bd-muted); margin-bottom: 1.4rem; transition: color 0.2s ease; }
	.rf-back:hover { color: var(--bd-accent); }
	.bc-eyebrow {
		display: inline-flex; align-items: center; gap: 0.5rem;
		font-size: 0.74rem; font-weight: 800; letter-spacing: 0.1em; text-transform: uppercase;
		color: var(--bd-accent);
		border: 1px solid color-mix(in srgb, var(--bd-accent) 35%, transparent);
		background: color-mix(in srgb, var(--bd-accent) 9%, transparent);
		padding: 0.4rem 0.95rem; border-radius: 9999px; margin-bottom: 1.3rem;
	}
	.bc-dot { width: 7px; height: 7px; border-radius: 9999px; background: var(--bd-accent); box-shadow: 0 0 0 4px color-mix(in srgb, var(--bd-accent) 22%, transparent); }
	.rf-title { font-family: 'Bebas Neue', sans-serif; font-weight: 400; line-height: 0.95; letter-spacing: 0.5px; font-size: clamp(2.6rem, 7vw, 4.5rem); margin-bottom: 1rem; }
	.bc-grad { background: linear-gradient(120deg, var(--bd-accent), #8dfeea); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent; }
	.rf-lead { max-width: 34rem; margin: 0 auto; color: var(--bd-muted); font-size: 1.02rem; line-height: 1.65; }

	.rf-card {
		max-width: 42rem; margin: clamp(2rem, 4vw, 3rem) auto 0;
		padding: clamp(1.5rem, 4vw, 2.6rem);
		border-radius: 1.5rem;
		background: var(--bd-glass); border: 1px solid var(--bd-glass-border);
		box-shadow: var(--bd-shadow); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
	}
	.rf-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.1rem 1.2rem; }
	.rf-field { display: grid; gap: 0.5rem; }
	.rf-field--full { grid-column: 1 / -1; }
	.rf-label { font-size: 0.82rem; font-weight: 700; color: color-mix(in srgb, var(--bd-ink) 82%, transparent); }
	.rf-label em { color: var(--bd-accent); font-style: normal; margin-left: 0.15rem; }
	.rf-opt { font-weight: 500; color: var(--bd-muted); }

	.rf-field input,
	.rf-field textarea,
	.rf-select select {
		width: 100%;
		font: inherit; font-size: 0.95rem;
		color: var(--bd-ink);
		background: var(--rf-input);
		border: 1px solid var(--bd-glass-border);
		border-radius: 0.8rem;
		padding: 0.85rem 1rem;
		transition: border-color 0.2s ease, box-shadow 0.2s ease;
	}
	.rf-field textarea { resize: vertical; min-height: 7rem; }
	.rf-field input::placeholder,
	.rf-field textarea::placeholder { color: color-mix(in srgb, var(--bd-ink) 42%, transparent); }
	.rf-field input:focus,
	.rf-field textarea:focus,
	.rf-select select:focus {
		outline: none;
		border-color: color-mix(in srgb, var(--bd-accent) 60%, transparent);
		box-shadow: 0 0 0 3px color-mix(in srgb, var(--bd-accent) 18%, transparent);
	}
	.rf-select { position: relative; }
	.rf-select select { appearance: none; -webkit-appearance: none; padding-right: 2.6rem; cursor: pointer; }
	.rf-select-caret { position: absolute; right: 0.9rem; top: 50%; transform: translateY(-50%); color: var(--bd-accent); pointer-events: none; }

	.rf-submit {
		width: 100%; margin-top: 1.6rem;
		display: inline-flex; align-items: center; justify-content: center; gap: 0.5rem;
		font-weight: 800; font-size: 1rem; color: #06231c;
		background: linear-gradient(95deg, #8dfeea, var(--bd-accent));
		border: 0; border-radius: 9999px; padding: 1rem 1.5rem; cursor: pointer;
		box-shadow: 0 18px 38px -16px color-mix(in srgb, var(--bd-accent) 70%, transparent);
		transition: transform 0.2s ease, filter 0.2s ease;
	}
	.rf-submit:hover { transform: translateY(-2px); filter: brightness(1.04); }
	.rf-fine { display: flex; align-items: center; justify-content: center; gap: 0.45rem; margin: 1.1rem 0 0; text-align: center; font-size: 0.84rem; color: var(--bd-muted); }
	.rf-fine :global(svg) { color: var(--bd-accent); flex-shrink: 0; }

	@media (max-width: 560px) {
		.rf-grid { grid-template-columns: 1fr; }
	}
</style>
