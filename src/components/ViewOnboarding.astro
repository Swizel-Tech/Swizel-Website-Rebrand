---
import { Icon } from 'astro-icon/components';
import { views, viewQuiz } from '../consts';

const services = [
	{ icon: 'mdi:code-tags', label: 'Software development', sub: 'Web & mobile apps' },
	{ icon: 'mdi:palette-outline', label: 'Design & branding', sub: 'UI/UX that converts' },
	{ icon: 'mdi:bullhorn-outline', label: 'Marketing & growth', sub: 'SEO, ads, content' },
	{ icon: 'mdi:compass-outline', label: 'Product strategy', sub: 'From idea to roadmap' },
	{ icon: 'mdi:server', label: 'Hosting & maintenance', sub: 'We stay after launch' },
	{ icon: 'mdi:school-outline', label: 'Free tech bootcamp', sub: 'Learn, build, get hired' },
];

const proof = [
	{ n: '65+', label: 'products shipped' },
	{ n: '7+', label: 'years building' },
	{ n: '10+', label: 'countries served' },
];
---

<div id="view-onboarding" class="vo" data-open="false" aria-hidden="true">
	<div class="vo__scrim" data-vo-close></div>

	<div
		class="vo__panel"
		role="dialog"
		aria-modal="true"
		aria-label="Welcome to Swizel"
	>
		<button class="vo__skip" type="button" data-vo-skip aria-label="Close and browse">
			<Icon width={16} name="mdi:close" />
		</button>

		<div class="vo__progress" aria-hidden="true">
			<span class="vo__progressbar" id="vo-bar"></span>
		</div>

		<!-- Welcome: the full pitch, in case this is all they ever see -->
		<section class="vo__step is-active" data-step="intro">
			<span class="vo__hello" aria-hidden="true">
				<span class="vo__hello-ring"></span>
				<span class="vo__hello-ring vo__hello-ring--2"></span>
				<svg class="vo__hello-mark" viewBox="0 0 1825 1182" xmlns="http://www.w3.org/2000/svg">
					<path d="M1107.42 708.786H1468.28V1181.19H1107.42V708.786Z" fill="#86E2EF"/>
					<path d="M1102.61 0.753906H1680.34C1759.86 0.753906 1824.34 65.2249 1824.34 144.754V656.868H1102.61V0.753906Z" fill="#377781"/>
					<path d="M0.334961 144.754C0.334961 65.2247 64.806 0.753906 144.335 0.753906H1050.12V1181.76H0.334961V144.754Z" fill="#2F4F4F"/>
				</svg>
			</span>
			<span class="vo__kicker">Swizel Technologies Limited</span>
			<h2 class="vo__title">
				We turn ideas into<br />
				<span class="gradient-text">products people love.</span>
			</h2>
			<p class="vo__lead">
				Software, design and marketing — one team that takes you from a
				blank page to a launched product, then stays to grow it.
			</p>

			<ul class="vo__services">
				{
					services.map((s) => (
						<li class="vo__service">
							<span class="vo__service-ico">
								<Icon width={18} name={s.icon} />
							</span>
							<span class="vo__service-txt">
								<strong>{s.label}</strong>
								<em>{s.sub}</em>
							</span>
						</li>
					))
				}
			</ul>

			<ul class="vo__proof">
				{
					proof.map((p) => (
						<li>
							<strong>{p.n}</strong> {p.label}
						</li>
					))
				}
			</ul>

			<div class="vo__divider">
				<span class="vo__divider-line"></span>
				<span class="vo__divider-txt">Here's the twist</span>
				<span class="vo__divider-line"></span>
			</div>

			<p class="vo__lead vo__lead--tight">
				This website reshapes itself around <strong>you</strong>. Answer
				two quick questions and we'll build the experience around what
				you care about — switch anytime, nothing is locked.
			</p>

			<div class="vo__actions">
				<button class="vo__cta" type="button" data-vo-start>
					Make it mine
					<Icon width={18} name="mdi:arrow-right" />
				</button>
				<a class="vo__cta vo__cta--ghost" href="/contact">
					Start a project
				</a>
				<button class="vo__textbtn" type="button" data-vo-explore>
					See all views
				</button>
			</div>
		</section>

		<!-- Two questions -->
		{
			viewQuiz.map((q, qi) => (
				<section class="vo__step" data-step={`q${qi}`}>
					<div class="vo__stephead">
						<button class="vo__back" type="button" data-vo-back>
							<Icon width={16} name="mdi:arrow-left" />
							Back
						</button>
						<span class="vo__qcount">
							{qi + 1} / {viewQuiz.length}
						</span>
					</div>
					<h3 class="vo__q">{q.q}</h3>
					<p class="vo__hint">{q.hint}</p>
					<div class="vo__options">
						{q.options.map((o) => (
							<button
								class="vo__opt"
								type="button"
								data-scores={JSON.stringify(o.scores)}
								data-q={qi}
							>
								<span class="vo__opt-ico">
									<Icon width={20} name={o.icon} />
								</span>
								<span class="vo__opt-txt">
									<strong>{o.label}</strong>
									<em>{o.sub}</em>
								</span>
								<span class="vo__opt-check">
									<Icon width={15} name="mdi:check-bold" />
								</span>
							</button>
						))}
					</div>
				</section>
			))
		}

		<!-- Results -->
		<section class="vo__step" data-step="results">
			<div class="vo__stephead">
				<button class="vo__back" type="button" data-vo-back>
					<Icon width={16} name="mdi:arrow-left" />
					Back
				</button>
			</div>
			<span class="vo__kicker" id="vo-rec-kicker">Recommendation</span>
			<h2 class="vo__title">
				We think you fit best in
				<span class="gradient-text" id="vo-rec-name">Boardroom</span>
			</h2>
			<p class="vo__lead">
				Same Swizel, told your way. Every view carries everything we do —
				pick one to enter, and switch whenever you like from the
				navigation.
			</p>
			<div class="vo__grid">
				{
					views.map((v) => (
						<button
							class="vo__card"
							type="button"
							data-view-id={v.id}
							style={`--va:${v.accent}`}
						>
							<span class="vo__card-top">
								<span class="vo__card-ico">
									<Icon width={22} name={v.icon} />
								</span>
								<span class="vo__card-badge">Recommended</span>
							</span>
							<span class="vo__card-name">{v.name}</span>
							<span class="vo__card-aud">{v.audience}</span>
							<span class="vo__card-blurb">{v.blurb}</span>
							<span class="vo__card-cta">
								Enter view
								<Icon width={15} name="mdi:arrow-right" />
							</span>
						</button>
					))
				}
			</div>
		</section>
	</div>
</div>

<style>
	/* Theme tokens — light by default, dark via html.dark */
	.vo {
		--ob-panel: linear-gradient(180deg, #ffffff, #f4f8f8);
		--ob-border: rgba(20, 22, 40, 0.1);
		--ob-ink: #14162a;
		--ob-muted: rgba(20, 22, 40, 0.64);
		--ob-faint: rgba(20, 22, 40, 0.45);
		--ob-card: rgba(20, 22, 40, 0.035);
		--ob-card-border: rgba(20, 22, 40, 0.12);
		--ob-track: rgba(20, 22, 40, 0.08);

		position: fixed;
		inset: 0;
		z-index: 1000;
		display: none;
		align-items: center;
		justify-content: center;
		padding: 1.25rem;
	}
	:global(html.dark) .vo {
		--ob-panel: linear-gradient(180deg, #1c1e30, #14151f);
		--ob-border: rgba(255, 255, 255, 0.1);
		--ob-ink: #ffffff;
		--ob-muted: rgba(255, 255, 255, 0.68);
		--ob-faint: rgba(255, 255, 255, 0.45);
		--ob-card: rgba(255, 255, 255, 0.03);
		--ob-card-border: rgba(255, 255, 255, 0.12);
		--ob-track: rgba(255, 255, 255, 0.08);
	}
	.vo[data-open='true'] {
		display: flex;
	}
	.vo__scrim {
		position: absolute;
		inset: 0;
		background: rgba(8, 9, 16, 0.72);
		backdrop-filter: blur(10px);
		animation: vo-fade 0.4s ease both;
	}
	.vo__panel {
		position: relative;
		width: min(100%, 940px);
		max-height: 92vh;
		overflow-y: auto;
		border-radius: 1.5rem;
		padding: clamp(1.4rem, 2.5vw, 2rem) clamp(1.4rem, 3vw, 2.5rem);
		background: var(--ob-panel);
		border: 1px solid var(--ob-border);
		box-shadow: 0 60px 120px -40px rgba(0, 0, 0, 0.8);
		color: var(--ob-ink);
		animation: vo-pop 0.5s cubic-bezier(0.22, 1, 0.36, 1) both;
	}
	@keyframes vo-fade {
		from {
			opacity: 0;
		}
	}
	@keyframes vo-pop {
		from {
			opacity: 0;
			transform: translateY(24px) scale(0.96);
		}
	}

	.vo__skip {
		position: sticky;
		top: 0;
		margin: -0.3rem 0 0.2rem auto;
		display: grid;
		place-items: center;
		width: 38px;
		height: 38px;
		border-radius: 9999px;
		border: 1px solid var(--ob-card-border);
		background: var(--ob-panel);
		color: var(--ob-faint);
		transition: color 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
		z-index: 5;
	}
	.vo__skip:hover {
		color: var(--ob-ink);
		border-color: var(--ob-ink);
		transform: rotate(90deg);
	}

	.vo__progress {
		height: 4px;
		border-radius: 9999px;
		background: var(--ob-track);
		overflow: hidden;
		margin-bottom: 1.1rem;
	}
	.vo__progressbar {
		display: block;
		height: 100%;
		width: 0%;
		border-radius: 9999px;
		background: linear-gradient(90deg, #13b6a0, #13a8bf, #1f8fd6);
		transition: width 0.5s cubic-bezier(0.22, 1, 0.36, 1);
	}

	.vo__step {
		display: none;
		animation: vo-step 0.45s cubic-bezier(0.22, 1, 0.36, 1) both;
	}
	.vo__step.is-active {
		display: block;
	}
	@keyframes vo-step {
		from {
			opacity: 0;
			transform: translateX(24px);
		}
	}
	/* reverse slide when navigating back */
	.vo__step.is-back {
		animation-name: vo-step-back;
	}
	@keyframes vo-step-back {
		from {
			opacity: 0;
			transform: translateX(-24px);
		}
	}

	.vo__stephead {
		display: flex;
		align-items: center;
		justify-content: space-between;
		margin-bottom: 1.25rem;
	}
	.vo__back {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		font-size: 0.85rem;
		font-weight: 600;
		color: var(--ob-faint);
		transition: color 0.2s ease, transform 0.2s ease;
	}
	.vo__back:hover {
		color: var(--ob-ink);
		transform: translateX(-3px);
	}

	.vo__kicker,
	.vo__qcount {
		display: inline-block;
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: #0e9c8b;
		margin-bottom: 0.55rem;
	}
	:global(html.dark) .vo .vo__kicker,
	:global(html.dark) .vo .vo__qcount {
		color: #86e2ef;
	}
	.vo__qcount {
		margin-bottom: 0;
		color: var(--ob-faint);
		font-family: ui-monospace, monospace;
	}
	.vo__title {
		font-family: 'Bebas Neue', sans-serif;
		font-size: clamp(1.9rem, 3.6vw, 2.5rem);
		line-height: 1.02;
		letter-spacing: 1px;
		text-transform: uppercase;
		margin: 0 0 0.6rem;
	}
	.vo__q {
		font-size: clamp(1.6rem, 3.2vw, 2.3rem);
		font-weight: 800;
		line-height: 1.15;
		margin: 0 0 0.35rem;
	}
	.vo__hint {
		color: var(--ob-faint);
		font-size: 0.92rem;
		margin: 0 0 1.5rem;
	}
	.vo__lead {
		color: var(--ob-muted);
		font-size: 0.96rem;
		line-height: 1.55;
		max-width: 60ch;
		margin: 0 0 1rem;
	}
	.vo__lead--tight {
		margin-bottom: 1.1rem;
	}
	.vo__lead strong {
		color: var(--ob-ink);
	}

	/* Welcome mark — floating brand orb with soft radar rings */
	.vo__hello {
		position: relative;
		display: grid;
		place-items: center;
		width: 44px;
		height: 44px;
		margin-bottom: 0.7rem;
		border-radius: 1.1rem;
		background: linear-gradient(135deg, rgba(19, 182, 160, 0.14), rgba(31, 143, 214, 0.14));
		border: 1px solid var(--ob-card-border);
		animation: vo-hello-float 4.5s ease-in-out infinite;
	}
	.vo__hello-mark {
		width: 22px;
		height: auto;
	}
	.vo__hello-ring {
		position: absolute;
		inset: 0;
		border-radius: 1.1rem;
		border: 1px solid rgba(19, 182, 160, 0.55);
		animation: vo-hello-ring 2.8s ease-out infinite;
	}
	.vo__hello-ring--2 {
		animation-delay: 1.4s;
	}
	@keyframes vo-hello-float {
		0%,
		100% {
			transform: translateY(0);
		}
		50% {
			transform: translateY(-5px);
		}
	}
	@keyframes vo-hello-ring {
		0% {
			opacity: 0.8;
			transform: scale(1);
		}
		100% {
			opacity: 0;
			transform: scale(1.45);
		}
	}

	/* Welcome: services + proof */
	.vo__services {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 0.5rem;
		margin: 0 0 0.9rem;
	}
	/* staggered entrance for the service cards each time the step shows */
	.vo__step.is-active .vo__service {
		animation: vo-rise 0.5s cubic-bezier(0.22, 1, 0.36, 1) both;
	}
	.vo__step.is-active .vo__service:nth-child(1) { animation-delay: 0.05s; }
	.vo__step.is-active .vo__service:nth-child(2) { animation-delay: 0.11s; }
	.vo__step.is-active .vo__service:nth-child(3) { animation-delay: 0.17s; }
	.vo__step.is-active .vo__service:nth-child(4) { animation-delay: 0.23s; }
	.vo__step.is-active .vo__service:nth-child(5) { animation-delay: 0.29s; }
	.vo__step.is-active .vo__service:nth-child(6) { animation-delay: 0.35s; }
	@keyframes vo-rise {
		from {
			opacity: 0;
			transform: translateY(12px);
		}
	}
	.vo__service {
		transition: border-color 0.25s ease, transform 0.25s ease;
	}
	.vo__service:hover {
		border-color: #13b6a0;
		transform: translateY(-2px);
	}
	@media (max-width: 880px) {
		.vo__services { grid-template-columns: repeat(2, minmax(0, 1fr)); }
	}
	@media (max-width: 560px) {
		.vo__services { grid-template-columns: 1fr; }
	}
	.vo__service {
		display: flex;
		align-items: center;
		gap: 0.55rem;
		padding: 0.5rem 0.65rem;
		border-radius: 0.8rem;
		border: 1px solid var(--ob-card-border);
		background: var(--ob-card);
	}
	.vo__service-ico {
		display: grid;
		place-items: center;
		width: 30px;
		height: 30px;
		flex-shrink: 0;
		border-radius: 0.6rem;
		background: linear-gradient(135deg, rgba(19, 182, 160, 0.16), rgba(31, 143, 214, 0.14));
		color: #0e9c8b;
	}
	:global(html.dark) .vo .vo__service-ico {
		color: #5eead4;
	}
	.vo__service-txt {
		display: flex;
		flex-direction: column;
		line-height: 1.25;
	}
	.vo__service-txt strong {
		font-size: 0.8rem;
		font-weight: 700;
	}
	.vo__service-txt em {
		font-style: normal;
		font-size: 0.7rem;
		color: var(--ob-faint);
	}

	.vo__proof {
		display: flex;
		flex-wrap: wrap;
		gap: 0.3rem 1.4rem;
		margin: 0 0 0.9rem;
		font-size: 0.84rem;
		color: var(--ob-muted);
	}
	.vo__proof strong {
		font-family: 'Bebas Neue', sans-serif;
		font-size: 1.1rem;
		letter-spacing: 0.5px;
		color: var(--ob-ink);
		margin-right: 0.2rem;
	}

	.vo__divider {
		display: flex;
		align-items: center;
		gap: 0.9rem;
		margin: 0 0 0.8rem;
	}
	.vo__divider-line {
		flex: 1;
		height: 1px;
		background: var(--ob-card-border);
	}
	.vo__divider-txt {
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--ob-faint);
	}

	.vo__actions {
		display: flex;
		align-items: center;
		gap: 1rem;
		flex-wrap: wrap;
	}
	.vo__cta {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.04em;
		font-size: 0.85rem;
		color: #03231d;
		background: linear-gradient(95deg, #13b6a0, #13a8bf 50%, #1f8fd6);
		padding: 0.75rem 1.4rem;
		border-radius: 9999px;
		box-shadow: 0 14px 30px -12px rgba(19, 168, 191, 0.55);
		transition: transform 0.25s ease, box-shadow 0.25s ease;
	}
	.vo__cta:hover {
		transform: translateY(-2px);
		box-shadow: 0 20px 40px -12px rgba(31, 143, 214, 0.6);
	}
	.vo__cta--ghost {
		color: var(--ob-ink);
		background: transparent;
		border: 1.5px solid var(--ob-card-border);
		box-shadow: none;
	}
	.vo__cta--ghost:hover {
		border-color: #13b6a0;
		box-shadow: none;
	}
	.vo__textbtn {
		font-weight: 600;
		color: var(--ob-faint);
		transition: color 0.2s ease;
	}
	.vo__textbtn:hover {
		color: var(--ob-ink);
	}

	/* Options */
	.vo__options {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.75rem;
	}
	@media (max-width: 640px) {
		.vo__options {
			grid-template-columns: 1fr;
		}
	}
	.vo__opt {
		display: flex;
		align-items: center;
		gap: 0.85rem;
		text-align: left;
		padding: 0.95rem 1.1rem;
		border-radius: 1rem;
		border: 1px solid var(--ob-card-border);
		background: var(--ob-card);
		color: var(--ob-ink);
		cursor: pointer;
		transition: border-color 0.25s ease, background 0.25s ease,
			transform 0.25s ease;
	}
	.vo__opt:hover {
		border-color: #13b6a0;
		background: rgba(19, 182, 160, 0.07);
		transform: translateX(4px);
	}
	.vo__opt-ico {
		display: grid;
		place-items: center;
		width: 40px;
		height: 40px;
		flex-shrink: 0;
		border-radius: 0.8rem;
		background: linear-gradient(135deg, rgba(19, 182, 160, 0.14), rgba(31, 143, 214, 0.12));
		color: #0e9c8b;
	}
	:global(html.dark) .vo .vo__opt-ico {
		color: #5eead4;
	}
	.vo__opt-txt {
		display: flex;
		flex-direction: column;
		line-height: 1.3;
		flex: 1;
	}
	.vo__opt-txt strong {
		font-size: 0.95rem;
		font-weight: 700;
	}
	.vo__opt-txt em {
		font-style: normal;
		font-size: 0.78rem;
		color: var(--ob-faint);
	}
	.vo__opt-check {
		display: grid;
		place-items: center;
		width: 22px;
		height: 22px;
		flex-shrink: 0;
		border-radius: 9999px;
		background: #13b6a0;
		color: #03231d;
		opacity: 0;
		transform: scale(0.4);
		transition: opacity 0.2s ease, transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
	}
	.vo__opt.is-selected {
		border-color: #13b6a0;
		background: rgba(19, 182, 160, 0.09);
	}
	.vo__opt.is-selected .vo__opt-check {
		opacity: 1;
		transform: scale(1);
	}

	/* Results grid */
	.vo__grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
		gap: 0.9rem;
		margin-top: 0.5rem;
	}
	.vo__card {
		text-align: left;
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
		padding: 1.25rem;
		border-radius: 1.1rem;
		border: 1px solid var(--ob-card-border);
		background: var(--ob-card);
		cursor: pointer;
		transition: border-color 0.25s ease, background 0.25s ease,
			transform 0.25s ease;
		position: relative;
	}
	.vo__card:hover {
		transform: translateY(-4px);
		border-color: var(--va);
	}
	.vo__card-top {
		display: flex;
