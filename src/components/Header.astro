---
import Icon from 'astro-icon';
import CustomButton from './CustomButton.astro';
import Link from './Link.astro';
import { formatLink, links } from '../consts';
import { disciplines } from '../data/disciplines';

// Keep "Services" highlighted across the hub AND every /services/<slug> page.
const onServices = Astro.url.pathname.startsWith('/services');
---

<header
	class="site-header py-5 px-[5%] top-0 z-20 sticky"
	id="navbar--header"
>
	<div class="container flex items-center justify-between mx-auto">
		<div class="flex-[0.2]">
			<Link
				class="site-logo text-swizelGreen w-fit block"
				aria-label="Swizel"
				href="/"
			>
				<Icon width={124} name="swizel" />
			</Link>
		</div>
		<div class="flex items-center justify-between col-span-2 flex-[0.8]">
			<div
				class="xl:hidden flex-1 flex items-center justify-end gap-3"
				style="color: var(--nav-ink);"
			>
				<button
					class="view-switch view-switch--icon"
					type="button"
					data-open-views
					aria-label="Switch site view"
				>
					<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/></svg>
				</button>
				<button
					class="theme-toggle"
					type="button"
					role="switch"
					aria-checked="false"
					aria-label="Toggle dark mode"
					data-theme-toggle
				>
					<svg
						class="tt-ico tt-sun"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2.2"
						stroke-linecap="round"
					>
						<circle cx="12" cy="12" r="4.2"></circle>
						<path
							d="M12 1.5v2.5M12 20v2.5M3.5 3.5l1.8 1.8M18.7 18.7l1.8 1.8M1.5 12h2.5M20 12h2.5M3.5 20.5l1.8-1.8M18.7 5.3l1.8-1.8"
						></path>
					</svg>
					<svg class="tt-ico tt-moon" viewBox="0 0 24 24" fill="currentColor">
						<path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"></path>
					</svg>
				</button>
				<button id="toggler-show" aria-label="show menu" type="button">
					<Icon size={28} name="hamburger" />
				</button>
			</div>
			<nav
				class="xl:flex hidden items-center md:ml-9 gap-x-10 justify-between text-[1.05rem] font-medium gap-8 xl:pl-7"
			>
				<Link href="/">Home</Link>
				{
					links.map((link) =>
						link === 'services' ? (
							<div class="nav-dd">
								<Link class:list={['capitalize nav-dd-trigger', { active: onServices }]} href="/services">
									{formatLink(link)}
									<svg class="nav-dd-caret" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9" /></svg>
								</Link>
								<div class="nav-dd-panel">
									<a href="/services" class="nav-dd-item nav-dd-item--over">
										<span class="nav-dd-ic">
											<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1" /><rect x="14" y="3" width="7" height="7" rx="1" /><rect x="14" y="14" width="7" height="7" rx="1" /><rect x="3" y="14" width="7" height="7" rx="1" /></svg>
										</span>
										<span class="nav-dd-txt">
											<strong>Services Overview</strong>
											<em>Everything we do, in one place</em>
										</span>
									</a>
									<span class="nav-dd-sep" />
									{disciplines.map((d) => (
										<a href={`/services/${d.slug}`} class="nav-dd-item" style={`--c:${d.color}`}>
											<span class="nav-dd-ic">
												<Icon width={18} name={d.icon} />
											</span>
											<span class="nav-dd-txt">
												<strong>{d.title}</strong>
												<em>{d.tagline}</em>
											</span>
										</a>
									))}
								</div>
							</div>
						) : (
							<Link class="capitalize" href={`/${link}`}>
								{formatLink(link)}
							</Link>
						)
					)
				}
				<!-- <Link
					download="The Brevarium by Swizel"
					href="/The Brevarium by Swizel.pdf"
				>
					The Brevarium
				</Link> -->
			</nav>
			<div class="hidden xl:flex items-center gap-4">
				<button
					class="view-switch"
					type="button"
					data-open-views
					aria-label="Switch site view"
				>
					<svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/></svg>
					<span>Views</span>
				</button>
				<button
					id="theme-toggle"
					class="theme-toggle"
					type="button"
					role="switch"
					aria-checked="false"
					aria-label="Toggle dark mode"
					data-theme-toggle
				>
					<svg
						class="tt-ico tt-sun"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2.2"
						stroke-linecap="round"
					>
						<circle cx="12" cy="12" r="4.2"></circle>
						<path
							d="M12 1.5v2.5M12 20v2.5M3.5 3.5l1.8 1.8M18.7 18.7l1.8 1.8M1.5 12h2.5M20 12h2.5M3.5 20.5l1.8-1.8M18.7 5.3l1.8-1.8"
						></path>
					</svg>
					<svg class="tt-ico tt-moon" viewBox="0 0 24 24" fill="currentColor">
						<path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"></path>
					</svg>
				</button>
				<CustomButton
					elementType="a"
					class="nav-cta flex"
					variant="outline"
					href="/contact"
					notRounded
				>
					Contact
				</CustomButton>
			</div>
		</div>
	</div>

	<div
		id="mobile-wrapper"
		role="dialog"
		class="fixed z-[15] xl:hidden inset-0 overflow-x-hidden"
	>
		<div id="close-overlay" class="fixed inset-0 bg-black/40"></div>
		<div
			id="mobile-menu"
			class="fixed left-0 h-full top-0 bg-swizelDark shadow-[-4px_0px_3px_1px_rgba(0,0,0,0.2)] border-l border-swizelDark"
		>
			<div class="py-4 px-5">
				<div class="flex items-center justify-between gap-4">
					<Link
						class="text-swizelGreen w-fit block"
						aria-label="Swizel"
						href="/"
					>
						<Icon width={123} name="swizel" />
					</Link>
					<button
						id="toggler-hide"
						aria-label="show menu"
						type="button"
					>
						<Icon size={35} name="close" />
					</button>
				</div>

				<nav class="mt-16">
					<ul
						class="grid gap-8 pl-2 text-white my-8 duration-300 apitalize whitespace-nowrap"
					>
						<Link class="whitespace-nowrap" href="/">Home</Link>
						{
							links.map((link) =>
								link === 'services' ? (
									<li class="capitalize">
										<details class="nav-m-dd" open={onServices}>
											<summary>
												<Link class:list={[{ active: onServices }]} href="/services">{formatLink(link)}</Link>
												<svg class="nav-m-caret" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9" /></svg>
											</summary>
											<ul class="nav-m-sub">
												<li><a href="/services">Services Overview</a></li>
												{disciplines.map((d) => (
													<li><a href={`/services/${d.slug}`}>{d.title}</a></li>
												))}
											</ul>
										</details>
									</li>
								) : (
									<li class="capitalize">
										<Link class="hover:text-white/60" href={`/${link}`}>
											{formatLink(link)}
										</Link>
									</li>
								)
							)
						}
						<!-- <Link
							download="The Brevarium by Swizel"
							href="/The Brevarium by Swizel.pdf"
						>
							The Brevarium
						</Link> -->
						<li>
							<CustomButton
								elementType="a"
								class="block max-w-[140px] mt-14 !border-white/60"
								variant="outline"
								href="/contact"
								notRounded
							>
								Contact
							</CustomButton>
						</li>
					</ul>
				</nav>
			</div>
		</div>
	</div>
</header>

<style>
	#mobile-wrapper {
		width: 0;
	}

	#mobile-wrapper[data-expanded='true'] {
		width: auto;
		transition: 0.5s;
		/* transition-timing-function: linear;t */
	}
	#mobile-wrapper > div {
		width: 0;
		transition: 0.7s ease;
		/* transition-timing-function: linear; */
		overflow-x: hidden;
	}
	#mobile-wrapper #close-overlay {
		width: 0;
		transition: opacity 0.5s;
		/* transition-timing-function: linear; */
		opacity: 0;
	}
	#mobile-wrapper[data-expanded='true'] #close-overlay {
		width: 100vw;
		transform-origin: right;
		opacity: 1;
		cursor: pointer;
	}
	#mobile-wrapper #mobile-menu > * {
		display: none;
	}
	#mobile-wrapper[data-expanded='true'] #mobile-menu {
		width: 350px;
	}
	#mobile-wrapper[data-expanded='true'] #mobile-menu > * {
		display: block;
	}

	.header-sticky {
		box-shadow: 0 2px 3px 4px rgba(0, 0, 0, 0.19);
	}

	@media (max-width: 380px) {
		#mobile-wrapper[data-expanded='true'] #mobile-menu {
			width: 300px;
		}
	}

	/* ── Desktop Services dropdown ── */
	.nav-dd { position: relative; }
	.nav-dd-trigger { display: inline-flex; align-items: center; gap: 0.28rem; }
	.nav-dd-caret { transition: transform 0.25s ease; opacity: 0.8; }
	.nav-dd:hover .nav-dd-caret,
	.nav-dd:focus-within .nav-dd-caret { transform: rotate(180deg); }
	.nav-dd-panel {
		position: absolute;
		top: 100%;
		left: 50%;
		transform: translateX(-50%) translateY(8px);
		margin-top: 14px;
		width: 340px;
		padding: 0.5rem;
		display: grid;
		gap: 0.1rem;
		border-radius: 1.1rem;
		background: #12152a;
		border: 1px solid rgba(255, 255, 255, 0.12);
		box-shadow: 0 40px 90px -30px rgba(0, 0, 0, 0.7);
		opacity: 0;
		visibility: hidden;
		pointer-events: none;
		transition: opacity 0.25s ease, transform 0.32s cubic-bezier(0.22, 1, 0.36, 1), visibility 0.25s;
		z-index: 50;
	}
	:global(html:not(.dark)) .nav-dd-panel { background: #ffffff; border-color: rgba(20, 22, 40, 0.1); box-shadow: 0 40px 90px -30px rgba(20, 22, 40, 0.28); }
	/* invisible bridge so the gap doesn't drop the hover */
	.nav-dd-panel::before { content: ''; position: absolute; left: 0; right: 0; top: -16px; height: 16px; }
	.nav-dd:hover .nav-dd-panel,
	.nav-dd:focus-within .nav-dd-panel { opacity: 1; visibility: visible; pointer-events: auto; transform: translateX(-50%) translateY(0); }
	.nav-dd-item {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		padding: 0.6rem 0.7rem;
		border-radius: 0.7rem;
		color: #e9eaf2;
		transition: background 0.2s ease;
	}
	:global(html:not(.dark)) .nav-dd-item { color: #14162a; }
	.nav-dd-item:hover { background: color-mix(in srgb, var(--c, #28a6ec) 14%, transparent); }
	.nav-dd-ic {
		display: grid; place-items: center; width: 38px; height: 38px; flex-shrink: 0; border-radius: 0.6rem;
		color: var(--c, #28a6ec);
		background: color-mix(in srgb, var(--c, #28a6ec) 14%, transparent);
		border: 1px solid color-mix(in srgb, var(--c, #28a6ec) 28%, transparent);
	}
	.nav-dd-txt { display: flex; flex-direction: column; line-height: 1.2; min-width: 0; }
	.nav-dd-txt strong { font-size: 0.92rem; font-weight: 700; }
	.nav-dd-txt em { font-style: normal; font-size: 0.74rem; opacity: 0.6; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
	.nav-dd-item--over .nav-dd-ic { color: #9bd8ff; background: rgba(155, 216, 255, 0.14); border-color: rgba(155, 216, 255, 0.3); }
	.nav-dd-sep { display: block; height: 1px; margin: 0.35rem 0.6rem; background: rgba(255, 255, 255, 0.1); }
	:global(html:not(.dark)) .nav-dd-sep { background: rgba(20, 22, 40, 0.1); }

	/* ── Mobile Services accordion ── */
	.nav-m-dd > summary { display: flex; align-items: center; justify-content: space-between; list-style: none; cursor: pointer; gap: 0.5rem; }
	.nav-m-dd > summary::-webkit-details-marker { display: none; }
	.nav-m-caret { transition: transform 0.25s ease; opacity: 0.7; flex-shrink: 0; }
	.nav-m-dd[open] > summary .nav-m-caret { transform: rotate(180deg); }
	.nav-m-sub { list-style: none; padding: 0.6rem 0 0.2rem 0.9rem; margin: 0.4rem 0 0; display: grid; gap: 0.7rem; border-left: 1px solid rgba(255, 255, 255, 0.16); }
	.nav-m-sub a { font-size: 0.95rem; color: rgba(255, 255, 255, 0.7); transition: color 0.2s ease; }
	.nav-m-sub a:hover { color: #fff; }
</style>
