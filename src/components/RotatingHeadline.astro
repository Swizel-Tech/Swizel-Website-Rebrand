---
// The permanent Swizel signature: "You Imagine. / We Build · Design · Scale · Launch."
// Reused across every view so the swapping headline is a constant.
interface Props {
	class?: string;
}
const { class: className = '' } = Astro.props;
const words = ['Build.', 'Design.', 'Scale.', 'Launch.'];
---

<h1 class:list={['rhead font-bebas', className]}>
	<span class="rhead__l1">You Imagine.</span>
	<span class="rhead__l2">
		<span>We</span>
		<span class="rhead__rot" aria-hidden="true">
			{
				words.map((w, i) => (
					<span class="rhead__w gradient-text" style={`--i:${i}`}>
						{w}
					</span>
				))
			}
		</span>
		<span class="rhead__sr">We build, design, scale and launch.</span>
	</span>
</h1>

<style>
	.rhead {
		font-weight: 800;
		text-transform: uppercase;
		line-height: 0.92;
		letter-spacing: 1px;
		margin: 0;
		color: #fff;
		-webkit-text-fill-color: #fff;
		font-size: clamp(2.6rem, 6vw, 5rem);
	}
	.rhead__l1 {
		display: block;
	}
	.rhead__l2 {
		display: flex;
		gap: 0.3em;
		align-items: baseline;
	}
	.rhead__rot {
		display: inline-grid;
	}
	.rhead__w {
		grid-area: 1 / 1;
		opacity: 0;
		transform: translateY(0.4em) rotateX(-50deg);
		animation: rhead-cycle 9.2s infinite;
		animation-delay: calc(var(--i) * 2.3s);
		white-space: nowrap;
		text-align: left;
	}
	@keyframes rhead-cycle {
		0% {
			opacity: 0;
			transform: translateY(0.42em) rotateX(-55deg);
		}
		4%,
		21% {
			opacity: 1;
			transform: translateY(0) rotateX(0);
		}
		26%,
		100% {
			opacity: 0;
			transform: translateY(-0.42em) rotateX(55deg);
		}
	}
	.rhead__sr {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}
	@media (prefers-reduced-motion: reduce) {
		.rhead__w {
			animation: none !important;
		}
		.rhead__w:first-child {
			opacity: 1;
			transform: none;
		}
	}
</style>
