---
import MailChimpInput from './MailChimpInput.astro';
---

<div id="mc_embed_shell">
	<link
		href="//cdn-images.mailchimp.com/embedcode/classic-061523.css"
		rel="stylesheet"
		type="text/css"
	/>

	<div id="mc_embed_signup">
		<form
			action="https://swizel.us21.list-manage.com/subscribe/post?u=be2d7317985c5a637d604b8e5&id=5164502885&f_id=00ece3e6f0"
			method="post"
			id="mc-embedded-subscribe-form"
			name="mc-embedded-subscribe-form"
			class="validate"
			target="_blank"
		>
			<div id="mc_embed_signup_scroll">
				<div class="indicates-required">
					<span class="asterisk">*</span> indicates required
				</div>
				<MailChimpInput
					label="What is your email address? "
					type="email"
					name="EMAIL"
					class="required email"
					id="mce-EMAIL"
					required=""
					value=""
				/>
				<MailChimpInput
					type="text"
					name="FULLNAME"
					class="required text"
					id="mce-FULLNAME"
					required=""
					label="What's your name ?"
					value=""
				/>
				<MailChimpInput
					type="text"
					name="PHONE"
					class="REQ_CSS"
					id="mce-PHONE"
					value=""
					label="What is your phone number? (optional)"
				/>
				<MailChimpInput
					class="mc-field-group"
					label="Type a message"
					type="text"
					name="MESSAGE"
					class="required text text_area__input"
					id="mce-MESSAGE"
					required=""
					value=""
				/>
				<div id="mce-responses" class="clear foot">
					<div class="response" id="mce-error-response" style="display: none;"></div>
					<div class="response" id="mce-success-response" style="display: none;"></div>
				</div>
				<div aria-hidden="true" style="position: absolute; left: -5000px;">
					<input
						type="text"
						name="b_be2d7317985c5a637d604b8e5_5164502885"
						tabindex="-1"
						value=""
					/>
				</div>
				<div class="optionalParent">
					<div class="clear foot">
						<input
							type="submit"
							name="subscribe"
							id="mc-embedded-subscribe"
							class="button"
							value="Submit"
						/>
						<p class="opacity-0" style="margin: 0px auto;">
							<a
								href="http://eepurl.com/iy0kqY"
								title="Mailchimp - email marketing made easy and fun"
								><span
									style="display: inline-block; background-color: transparent; border-radius: 4px;"
									><img
										class="refferal_badge"
										src="https://digitalasset.intuit.com/render/content/dam/intuit/mc-fe/en_us/images/intuit-mc-rewards-text-dark.svg"
										alt="Intuit Mailchimp"
										style="width: 220px; height: 40px; display: flex; padding: 2px 0px; justify-content: center; align-items: center;"
									/></span
								></a
							>
						</p>
					</div>
				</div>
			</div>
		</form>
	</div>
	<script
		type="text/javascript"
		src="//s3.amazonaws.com/downloads.mailchimp.com/js/mc-validate.js"
		is:inline
	></script><script type="text/javascript">
		(function ($) {
			window.fnames = new Array();
			window.ftypes = new Array();
			fnames[0] = 'EMAIL';
			ftypes[0] = 'email';
			fnames[1] = 'FULLNAME';
			ftypes[1] = 'text';
			fnames[4] = 'PHONE';
			ftypes[4] = 'phone';
			fnames[2] = 'MESSAGE';
			ftypes[2] = 'text';
		})(jQuery);
		var $mcj = jQuery.noConflict(true);
	</script>
</div>

<style type="text/css" is:inline>
	#mc_embed_signup {
	}

	#mc_embed_signup .mc-field-group input {
		height: 50px;
		border-radius: 20px;
		padding-inline: 10px;
		color: #fff;
	}
	#mc_embed_signup .mc-field-group .text_area__input {
		height: 100px;
		display: flex;
		align-items: start;
		justify-content: start;
	}

	#mc_embed_signup #mc-embedded-subscribe-form div.mce_inline_error {
		background-color: transparent;
		font-size: 12px;
	}

	#mc_embed_signup .button {
		background-color: #428776;
		padding: 10px 20px;
		font-weight: 600;
		height: auto;
		border-radius: 100px;
		display: flex;
		align-items: center;
		justify-content: center;
		width: auto;
		max-width: 200px;
	}
</style>
