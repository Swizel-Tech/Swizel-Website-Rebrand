---
import { Icon } from 'astro-icon/components';
import CustomButton from '../CustomButton.astro';
import AccentHeader from '../HTML/AccentHeader.astro';
import Heading from '../HTML/Heading.astro';
---

<div
	class="bg-[#FDF0E9] md:px-10 xl:px-28 grid md:grid-cols-3 md:max-lg:grid-cols-2 md:gap-4 relative"
>
	<div class="space-y-5 py-16 max-md:pb-10 sm:px-16 lg:px-0 px-9 relative">
		<div class="absolute top-0 -translate-y-1/2">
			<Icon name="shinny-star" class="w-[100px] sm:w-[140px]" />
		</div>
		<AccentHeader>Get Started</AccentHeader>
		<Heading type="h4" className="max-w-xs md:leading-[1.25]">
			We Help Companies Move Faster
		</Heading>
		<div>
			<CustomButton elementType="a" href="/contact">
				Contact Us
			</CustomButton>
		</div>
	</div>
	<div class="flex items-center md:max-lg:hidden justify-center">
		<img
			src="/images/portfolio--cta.svg"
			class="md:max-h-[200px] w-full object-cover"
			alt=""
		/>
	</div>
	<div
		class="flex items-center justify-center md:justify-start md:relative max-md:px-8"
	>
		<img
			class="md:absolute bottom-0 md:right-1/2 md:translate-x-1/2 max-sm:max-h-[300px]"
			src="/images/portfolio--lady.png"
			alt=""
		/>
	</div>
</div>
