---
import { Icon } from 'astro-icon/components';
interface Props {
	href?: string;
	kicker?: string;
	label?: string;
}
const {
	href = '/about',
	kicker = '// the humans behind the products',
	label = 'The people you’ll work with',
} = Astro.props;
---

<a href={href} class="teamchip" data-tour="team">
	<span class="teamchip__pic">
		<img src="/images/hero-team.jpg" alt="The Swizel team" loading="lazy" />
		<span class="teamchip__live"></span>
	</span>
	<span class="teamchip__txt">
		<span class="teamchip__k">{kicker}</span>
		<span class="teamchip__l">
			{label}
			<Icon width={14} name="mdi:arrow-right" />
		</span>
	</span>
</a>

<style>
	.teamchip {
		display: inline-flex;
		align-items: center;
		gap: 0.85rem;
		margin-top: 1.5rem;
		padding: 0.5rem 0.95rem 0.5rem 0.5rem;
		border-radius: 9999px;
		border: 1px solid rgba(255, 255, 255, 0.12);
		background: rgba(255, 255, 255, 0.04);
		width: fit-content;
		transition: border-color 0.3s ease, background 0.3s ease,
			transform 0.3s ease;
	}
	.teamchip:hover {
		border-color: var(--view-accent, #18debe);
		background: color-mix(in srgb, var(--view-accent, #18debe) 9%, transparent);
		transform: translateY(-2px);
	}
	.teamchip__pic {
		position: relative;
		flex-shrink: 0;
		width: 86px;
		height: 52px;
		border-radius: 9999px;
		overflow: hidden;
		border: 1px solid color-mix(in srgb, var(--view-accent, #18debe) 45%, transparent);
	}
	.teamchip__pic img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: 50% 28%;
	}
	.teamchip__live {
		position: absolute;
		right: 5px;
		bottom: 5px;
		width: 8px;
		height: 8px;
		border-radius: 9999px;
		background: #28c840;
		border: 2px solid #0b0f17;
	}
	.teamchip__txt {
		display: flex;
		flex-direction: column;
		gap: 1px;
	}
	.teamchip__k {
		font-family: ui-monospace, monospace;
		font-size: 0.7rem;
		color: rgba(255, 255, 255, 0.45);
	}
	.teamchip__l {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		font-size: 0.92rem;
		font-weight: 700;
		color: #fff;
	}
</style>
