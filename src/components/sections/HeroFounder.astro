---
import { Icon } from 'astro-icon';
import CustomButton from '../CustomButton.astro';
import Section from '../HTML/Section.astro';
import RotatingHeadline from '../RotatingHeadline.astro';
import TeamChip from '../TeamChip.astro';

const stats = [
	{ to: 6, suffix: ' wks', label: 'Idea to MVP' },
	{ to: 65, suffix: '+', label: 'Products launched' },
	{ to: 7, suffix: '+', label: 'Years building' },
];

const stages = [
	{ n: '01', name: 'Discover & define', when: 'Week 1', pct: 22 },
	{ n: '02', name: 'Design & prototype', when: 'Week 2', pct: 48 },
	{ n: '03', name: 'Build & test', when: 'Weeks 3 to 5', pct: 82 },
	{ n: '04', name: 'Launch & scale', when: 'Week 6', pct: 100 },
];

const launched = [
	{ name: 'OGGMA', sector: 'Food delivery' },
	{ name: 'Betslipswitch', sector: 'Sports' },
	{ name: 'Hemam Synergy', sector: 'Real estate' },
	{ name: 'Brixmarket', sector: 'E commerce' },
];
---

<Section
	sectionClass="hero--stage hero-view hero-founder founder--stage relative overflow-hidden"
	divClass="relative z-10 pb-16 sm:pb-24"
>
	<div class="founder--bg" aria-hidden="true">
		<span class="founder--glow"></span>
		{Array.from({ length: 7 }).map((_, i) => <span class="founder--rise" style={`--i:${i}`} />)}
	</div>

	<div class="founder--layout">
		<div class="founder--copy">
			<span class="founder--eyebrow">
				<Icon width={15} name="mdi:rocket-launch-outline" />
				Zero to MVP
			</span>

			<RotatingHeadline class="founder--head" />

			<p class="founder--sub">
				From a blank page to a launched product in weeks, not months. We
				plan, build and ship with you, then scale what works.
			</p>

			<div class="founder--cta">
				<CustomButton
					variant="accent"
					elementType="a"
					href="/contact"
					class="flex items-center justify-center gap-2"
				>
					Book a build sprint
					<Icon width={18} name="mdi:arrow-right" />
				</CustomButton>
				<button class="founder--tour" type="button" data-tour-start="founder">
					<Icon width={16} name="mdi:compass-outline" />
					Take the 20s tour
				</button>
			</div>

			<ul class="founder--stats" data-tour="stats">
				{
					stats.map((s) => (
						<li class="founder--stat">
							<span
								class="founder--statnum"
								data-count-to={s.to}
								data-suffix={s.suffix}
							>
								{s.to}
								{s.suffix}
							</span>
							<span class="founder--statlabel">{s.label}</span>
						</li>
					))
				}
			</ul>

			<TeamChip
				kicker="// the people who launch with you"
				label="Meet your build team"
			/>
		</div>

		<!-- Launch pipeline widget -->
		<div class="founder--widget" id="founder-widget" data-tour="pipeline">
			<div class="fw--head">
				<div>
					<span class="fw--title">Idea → MVP</span>
					<span class="fw--eta">in about 6 weeks</span>
				</div>
				<button class="fw--launch" type="button" data-fw-launch>
					<Icon width={15} name="mdi:rocket-launch-outline" />
					<span class="fw--launch-txt">Launch my MVP</span>
				</button>
			</div>

			<div class="fw--body">
				<div class="fw--ring" data-tour="ring">
					<svg class="fw--ringsvg" viewBox="0 0 120 120" aria-hidden="true">
						<circle class="fw--ringbg" cx="60" cy="60" r="52"></circle>
						<circle class="fw--ringfg" id="fw-ring" cx="60" cy="60" r="52"></circle>
					</svg>
					<span class="fw--pct" id="fw-pct">0%</span>
					<span class="fw--ringlabel">to launch</span>
				</div>

				<ol class="fw--stages">
					{
						stages.map((s) => (
							<li class="fw--stage" data-pct={s.pct}>
								<span class="fw--stagenum">{s.n}</span>
								<span class="fw--stagebody">
									<span class="fw--stagename">{s.name}</span>
									<span class="fw--stageweek">{s.when}</span>
								</span>
								<span class="fw--check">
									<Icon width={14} name="mdi:check" />
								</span>
							</li>
						))
					}
				</ol>
			</div>

			<div class="fw--launched" data-tour="launched">
				<span class="fw--launched-label">
					<span class="fw--launched-dot"></span>
					Recently launched, across sectors
				</span>
				<div class="fw--cards">
					{
						launched.map((p, i) => (
							<span class="fw--card" style={`--i:${i}`}>
								<span class="fw--card-name">{p.name}</span>
								<span class="fw--card-sector">{p.sector}</span>
							</span>
						))
					}
				</div>
			</div>
		</div>
	</div>
</Section>

<style>
	.founder--stage {
		background:
			radial-gradient(900px 520px at 80% -10%, rgba(139, 92, 246, 0.2), transparent 60%),
			linear-gradient(180deg, #161229 0%, #120f22 55%, #0d0b1a 100%);
		color: #ede9fb;
		isolation: isolate;
	}
	.founder--bg {
		position: absolute; top: 0; left: 50%; transform: translateX(-50%);
		width: 100vw; height: 100%; z-index: 0; overflow: hidden; pointer-events: none;
		background:
			radial-gradient(900px 520px at 80% -10%, rgba(139, 92, 246, 0.2), transparent 60%),
			linear-gradient(180deg, #161229 0%, #120f22 55%, #0d0b1a 100%);
	}
	.founder--glow {
		position: absolute;
		top: -20%;
		left: 50%;
		transform: translateX(-50%);
		width: 70vw;
		max-width: 820px;
		height: 460px;
		background: radial-gradient(ellipse at center, rgba(139, 92, 246, 0.28), transparent 70%);
		filter: blur(50px);
	}
	.founder--rise {
		position: absolute;
		bottom: -10%;
		left: calc((var(--i) + 1) * 12%);
		width: 5px;
		height: 5px;
		border-radius: 9999px;
		background: rgba(167, 139, 250, 0.7);
		box-shadow: 0 0 10px 2px rgba(139, 92, 246, 0.5);
		animation: rise 9s linear infinite;
		animation-delay: calc(var(--i) * -1.3s);
	}
	@keyframes rise {
		0% { transform: translateY(0); opacity: 0; }
		15% { opacity: 1; }
		85% { opacity: 1; }
		100% { transform: translateY(-92vh); opacity: 0; }
	}

	.founder--layout {
		position: relative;
		z-index: 1;
		display: grid;
		gap: 2.5rem;
		align-items: center;
		min-height: calc(100vh - 90px);
		padding-top: 2rem;
	}
	@media (min-width: 1024px) {
		.founder--layout { grid-template-columns: 0.92fr 1.08fr; gap: 3rem; }
	}

	.founder--eyebrow {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: #c4b5fd;
		margin-bottom: 1.2rem;
	}
	.founder--head { font-size: clamp(2.6rem, 6vw, 5.2rem); margin-bottom: 1.4rem; }
	.founder--sub {
		max-width: 30rem;
		color: rgba(237, 233, 251, 0.66);
		font-size: 1.08rem;
		line-height: 1.65;
		margin-bottom: 1.8rem;
	}
	.founder--cta { display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; margin-bottom: 2rem; }
	.founder--tour {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		font-size: 0.82rem;
		font-weight: 600;
		color: #ede9fb;
		padding: 0.85rem 1.2rem;
		border-radius: 9999px;
		border: 1px dashed rgba(196, 181, 253, 0.45);
		transition: border-color 0.25s ease, color 0.25s ease, background 0.25s ease;
	}
	.founder--tour:hover {
		border-color: var(--view-accent, #8b5cf6);
		color: #c4b5fd;
		background: rgba(139, 92, 246, 0.1);
	}

	.founder--stats { display: flex; gap: clamp(1.5rem, 4vw, 3rem); flex-wrap: wrap; padding-top: 1.5rem; border-top: 1px solid rgba(255, 255, 255, 0.08); }
	.founder--statnum {
		font-family: 'Bebas Neue', sans-serif;
		font-size: clamp(2.2rem, 4vw, 3rem);
		line-height: 1;
		background: linear-gradient(135deg, #c4b5fd, var(--view-accent, #8b5cf6));
		-webkit-background-clip: text;
		background-clip: text;
		-webkit-text-fill-color: transparent;
		color: transparent;
	}
	.founder--statlabel { display: block; font-size: 0.74rem; text-transform: uppercase; letter-spacing: 0.08em; color: rgba(237, 233, 251, 0.5); margin-top: 0.3rem; }

	/* ===== Launch pipeline widget ===== */
	.founder--widget {
		border-radius: 1.25rem;
		padding: 1.25rem;
		background: rgba(22, 18, 41, 0.66);
		border: 1px solid rgba(167, 139, 250, 0.22);
		backdrop-filter: blur(14px);
		box-shadow: 0 40px 90px -40px rgba(0, 0, 0, 0.85);
	}
	.fw--head { display: flex; align-items: center; justify-content: space-between; gap: 1rem; margin-bottom: 1.25rem; }
	.fw--title { font-size: 1.15rem; font-weight: 800; color: #fff; }
	.fw--eta { display: block; font-size: 0.8rem; color: rgba(237, 233, 251, 0.55); }
	.fw--launch {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		font-size: 0.8rem;
		font-weight: 700;
		color: #1a1030;
		background: linear-gradient(95deg, #c4b5fd, #8b5cf6);
		padding: 0.6rem 1.05rem;
		border-radius: 9999px;
		cursor: pointer;
		transition: transform 0.2s ease, filter 0.2s ease;
		white-space: nowrap;
	}
	.fw--launch:hover { transform: translateY(-1px); filter: brightness(1.05); }

	.fw--body { display: flex; gap: 1.25rem; align-items: center; }
	.fw--ring { position: relative; width: 120px; height: 120px; flex-shrink: 0; display: grid; place-items: center; }
	.fw--ringsvg { width: 120px; height: 120px; transform: rotate(-90deg); }
	.fw--ringbg { fill: none; stroke: rgba(255, 255, 255, 0.08); stroke-width: 9; }
	.fw--ringfg {
		fill: none;
		stroke: url(#fwgrad);
		stroke: #a78bfa;
		stroke-width: 9;
		stroke-linecap: round;
		stroke-dasharray: 326.7;
		stroke-dashoffset: 326.7;
	}
	.fw--pct { position: absolute; font-family: 'Bebas Neue', sans-serif; font-size: 2rem; color: #fff; line-height: 1; }
	.fw--ringlabel { position: absolute; margin-top: 3.1rem; font-size: 0.62rem; text-transform: uppercase; letter-spacing: 0.1em; color: rgba(237, 233, 251, 0.5); }

	.fw--stages { display: grid; gap: 0.55rem; flex: 1; }
	.fw--stage {
		display: flex;
		align-items: center;
		gap: 0.7rem;
		padding: 0.5rem 0.6rem;
		border-radius: 0.7rem;
		border: 1px solid rgba(255, 255, 255, 0.07);
		background: rgba(255, 255, 255, 0.02);
		transition: border-color 0.4s ease, background 0.4s ease;
	}
	.fw--stage.is-done { border-color: rgba(167, 139, 250, 0.5); background: rgba(139, 92, 246, 0.12); }
	.fw--stagenum { font-family: ui-monospace, monospace; font-size: 0.72rem; color: rgba(237, 233, 251, 0.4); }
	.fw--stage.is-done .fw--stagenum { color: #c4b5fd; }
	.fw--stagebody { flex: 1; display: flex; flex-direction: column; }
	.fw--stagename { font-size: 0.84rem; font-weight: 600; color: #eee9fb; }
	.fw--stageweek { font-size: 0.7rem; color: rgba(237, 233, 251, 0.45); }
	.fw--check {
		display: grid;
		place-items: center;
		width: 22px;
		height: 22px;
		border-radius: 9999px;
		background: rgba(255, 255, 255, 0.06);
		color: transparent;
		transform: scale(0.6);
		transition: transform 0.3s ease, background 0.3s ease, color 0.3s ease;
	}
	.fw--stage.is-done .fw--check { background: #8b5cf6; color: #fff; transform: scale(1); }

	.fw--launched { margin-top: 1.25rem; padding-top: 1rem; border-top: 1px dashed rgba(255, 255, 255, 0.1); }
	.fw--launched-label { display: inline-flex; align-items: center; gap: 0.4rem; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.08em; color: rgba(237, 233, 251, 0.5); margin-bottom: 0.7rem; }
	.fw--launched-dot { width: 7px; height: 7px; border-radius: 9999px; background: #28c840; }
	.fw--cards { display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.55rem; }
	.fw--card {
		display: flex;
		flex-direction: column;
		padding: 0.6rem 0.75rem;
		border-radius: 0.7rem;
		border: 1px solid rgba(167, 139, 250, 0.2);
		background: rgba(139, 92, 246, 0.07);
		opacity: 0;
		transform: translateY(8px);
	}
	.founder--widget.is-launched .fw--card { animation: fwcard 0.45s ease forwards; animation-delay: calc(var(--i) * 0.12s); }
	@keyframes fwcard { to { opacity: 1; transform: translateY(0); } }
	.fw--card-name { font-size: 0.85rem; font-weight: 700; color: #fff; }
	.fw--card-sector { font-size: 0.7rem; color: #c4b5fd; }

	@media (max-width: 1023px) {
		.founder--layout { min-height: auto; }
	}
	@media (max-width: 768px) {
		.founder--layout { gap: 1.75rem; padding-top: 0.5rem; }
		.founder--head { font-size: clamp(2.2rem, 9.5vw, 3.2rem); }
		.founder--sub { font-size: 1rem; margin-bottom: 1.4rem; }
		.fw--body { flex-direction: column; }
		.fw--ring { width: 104px; height: 104px; }
		.fw--ringsvg { width: 104px; height: 104px; }
	}
	@media (prefers-reduced-motion: reduce) {
		.founder--rise { animation: none !important; }
	}
</style>
