---
// A full case-study page — the Boardroom world, themed in the project's colour.
// Curtains-open storytelling: hero, the challenge, what we did, the solution,
// a gallery with room for pics + video, the results, a quote, and a clear
// "this is just the tip" hand-off. Reuses initBoardroomBody reveals/counters.
import { Icon } from 'astro-icon';
import type { Project } from '../../data/projects';

interface Props {
	project: Project;
	others: Project[];
}
const { project: p, others } = Astro.props;
const cs = p.caseStudy!;
const next = others[0];
// gallery: one big video on the left, the images as a grid on the right
const galVideo = cs.gallery.find((g) => g.kind === 'video');
const galImages = cs.gallery.filter((g) => g.kind !== 'video');
// the custom cursor adapts to the sector (health ≠ briefcase)
const sectorCursor: Record<string, string> = { agri: 'branch', health: 'pulse', property: 'layers', media: 'book', commerce: 'pkg', product: 'repo' };
const cur = sectorCursor[p.sector] ?? 'repo';
---

<div class="bdbody bd-services bd-case view-body view-body-boardroom" style={`--c:${p.color}`} data-cursor={cur}>
	<!-- ── Hero ───────────────────────────────────────────── -->
	<header class="cs-hero bd-reveal">
		<span class="cs-hero-aurora" aria-hidden="true"></span>
		<a href="/portfolio" class="cs-back"><Icon width={15} name="mdi:arrow-left" /> All work</a>
		<div class="cs-hero-grid">
			<div class="cs-hero-text">
				<span class="cs-eyebrow">{cs.meta.sector}</span>
				<h1 class="bd-display cs-h1">{p.name}</h1>
				<p class="cs-tagline">{p.tagline}</p>
				<div class="bd-links cs-hero-links">
					{cs.liveUrl && (
						<a href={cs.liveUrl} target="_blank" rel="noopener noreferrer" class="bd-pill">Visit live site <Icon width={15} name="mdi:open-in-new" /></a>
					)}
					{cs.extraLinks?.map((l) => (
						<a href={l.url} target="_blank" rel="noopener noreferrer" class="bd-link">{l.label} <Icon width={15} name="mdi:arrow-top-right" /></a>
					))}
				</div>
			</div>
			<a class:list={['cs-shot', { 'cs-shot--app': p.kind === 'app' }]} href={cs.liveUrl ?? undefined} target={cs.liveUrl ? '_blank' : undefined} rel={cs.liveUrl ? 'noopener noreferrer' : undefined}>
				{p.kind !== 'app' && <span class="cs-bar" aria-hidden="true"><i></i><i></i><i></i><span class="cs-url">{p.host}</span></span>}
				<span class="cs-img"><img src={p.img} alt={`${p.name}`} width="1280" height="800" /></span>
			</a>
		</div>
		<ul class="cs-meta">
			<li><span>Client</span><strong>{cs.meta.client}</strong></li>
			<li><span>Sector</span><strong>{cs.meta.sector}</strong></li>
			<li><span>Year</span><strong>{cs.meta.year}</strong></li>
			<li><span>Scope</span><strong>{cs.meta.scope}</strong></li>
		</ul>
	</header>

	<!-- ── Intro story ─────────────────────────────────────── -->
	<section class="cs-intro bd-reveal">
		<span class="bd-eyebrow">The story</span>
		<p class="cs-intro-text">{cs.intro}</p>
	</section>

	<!-- ── The challenge ───────────────────────────────────── -->
	<section class="cs-challenge bd-reveal" data-cursor="vector">
		<span class="cs-challenge-aurora" aria-hidden="true"></span>
		<div class="cs-challenge-inner">
			<span class="cs-eyebrow">The challenge</span>
			<p class="cs-challenge-text">{cs.challenge}</p>
		</div>
	</section>

	<!-- ── What we did ─────────────────────────────────────── -->
	<section class="cs-scope bd-reveal">
		<div class="cs-scope-head">
			<span class="cs-eyebrow">The work · {cs.approach.length} moves</span>
			<h2 class="bd-display cs-scope-h">What we actually did.</h2>
			<p class="cs-scope-lead">Not a logo and a landing page. A full effort across strategy, brand, content and engineering — here’s the play-by-play.</p>
			<ul class="cs-services">
				{cs.services.map((s) => <li>{s}</li>)}
			</ul>
		</div>
		<ol class="cs-approach">
			{cs.approach.map((a, i) => (
				<li class="cs-approach-item bd-reveal" data-cursor="layers">
					<span class="cs-approach-n">{String(i + 1).padStart(2, '0')}</span>
					<div class="cs-approach-body">
						<h3 class="cs-approach-t">{a.title}</h3>
						<p class="cs-approach-d">{a.desc}</p>
					</div>
				</li>
			))}
		</ol>
	</section>

	<!-- ── The solution — highlight blocks ─────────────────── -->
	<section class="bd-head bd-reveal">
		<h2 class="bd-h bd-h--center">How our awesomeness made it happen.</h2>
		<p class="bd-p bd-p--center">The moves that turned the brief into a result.</p>
	</section>
	<div class="cs-highlights">
		{cs.highlights.map((h, i) => (
			<article class="cs-highlight bd-reveal" data-cursor="layers">
				<span class="cs-highlight-n">{String(i + 1).padStart(2, '0')}</span>
				<h3 class="cs-highlight-t">{h.title}</h3>
				<p class="cs-highlight-d">{h.desc}</p>
			</article>
		))}
	</div>

	<!-- ── Gallery: a big walkthrough video + a grid of shots ── -->
	<section class="bd-head bd-reveal">
		<h2 class="bd-h bd-h--center">Inside the build.</h2>
		<p class="bd-p bd-p--center">A closer look — the walkthrough on the left, the shots on the right.</p>
	</section>
	<div class="cs-gallery-split">
		{galVideo && (
			<figure class="cs-gvideo bd-reveal" data-cursor="play">
				<span class="cs-gvideo-frame">
					<span class="cs-gslot-sheen" aria-hidden="true"></span>
					<span class="cs-gvideo-lines" aria-hidden="true"></span>
					{galVideo.src ? (
						<video src={galVideo.src} controls playsinline preload="metadata"></video>
					) : (
						<span class="cs-gvideo-play"><Icon width={34} name="mdi:play" /></span>
					)}
					{!galVideo.src && <span class="cs-gslot-label">Video placeholder</span>}
				</span>
				<figcaption><strong>{galVideo.label}</strong>{galVideo.caption && <em> — {galVideo.caption}</em>}</figcaption>
			</figure>
		)}
		<div class:list={['cs-gimgs', { 'cs-gimgs--solo': !galVideo }]}>
			{galImages.map((g) => (
				<figure class="cs-gitem bd-reveal" data-cursor="repo">
					{g.src ? (
						<span class="cs-gimg"><img src={g.src} alt={g.label} loading="lazy" /></span>
					) : (
						<span class="cs-gslot">
							<span class="cs-gslot-sheen" aria-hidden="true"></span>
							<span class="cs-gslot-ic"><Icon width={22} name="mdi:image-outline" /></span>
							<span class="cs-gslot-label">Image</span>
						</span>
					)}
					<figcaption>{g.label}{g.caption && <em> — {g.caption}</em>}</figcaption>
				</figure>
			))}
		</div>
	</div>

	<!-- ── Results ─────────────────────────────────────────── -->
	<section class="cs-results bd-reveal" data-cursor="chart">
		<span class="cs-results-aurora" aria-hidden="true"></span>
		<div class="cs-results-head">
			<span class="cs-eyebrow">The result</span>
			<h2 class="bd-h">Proof it worked.</h2>
		</div>
		<ul class="cs-results-grid">
			{cs.results.map((r) => (
				<li class="cs-result">
					<strong>{r.stat}</strong>
					<span>{r.label}</span>
				</li>
			))}
		</ul>
	</section>

	<!-- ── In the press ────────────────────────────────────── -->
	{cs.press && (
		<section class="cs-press bd-reveal">
			<div class="cs-press-head">
				<span class="cs-eyebrow">In the press</span>
				<h2 class="bd-h">It made the news.</h2>
				{cs.press.intro && <p class="bd-p">{cs.press.intro}</p>}
			</div>
			<div class="cs-press-grid">
				{cs.press.items.map((it) => {
					const Tag = it.url ? 'a' : 'div';
					return (
						<Tag class="cs-press-card bd-reveal" href={it.url ?? undefined} target={it.url ? '_blank' : undefined} rel={it.url ? 'noopener noreferrer' : undefined} data-cursor="repo">
							<span class="cs-press-clip" aria-hidden="true">
								<span class="cs-press-mast"></span>
								<span class="cs-press-cols"><i></i><i></i><i></i><i></i><i></i></span>
								<Icon class="cs-press-clip-ic" width={20} name="mdi:newspaper-variant-outline" />
							</span>
							<span class="cs-press-meta">
								<span class="cs-press-outlet">{it.outlet}{it.date && <em> · {it.date}</em>}</span>
								<strong>{it.title}</strong>
								<span class="cs-press-link">{it.url ? 'Read the coverage' : 'Link coming'} <Icon width={14} name={it.url ? 'mdi:open-in-new' : 'mdi:dots-horizontal'} /></span>
							</span>
						</Tag>
					);
				})}
			</div>
		</section>
	)}

	<!-- ── Quote ───────────────────────────────────────────── -->
	{cs.quote && (
		<section class="cs-quote bd-reveal" data-cursor="quote">
			<Icon class="cs-quote-mark" width={42} name="mdi:format-quote-close" />
			<blockquote>{cs.quote.text}</blockquote>
			<footer>— {cs.quote.who}</footer>
		</section>
	)}

	<!-- ── Tip of the iceberg ──────────────────────────────── -->
	<section class="cs-tip bd-reveal">
		<div class="cs-tip-inner">
			<span class="cs-eyebrow">And this is just the tip</span>
			<h2 class="bd-display cs-tip-h">There’s a lot more where this came from.</h2>
			<p class="bd-sub">One project, told in full. We’ve shipped dozens more across agritech, health, media, property, commerce and platforms.</p>
			<div class="bd-links bd-links--center">
				<a href="/portfolio" class="bd-pill bd-pill--light">See all the work</a>
				<a href="/contact" class="bd-link bd-link--invert">Start your project <Icon width={15} name="mdi:chevron-right" /></a>
			</div>
		</div>
	</section>

	<!-- ── Next project ────────────────────────────────────── -->
	{next && (
		<a href={`/work/${next.slug}`} class="cs-next bd-reveal" style={`--c:${next.color}`} data-cursor="repo">
			<span class="cs-next-label">Next case study</span>
			<span class="cs-next-name">{next.name} <Icon width={22} name="mdi:arrow-right" /></span>
			<span class="cs-next-tag">{next.tagline}</span>
		</a>
	)}
</div>

<style>
	/* ════ Boardroom base (self-contained), themed by --c ════ */
	.bdbody {
		--bd-accent: var(--c, #28a6ec);
		--bd-ink: #f4f6fb;
		--bd-muted: rgba(244, 246, 251, 0.62);
		--bd-glass: linear-gradient(160deg, rgba(255, 255, 255, 0.07), rgba(255, 255, 255, 0.02) 55%);
		--bd-glass-border: rgba(255, 255, 255, 0.1);
		--bd-shadow: 0 34px 80px -34px rgba(0, 0, 0, 0.8);
		font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
		position: relative; isolation: isolate; overflow: hidden;
		background:
			radial-gradient(1100px 540px at 78% -6%, color-mix(in srgb, var(--c) 15%, transparent), transparent 62%),
			radial-gradient(900px 520px at 8% 38%, rgba(58, 90, 200, 0.1), transparent 60%),
			linear-gradient(180deg, #070910 0%, #0a0d1c 45%, #05060d 100%);
		color: var(--bd-ink);
		padding: clamp(2.5rem, 6vw, 4.5rem) clamp(1rem, 3vw, 2rem) clamp(2.5rem, 5vw, 4rem);
	}
	:global(html:not(.dark)) .bdbody {
		--bd-ink: #0f1120;
		--bd-muted: rgba(28, 32, 52, 0.82);
		--bd-glass: linear-gradient(160deg, #ffffff, #f3f6fb 60%);
		--bd-glass-border: rgba(18, 22, 45, 0.16);
		--bd-shadow: 0 26px 60px -32px rgba(20, 28, 60, 0.4);
		background:
			radial-gradient(1100px 540px at 78% -6%, color-mix(in srgb, var(--c) 13%, transparent), transparent 62%),
			linear-gradient(180deg, #e4eaf2 0%, #dbe3ee 50%, #e4eaf2 100%);
	}
	/* living background — drifting light blobs + a slow-panning dot grid */
	.bdbody::before {
		content: ''; position: absolute; inset: -12%; z-index: -2; pointer-events: none;
		background:
			radial-gradient(440px 440px at 14% 16%, color-mix(in srgb, var(--c) 26%, transparent), transparent 60%),
			radial-gradient(400px 400px at 88% 24%, rgba(139, 92, 246, 0.18), transparent 60%),
			radial-gradient(480px 480px at 60% 90%, color-mix(in srgb, var(--c) 20%, transparent), transparent 62%);
		filter: blur(60px); opacity: 0.7; animation: cs-bg-float 26s ease-in-out infinite;
	}
	:global(html:not(.dark)) .bdbody::before { opacity: 0.45; }
	@keyframes cs-bg-float { 0%,100%{ transform: translate3d(0,0,0) scale(1); } 33%{ transform: translate3d(3%,-2%,0) scale(1.08); } 66%{ transform: translate3d(-2%,2%,0) scale(1.04); } }
	.bdbody::after {
		content: ''; position: absolute; inset: 0; z-index: -2; pointer-events: none; opacity: 0.45;
		background-image: radial-gradient(circle, color-mix(in srgb, var(--c) 30%, transparent) 1px, transparent 1px);
		background-size: 36px 36px;
		-webkit-mask-image: radial-gradient(1300px 760px at 50% 2%, #000, transparent 72%);
		mask-image: radial-gradient(1300px 760px at 50% 2%, #000, transparent 72%);
		animation: cs-bg-pan 46s linear infinite;
	}
	:global(html:not(.dark)) .bdbody::after { opacity: 0.28; }
	@keyframes cs-bg-pan { to { background-position: 360px 220px; } }

	.bd-display { font-size: clamp(2.4rem, 5.5vw, 4.2rem); font-weight: 700; letter-spacing: -0.025em; line-height: 1.04; margin: 0 0 1rem; }
	.bd-sub { font-size: clamp(1.05rem, 2vw, 1.32rem); line-height: 1.5; color: var(--bd-muted); max-width: 42rem; margin: 0 auto 1.4rem; }
	.bd-h { font-size: clamp(1.7rem, 3.4vw, 2.5rem); font-weight: 700; letter-spacing: -0.02em; line-height: 1.1; margin: 0 0 0.7rem; }
	.bd-h--center { text-align: center; }
	.bd-p { font-size: 1.02rem; line-height: 1.6; color: var(--bd-muted); max-width: 34rem; margin: 0 auto 1.2rem; }
	.bd-p--center { margin-inline: auto; text-align: center; }
	.bd-eyebrow { display: block; font-size: 0.76rem; font-weight: 800; letter-spacing: 0.14em; text-transform: uppercase; color: var(--c); margin-bottom: 0.7rem; }
	.bd-head { max-width: 56rem; margin: clamp(2.5rem, 6vw, 4rem) auto clamp(1.5rem, 3vw, 2rem); text-align: center; }
	.bd-links { display: flex; align-items: center; gap: 1.2rem; flex-wrap: wrap; }
	.bd-links--center { justify-content: center; }
	.bd-pill { display: inline-flex; align-items: center; gap: 0.4rem; padding: 0.78rem 1.5rem; border-radius: 9999px; background: linear-gradient(180deg, color-mix(in srgb, var(--c) 88%, #fff), var(--c) 45%, color-mix(in srgb, var(--c) 72%, #03244a)); border: 1px solid color-mix(in srgb, var(--c) 60%, rgba(255, 255, 255, 0.4)); color: #fff; font-size: 0.95rem; font-weight: 600; text-shadow: 0 1px 2px rgba(0, 0, 0, 0.25); box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.35), 0 12px 28px -12px color-mix(in srgb, var(--c) 65%, transparent); transition: transform 0.25s ease; }
	.bd-pill:hover { transform: translateY(-2px); }
	.bd-pill--light { background: linear-gradient(180deg, #fff, #dfe6f2); border-color: rgba(255, 255, 255, 0.8); color: #0b0d18; text-shadow: none; }
	.bd-link { display: inline-flex; align-items: center; gap: 0.3rem; font-size: 0.98rem; font-weight: 600; color: var(--c); transition: gap 0.25s ease; }
	.bd-link:hover { gap: 0.5rem; }
	.bd-link--invert { color: color-mix(in srgb, var(--c) 55%, #fff); }

	/* ── Hero ── */
	.cs-hero { position: relative; max-width: 84rem; margin: 0 auto clamp(2rem, 5vw, 3.5rem); }
	.cs-hero-aurora { position: absolute; inset: -20% -10% auto; height: 80%; z-index: -1; pointer-events: none; background: radial-gradient(560px 380px at 25% 20%, color-mix(in srgb, var(--c) 32%, transparent), transparent 62%); filter: blur(54px); opacity: 0.6; }
	:global(html:not(.dark)) .cs-hero-aurora { opacity: 0.4; }
	.cs-back { display: inline-flex; align-items: center; gap: 0.35rem; font-size: 0.88rem; font-weight: 600; color: var(--bd-muted); margin-bottom: 1.6rem; transition: gap 0.25s ease, color 0.25s ease; }
	.cs-back:hover { gap: 0.55rem; color: var(--c); }
	.cs-hero-grid { display: grid; gap: clamp(1.8rem, 4vw, 3rem); align-items: center; }
	@media (min-width: 940px) { .cs-hero-grid { grid-template-columns: 0.92fr 1.08fr; } }
	.cs-eyebrow { display: block; font-size: 0.78rem; font-weight: 800; letter-spacing: 0.14em; text-transform: uppercase; color: var(--c); margin-bottom: 0.9rem; }
	.cs-h1 { max-width: 14ch; }
	.cs-tagline { font-size: clamp(1.15rem, 2.2vw, 1.5rem); font-weight: 600; line-height: 1.35; color: color-mix(in srgb, var(--c) 70%, var(--bd-ink)); margin: 0 0 1.5rem; max-width: 24ch; }
	.cs-hero-links { justify-content: flex-start; }

	/* browser-framed hero shot */
	.cs-shot { position: relative; display: block; border-radius: 1.2rem; overflow: hidden; background: #0b0d16; border: 1px solid color-mix(in srgb, var(--c) 30%, var(--bd-glass-border)); box-shadow: var(--bd-shadow); transition: transform 0.4s cubic-bezier(0.22,1,0.36,1); }
	.cs-shot:hover { transform: translateY(-5px); }
	.cs-bar { display: flex; align-items: center; gap: 0.4rem; padding: 0.6rem 0.9rem; background: color-mix(in srgb, var(--bd-ink) 8%, #11131c); border-bottom: 1px solid var(--bd-glass-border); }
	.cs-bar i { width: 10px; height: 10px; border-radius: 50%; background: rgba(255,255,255,0.25); }
	.cs-bar i:first-child { background: #ff5f57; } .cs-bar i:nth-child(2) { background: #febc2e; } .cs-bar i:nth-child(3) { background: #28c840; }
	.cs-url { margin-left: 0.5rem; font-size: 0.74rem; font-weight: 600; color: color-mix(in srgb, var(--bd-ink) 60%, transparent); font-family: ui-monospace, 'SF Mono', Menlo, monospace; }
	:global(html:not(.dark)) .cs-bar { background: #f1f3f8; }
	:global(html:not(.dark)) .cs-shot { background: #f1f3f8; }
	.cs-img { display: block; aspect-ratio: 16 / 10; }
	.cs-img img { width: 100%; height: 100%; object-fit: cover; object-position: top; }
	.cs-shot--app .cs-img { background: radial-gradient(130% 130% at 50% 0%, color-mix(in srgb, var(--c) 22%, #0b0d16), #0b0d16); }
	:global(html:not(.dark)) .cs-shot--app .cs-img { background: radial-gradient(130% 130% at 50% 0%, color-mix(in srgb, var(--c) 18%, #eef2f7), #eef2f7); }
	.cs-shot--app .cs-img img { object-fit: contain; padding: 0.5rem; }

	.cs-meta { list-style: none; display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 1px; margin: clamp(1.8rem, 4vw, 2.6rem) 0 0; padding: 0; border-radius: 1.1rem; overflow: hidden; background: var(--bd-glass-border); border: 1px solid var(--bd-glass-border); }
	@media (max-width: 640px) { .cs-meta { grid-template-columns: 1fr 1fr; } }
	.cs-meta li { display: flex; flex-direction: column; gap: 0.25rem; padding: 1rem 1.1rem; background: color-mix(in srgb, var(--bd-ink) 4%, #0b0d16); }
	:global(html:not(.dark)) .cs-meta li { background: rgba(255, 255, 255, 0.7); }
	.cs-meta span { font-size: 0.68rem; font-weight: 800; letter-spacing: 0.12em; text-transform: uppercase; color: var(--bd-muted); }
	.cs-meta strong { font-size: 0.92rem; font-weight: 600; line-height: 1.3; }

	/* ── Intro ── */
	.cs-intro { max-width: 60rem; margin: clamp(2.5rem, 6vw, 4rem) auto; }
	.cs-intro-text { font-size: clamp(1.25rem, 2.6vw, 1.85rem); font-weight: 500; line-height: 1.5; letter-spacing: -0.01em; margin: 0; }

	/* ── Challenge ── */
	.cs-challenge { position: relative; max-width: 76rem; margin: clamp(2.5rem, 6vw, 4rem) auto; border-radius: 2rem; overflow: hidden; isolation: isolate; padding: clamp(2rem, 5vw, 3.5rem) clamp(1.5rem, 4vw, 3rem); background: color-mix(in srgb, var(--c) 8%, var(--bd-glass)); border: 1px solid color-mix(in srgb, var(--c) 22%, var(--bd-glass-border)); box-shadow: var(--bd-shadow); backdrop-filter: blur(18px); -webkit-backdrop-filter: blur(18px); }
	.cs-challenge-aurora { position: absolute; inset: 0; z-index: -1; pointer-events: none; background: radial-gradient(600px 320px at 85% 0%, color-mix(in srgb, var(--c) 20%, transparent), transparent 62%); filter: blur(34px); opacity: 0.7; }
	.cs-challenge-inner { max-width: 50rem; }
	.cs-challenge-text { font-size: clamp(1.05rem, 1.9vw, 1.3rem); line-height: 1.6; font-weight: 500; margin: 0; }

	/* ── Scope / what we did — centred header, boxes in a grid ── */
	.cs-scope { max-width: 78rem; margin: clamp(2.5rem, 6vw, 4rem) auto; }
	.cs-scope-head { max-width: 46rem; margin: 0 auto clamp(1.8rem, 4vw, 2.6rem); text-align: center; }
	.cs-scope-h { font-size: clamp(2rem, 4.5vw, 3.2rem); }
	.cs-scope-lead { font-size: 1.05rem; line-height: 1.6; color: var(--bd-muted); margin: 0 auto 1.2rem; max-width: 36rem; }
	.cs-services { list-style: none; padding: 0; margin: 0; display: flex; flex-wrap: wrap; gap: 0.5rem; justify-content: center; }
