---
import { Icon } from 'astro-icon';

const stats = [
	{ to: 7, suffix: '+', label: 'Years shipping' },
	{ to: 25, suffix: '+', label: 'Engineers & designers' },
	{ to: 65, suffix: '+', label: 'Products live' },
	{ to: 10, suffix: '+', label: 'Countries' },
];
---

<div class="bbody view-body-builder">
	<!-- ===================== ABOUT ===================== -->
	<section class="bb-sec" data-cursor="term" data-tour="b-about">
		<div class="bb-wrap bb-about">
			<div class="bb-copy">
				<span class="bb-label">
					<span class="bb-label-dot"></span>// about
				</span>
				<h2 class="bb-h">
					Your team,
					<span class="bb-h-accent">as a service.</span>
				</h2>
				<p class="bb-p">
					Swizel is a global product studio. We plug a full team of
					engineers and designers into your idea, ship it fast, and stay
					to scale it. No hand offs, no guesswork.
				</p>
				<p class="bb-p bb-p-muted">
					Built across diverse fields of business and technology, driven
					by people who care about the details.
				</p>

				<ul class="bb-stats">
					{
						stats.map((s) => (
							<li>
								<strong data-count={s.to} data-suffix={s.suffix}>
									{s.to}
									{s.suffix}
								</strong>
								<span>{s.label}</span>
							</li>
						))
					}
				</ul>

				<a href="/about" class="bb-link">
					Meet the team
					<Icon width={16} name="mdi:arrow-right" />
				</a>
			</div>

			<div class="bb-media">
				<figure class="bb-photo">
					<div class="bb-photo-bar">
						<span class="bb-dot"></span>
						<span class="bb-dot"></span>
						<span class="bb-dot"></span>
						<span class="bb-photo-name">team.jpg</span>
						<span class="bb-photo-meta">RGB · 100%</span>
					</div>
					<img
						src="/images/hero-team.jpg"
						alt="The Swizel team — engineers and designers"
						loading="lazy"
					/>
					<figcaption class="bb-photo-cap">
						<span class="bb-photo-live"></span>
						25+ humans, building daily
					</figcaption>
				</figure>

				<!-- branded media placeholder (swap with real video later) -->
				<button class="bb-video media-frame" type="button" aria-label="Video coming soon">
					<span class="mf-play"><Icon width={20} name="mdi:play" /></span>
					<span class="mf-text">
						<span class="mf-title">Life at Swizel</span>
						<span class="mf-sub">video coming soon</span>
					</span>
				</button>
			</div>
		</div>
	</section>
</div>

<style>
	.bbody {
		position: relative;
		background:
			radial-gradient(800px 400px at 85% 0%, rgba(24, 222, 190, 0.07), transparent 60%),
			linear-gradient(180deg, #0b0f17 0%, #090c12 100%);
		color: #cfe0e0;
	}
	.bb-sec { padding: clamp(3.5rem, 8vw, 6rem) 5%; }
	.bb-wrap { max-width: 1120px; margin: 0 auto; }

	.bb-label {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		font-family: ui-monospace, monospace;
		font-size: 0.82rem;
		color: var(--view-accent, #18debe);
	}
	.bb-label-dot {
		width: 8px;
		height: 8px;
		border-radius: 9999px;
		background: var(--view-accent, #18debe);
		box-shadow: 0 0 10px 1px rgba(24, 222, 190, 0.6);
	}

	.bb-about {
		display: grid;
		gap: 2.5rem;
		align-items: center;
	}
	@media (min-width: 920px) {
		.bb-about { grid-template-columns: 1fr 1.05fr; gap: 4rem; }
	}

	.bb-h {
		font-size: clamp(2.2rem, 5vw, 3.6rem);
		font-weight: 800;
		line-height: 1.05;
		letter-spacing: -0.5px;
		color: #fff;
		margin: 0.7rem 0 1.2rem;
	}
	.bb-h-accent {
		display: block;
		background: linear-gradient(95deg, #8dfeea, var(--view-accent, #18debe), #28a6ec);
		-webkit-background-clip: text;
		background-clip: text;
		-webkit-text-fill-color: transparent;
	}
	.bb-p { color: rgba(207, 224, 224, 0.72); line-height: 1.75; max-width: 34rem; }
	.bb-p-muted { color: rgba(207, 224, 224, 0.48); font-size: 0.94rem; margin-top: 0.8rem; }

	.bb-stats {
		list-style: none;
		padding: 1.7rem 0 0;
		margin: 1.7rem 0 0;
		display: grid;
		grid-template-columns: repeat(2, auto);
		gap: 1.5rem 2.5rem;
		width: fit-content;
		border-top: 1px solid rgba(255, 255, 255, 0.08);
	}
	@media (min-width: 540px) { .bb-stats { grid-template-columns: repeat(4, auto); } }
	.bb-stats strong {
		display: block;
		font-family: 'Bebas Neue', sans-serif;
		font-size: 2.4rem;
		line-height: 1;
		background: linear-gradient(135deg, #8dfeea, var(--view-accent, #18debe));
		-webkit-background-clip: text;
		background-clip: text;
		-webkit-text-fill-color: transparent;
	}
	.bb-stats span {
		font-size: 0.72rem;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: rgba(207, 224, 224, 0.5);
	}

	.bb-link {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		margin-top: 1.8rem;
		font-weight: 700;
		color: var(--view-accent, #18debe);
		transition: gap 0.25s ease;
	}
	.bb-link:hover { gap: 0.8rem; }

	/* media column */
	.bb-media { position: relative; }
	.bb-photo {
		margin: 0;
		border-radius: 1.1rem;
		overflow: hidden;
		border: 1px solid rgba(134, 226, 239, 0.18);
		background: #0d1119;
		box-shadow: 0 40px 90px -40px rgba(0, 0, 0, 0.9);
	}
	.bb-photo-bar {
		display: flex;
		align-items: center;
		gap: 6px;
		padding: 0.6rem 0.85rem;
		background: #11161f;
		border-bottom: 1px solid rgba(255, 255, 255, 0.06);
	}
	.bb-dot { width: 10px; height: 10px; border-radius: 9999px; background: #2a3340; }
	.bb-dot:first-child { background: #ff5f57; }
	.bb-dot:nth-child(2) { background: #febc2e; }
	.bb-dot:nth-child(3) { background: #28c840; }
	.bb-photo-name { margin-left: 6px; font-family: ui-monospace, monospace; font-size: 0.78rem; color: rgba(207, 224, 224, 0.6); }
	.bb-photo-meta { margin-left: auto; font-family: ui-monospace, monospace; font-size: 0.72rem; color: rgba(207, 224, 224, 0.35); }
	.bb-photo img { display: block; width: 100%; height: auto; }
	.bb-photo-cap {
		position: absolute;
		bottom: 12px;
		left: 12px;
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		padding: 0.35rem 0.7rem;
		border-radius: 9999px;
		background: rgba(11, 15, 23, 0.78);
		border: 1px solid rgba(255, 255, 255, 0.12);
		backdrop-filter: blur(8px);
		font-size: 0.74rem;
		color: rgba(255, 255, 255, 0.85);
	}
	.bb-photo-live {
		width: 7px; height: 7px; border-radius: 9999px; background: #28c840;
		box-shadow: 0 0 0 0 rgba(40, 200, 64, 0.5);
		animation: bb-pulse 2s infinite;
	}
	@keyframes bb-pulse {
		0% { box-shadow: 0 0 0 0 rgba(40, 200, 64, 0.5); }
		70% { box-shadow: 0 0 0 6px rgba(40, 200, 64, 0); }
		100% { box-shadow: 0 0 0 0 rgba(40, 200, 64, 0); }
	}

	/* branded media placeholder */
	.media-frame {
		position: absolute;
		right: -14px;
		bottom: -22px;
		display: flex;
		align-items: center;
		gap: 0.7rem;
		padding: 0.7rem 1rem 0.7rem 0.7rem;
		border-radius: 0.9rem;
		border: 1px dashed rgba(134, 226, 239, 0.45);
		background: rgba(13, 17, 25, 0.9);
		backdrop-filter: blur(10px);
		box-shadow: 0 20px 40px -18px rgba(0, 0, 0, 0.7);
		cursor: pointer;
		transition: border-color 0.25s ease, transform 0.25s ease;
	}
	.media-frame:hover { border-color: var(--view-accent, #18debe); transform: translateY(-3px); }
	.mf-play {
		display: grid;
		place-items: center;
		width: 38px;
		height: 38px;
		border-radius: 9999px;
		color: #06231c;
		background: linear-gradient(135deg, #8dfeea, var(--view-accent, #18debe));
		flex-shrink: 0;
	}
	.mf-text { display: flex; flex-direction: column; text-align: left; }
	.mf-title { font-size: 0.86rem; font-weight: 700; color: #fff; }
	.mf-sub { font-size: 0.72rem; color: rgba(207, 224, 224, 0.5); font-family: ui-monospace, monospace; }

	@media (max-width: 919px) {
		.media-frame { position: static; margin-top: 1.5rem; width: fit-content; right: auto; bottom: auto; }
	}
	@media (prefers-reduced-motion: reduce) {
		.bb-photo-live { animation: none !important; }
	}
</style>
