---
// Builder view body — a world for engineers. The page itself behaves like
// a dev environment: a terminal that types, services as code files, the
// process as a git graph, shipped work as a deployments panel, and
// testimonials as pull-request approvals.
import { Icon } from 'astro-icon';

const stats = [
	{ to: 65, suffix: '+', label: 'products shipped' },
	{ to: 25, suffix: '+', label: 'specialists' },
	{ to: 7, suffix: '+', label: 'years in production' },
	{ to: 10, suffix: '+', label: 'countries' },
];

// terminal script — $ lines get typed, the rest print
const termLines = [
	{ cmd: true, text: 'whoami' },
	{ cmd: false, text: 'swizel — a 25+ person product studio', cls: '' },
	{ cmd: true, text: 'swizel init your-product' },
	{ cmd: false, text: '✔ design system ready', cls: 'tl-ok' },
	{ cmd: false, text: '✔ engineers assigned (7)', cls: 'tl-ok' },
	{ cmd: false, text: '✔ CI/CD pipeline configured', cls: 'tl-ok' },
	{ cmd: false, text: '➜ shipping in weeks, not quarters', cls: 'tl-accent' },
];

const files = [
	{
		id: 'design',
		name: 'design.tsx',
		icon: 'mdi:language-typescript',
		code: [
			{ t: 'cm', s: '// interfaces your users already understand' },
			{ t: 'plain', s: '' },
			{ t: 'mixed', s: [['kw', 'export function '], ['fn', 'Brand'], ['plain', '() {']] },
			{ t: 'mixed', s: [['plain', '  '], ['kw', 'return'], ['plain', ' (']] },
			{ t: 'mixed', s: [['plain', '    <'], ['tag', 'Identity'], ['plain', ' '], ['attr', 'voice'], ['plain', '='], ['str', '"yours"'], ['plain', ' />']] },
			{ t: 'mixed', s: [['plain', '    <'], ['tag', 'Interface'], ['plain', ' '], ['attr', 'feel'], ['plain', '='], ['str', '"effortless"'], ['plain', ' />']] },
			{ t: 'mixed', s: [['plain', '    <'], ['tag', 'Motion'], ['plain', ' '], ['attr', 'amount'], ['plain', '='], ['str', '"just right"'], ['plain', ' />']] },
			{ t: 'plain', s: '  );' },
			{ t: 'plain', s: '}' },
		],
	},
	{
		id: 'build',
		name: 'build.ts',
		icon: 'mdi:code-braces',
		code: [
			{ t: 'cm', s: '// web & mobile, engineered to scale' },
			{ t: 'plain', s: '' },
			{ t: 'mixed', s: [['kw', 'async function '], ['fn', 'ship'], ['plain', '(idea: '], ['tag', 'Idea'], ['plain', ') {']] },
			{ t: 'mixed', s: [['plain', '  '], ['kw', 'const'], ['plain', ' spec  = '], ['kw', 'await'], ['plain', ' '], ['fn', 'discover'], ['plain', '(idea);']] },
			{ t: 'mixed', s: [['plain', '  '], ['kw', 'const'], ['plain', ' build = '], ['kw', 'await'], ['plain', ' '], ['fn', 'engineer'], ['plain', '(spec);']] },
			{ t: 'mixed', s: [['plain', '  '], ['kw', 'await'], ['plain', ' '], ['fn', 'test'], ['plain', '(build); '], ['cm', '// every time']] },
			{ t: 'mixed', s: [['plain', '  '], ['kw', 'return'], ['plain', ' '], ['fn', 'launch'], ['plain', '(build); '], ['cm', '// weeks, not quarters']] },
			{ t: 'plain', s: '}' },
		],
	},
	{
		id: 'market',
		name: 'market.md',
		icon: 'mdi:language-markdown',
		code: [
			{ t: 'tag', s: '# Growth that compounds' },
			{ t: 'plain', s: '' },
			{ t: 'mixed', s: [['accent', '- '], ['plain', 'SEO that ranks for what buyers type']] },
			{ t: 'mixed', s: [['accent', '- '], ['plain', 'Ads that pay for themselves']] },
			{ t: 'mixed', s: [['accent', '- '], ['plain', 'Content people actually share']] },
			{ t: 'plain', s: '' },
			{ t: 'cm', s: '> shipped is only half the job —' },
			{ t: 'cm', s: '> someone has to find it.' },
		],
	},
	{
		id: 'maintain',
		name: 'maintain.yml',
		icon: 'mdi:cog-outline',
		code: [
			{ t: 'cm', s: '# we stay after launch' },
			{ t: 'mixed', s: [['attr', 'uptime'], ['plain', ': '], ['str', '99.9%']] },
			{ t: 'mixed', s: [['attr', 'monitoring'], ['plain', ': '], ['str', 'around-the-clock']] },
			{ t: 'mixed', s: [['attr', 'backups'], ['plain', ': '], ['str', 'automated']] },
			{ t: 'mixed', s: [['attr', 'response'], ['plain', ': '], ['str', 'same-day']] },
			{ t: 'mixed', s: [['attr', 'support'], ['plain', ':']] },
			{ t: 'mixed', s: [['plain', '  '], ['accent', '- '], ['str', 'devops']] },
			{ t: 'mixed', s: [['plain', '  '], ['accent', '- '], ['str', 'scaling']] },
			{ t: 'mixed', s: [['plain', '  '], ['accent', '- '], ['str', 'real humans']] },
		],
	},
];

const commits = [
	{ hash: 'a3f9c21', type: 'init', msg: 'discover & spec', desc: 'Goals, users and scope — locked together, in writing.' },
	{ hash: 'b8e2d47', type: 'feat', msg: 'design system', desc: 'Brand, UI and a clickable prototype you can feel.' },
	{ hash: 'c5a1f93', type: 'feat', msg: 'build & test', desc: 'Engineering in tight, visible loops. You see every push.' },
	{ hash: 'd9c4b06', type: 'release', msg: 'v1.0 → production', desc: 'Launch day. Monitored, measured, celebrated.' },
	{ hash: 'e2f7a58', type: 'chore', msg: 'scale & maintain', desc: 'We stay — uptime, growth and the next features.' },
];

const deploys = [
	{ name: 'brixmarket', domain: 'brixmarket.com', sector: 'Real estate', img: '/images/portfolio/brix%20marketplace.jpg', url: 'https://brixmarket.com/', uptime: '99.9%' },
	{ name: 'betslipswitch', domain: 'betslipswitch.com', sector: 'Sports', img: '/images/portfolio/betslipswitch.jpg', url: 'https://betslipswitch.com/', uptime: '99.9%' },
	{ name: 'saros-learning', domain: 'sarosinternationallearning.com', sector: 'Education', img: '/images/portfolio/sarosgp.jpg', url: 'https://sarosinternationallearning.com/', uptime: '99.9%' },
	{ name: 'convertmybetcode', domain: 'convertmybetcode.com', sector: 'Sports', img: '', url: 'https://convertmybetcode.com/', uptime: '99.8%' },
	{ name: 'buygas', domain: 'buygas.org', sector: 'On-demand delivery', img: '', url: 'https://buygas.org/', uptime: '99.9%' },
	{ name: 'purple-panda', domain: 'purplepanda.world', sector: 'Marketing', img: '/images/portfolio/purplepanda%20world.jpg', url: '', uptime: '99.9%' },
];

const sectors = [
	'fintech',
	'real-estate',
	'sports',
	'e-commerce',
	'education',
	'logistics',
	'healthcare',
	'beauty',
	'energy',
	'agritech',
	'hospitality',
	'media',
	'retail',
	'travel',
	'gaming',
	'legal',
];

const logos = [
	'betslipswitch.svg',
	'trueverdict.png',
	'brix market logo.svg',
	'ejike-fc.svg',
	'purple-panda.svg',
	'saros-sgp.svg',
	'my eya homes.svg',
	'the-presidential-diary.png',
	'hemamsynergy.png',
];

const reviews = [
	{ name: 'Favour', img: '/testimonial/favour.jpeg', body: 'Geniuses, honestly. Working with them was effortless from kickoff to launch.', files: '+1 product · −0 regrets' },
	{ name: 'Chidimma', img: '/testimonial/chidima.jpeg', body: 'Warm, responsive and a true extension of our team. Every sprint, visible.', files: '+1 platform · −100 worries' },
	{ name: 'Russell', img: '/testimonial/russell.jpeg', body: 'Friendly and efficient. I have trusted them with my products for years.', files: '+3 releases · −0 downtime' },
	{ name: 'Cheta', img: '/testimonial/cheta.jpeg', body: 'Thorough, polite and always on time. They make hard things feel easy.', files: '+1 store · −0 missed dates' },
];
---

<div class="bbody view-body view-body-builder">
	<!-- ── 01 · whoami ─────────────────────────────────────── -->
	<section class="bb-sec" data-cursor="term">
		<div class="bb-wrap bb-about">
			<div class="bb-copy bb-rev">
				<span class="bb-kick">// whoami</span>
				<h2 class="bb-h">Your team, <span class="bb-acc">as a service.</span></h2>
				<p class="bb-p">
					Plug a full squad of senior engineers and designers into your
					idea. We ship it fast, keep it running, and stay to scale it —
					no hand-offs, no guesswork.
				</p>
				<ul class="bb-stats">
					{
						stats.map((s) => (
							<li>
								<strong data-count={s.to} data-suffix={s.suffix}>0{s.suffix}</strong>
								<span>{s.label}</span>
							</li>
						))
					}
				</ul>
				<a href="/about" class="bb-link">
					The humans behind the commits
					<Icon width={16} name="mdi:arrow-right" />
				</a>
			</div>

			<div class="bb-term bb-rev" id="bb-term">
				<div class="bb-winbar">
					<span class="bb-dot bb-dot--r"></span>
					<span class="bb-dot bb-dot--y"></span>
					<span class="bb-dot bb-dot--g"></span>
					<span class="bb-wintitle">swizel — zsh</span>
				</div>
				<div class="bb-termbody">
					{
						termLines.map((l) => (
							<p
								class:list={['bb-tline', l.cls, { 'bb-tline--cmd': l.cmd }]}
								data-text={l.text}
								data-cmd={l.cmd ? '1' : undefined}
							>
								{l.cmd && <span class="bb-prompt">$</span>}
								<span class="bb-ttext" />
							</p>
						))
					}
					<p class="bb-tline bb-tline--cursorline">
						<span class="bb-prompt">$</span>
						<span class="bb-caret" aria-hidden="true"></span>
					</p>
				</div>
			</div>
		</div>
	</section>

	<!-- ── 01b · the studio, in frames ─────────────────────── -->
	<section class="bb-sec" data-cursor="repo">
		<div class="bb-wrap bb-wrap--wide">
			<div class="bb-head bb-rev">
				<span class="bb-kick">// the_studio</span>
				<h2 class="bb-h">Real people, <span class="bb-acc">real keyboards.</span></h2>
			</div>
			<div class="bb-gallery bb-rev">
				<div class="bb-shot bb-shot--big">
					<Icon width={30} name="mdi:image-outline" />
					<span class="bb-shot-name">team-at-work.jpg</span>
					<span class="bb-shot-sub">Big horizontal shot — the squad, mid-build</span>
				</div>
				<div class="bb-shot-stack">
					<div class="bb-shot bb-shot--loud">
						<Icon width={22} name="mdi:image-outline" />
						<span class="bb-shot-name">launch-day.jpg</span>
						<span class="bb-shot-sub">The loud one</span>
					</div>
					<div class="bb-shot">
						<Icon width={22} name="mdi:image-outline" />
						<span class="bb-shot-name">late-night-ship.jpg</span>
					</div>
				</div>
			</div>

			<!-- the idea compiler — a tiny game: hit build, watch it ship -->
			<div class="bb-game bb-rev" id="bb-game">
				<div class="bb-game-head">
					<span class="bb-game-title">// got_an_idea? compile it:</span>
					<span class="bb-game-status" id="bb-game-status">ready</span>
				</div>
				<div class="bb-game-bar">
					<span class="bb-game-fill" id="bb-game-fill"></span>
				</div>
				<p class="bb-game-msg" id="bb-game-msg">hit the button — we'll handle the rest.</p>
				<div class="bb-game-row">
					<button class="bb-game-btn" type="button" id="bb-game-btn">
						$ npm run build:my-idea
					</button>
					<a class="bb-game-ship" id="bb-game-ship" href="/contact" hidden>
						🚀 Ship it for real
						<Icon width={15} name="mdi:arrow-right" />
					</a>
				</div>
				<div class="bb-game-burst" id="bb-game-burst" aria-hidden="true"></div>
			</div>
		</div>
	</section>

	<!-- ── 02 · services as files ──────────────────────────── -->
	<section class="bb-sec" data-cursor="pkg">
		<div class="bb-wrap">
			<div class="bb-head bb-rev">
				<span class="bb-kick">// services</span>
				<h2 class="bb-h">Everything you need, <span class="bb-acc">one repo.</span></h2>
				<p class="bb-p bb-p--center">
					Four disciplines, one team. Click through the files.
				</p>
			</div>

			<div class="bb-editor bb-rev" id="bb-editor">
				<div class="bb-tabs" role="tablist" aria-label="Services">
					{
						files.map((f, i) => (
							<button
								class:list={['bb-tab', { 'is-on': i === 0 }]}
								type="button"
								role="tab"
								aria-selected={i === 0 ? 'true' : 'false'}
								data-tab={f.id}
							>
								<Icon width={15} name={f.icon} />
								{f.name}
							</button>
						))
					}
				</div>
				{
					files.map((f, i) => (
						<pre
							class:list={['bb-file', { 'is-on': i === 0 }]}
							data-file={f.id}
						>{f.code.map((line, li) => (
							<span class="bb-cline"><span class="bb-ln">{String(li + 1).padStart(2, ' ')}</span>{
								line.t === 'mixed'
									? (line.s as [string, string][]).map(([cls, txt]) => <span class={`tk-${cls}`}>{txt}</span>)
									: <span class={`tk-${line.t}`}>{line.s}</span>
							}</span>
						))}</pre>
					))
				}
			</div>
		</div>
	</section>

	<!-- ── 03 · process as git log ─────────────────────────── -->
	<section class="bb-sec" data-cursor="branch">
		<div class="bb-wrap bb-gitwrap">
			<div class="bb-copy bb-rev">
				<span class="bb-kick">// how_we_work</span>
				<h2 class="bb-h">git log <span class="bb-acc">--your-product</span></h2>
				<p class="bb-p">
					No black box. We work in tight, visible loops — you see every
					commit from the first spec to the release tag, and beyond.
				</p>
				<a href="/contact" class="bb-link">
					Start your first commit
					<Icon width={16} name="mdi:arrow-right" />
				</a>
			</div>

			<ol class="bb-git" id="bb-git">
				{
					commits.map((c) => (
						<li class="bb-commit bb-rev">
							<span class="bb-node" aria-hidden="true"></span>
							<div class="bb-commit-card">
								<div class="bb-commit-top">
									<span class="bb-hash">{c.hash}</span>
									<span class:list={['bb-ctype', `bb-ctype--${c.type}`]}>{c.type}</span>
									<span class="bb-cmsg">{c.msg}</span>
								</div>
								<p class="bb-cdesc">{c.desc}</p>
							</div>
						</li>
					))
				}
			</ol>
		</div>
	</section>

	<!-- ── 04 · deployments ────────────────────────────────── -->
	<section class="bb-sec" data-cursor="repo">
		<div class="bb-wrap">
			<div class="bb-head bb-rev">
				<span class="bb-kick">// deployments</span>
				<h2 class="bb-h">Live <span class="bb-acc">in production.</span></h2>
				<p class="bb-p bb-p--center">
					Not mockups — real products carrying real businesses, right now.
				</p>
			</div>

			<!-- CI pipeline — runs on a loop, like every good pipeline should -->
			<div class="bb-ci bb-rev" id="bb-ci" aria-hidden="true">
				<span class="bb-ci-file">ci/pipeline.yml</span>
				{
					['install', 'build', 'test', 'deploy'].map((step) => (
						<span class="bb-ci-step" data-step={step}>
							<span class="bb-ci-ico">
								<span class="bb-ci-spin" />
								<Icon class="bb-ci-check" width={12} name="mdi:check-bold" />
							</span>
							{step}
						</span>
					))
				}
				<span class="bb-ci-pass" id="bb-ci-pass">✓ build passing</span>
			</div>

			<div class="bb-deploys bb-rev">
				<div class="bb-deploys-head">
					<span>Project</span>
					<span class="bb-dh-status">Status</span>
					<span class="bb-dh-uptime">Uptime</span>
					<span></span>
				</div>
				{
					deploys.map((d) => {
						const Tag = d.url ? 'a' : 'div';
						return (
							<Tag
								class="bb-deploy"
								href={d.url || undefined}
								target={d.url ? '_blank' : undefined}
								rel={d.url ? 'noopener noreferrer' : undefined}
							>
								<span class="bb-deploy-id">
									{d.img ? (
										<img src={d.img} alt="" loading="lazy" />
									) : (
										<span class="bb-deploy-ph">
											<Icon width={15} name="mdi:image-outline" />
										</span>
									)}
									<span class="bb-deploy-name">
										<strong>{d.name}</strong>
										<em>{d.domain} · {d.sector}</em>
									</span>
								</span>
								<span class="bb-deploy-status">
									<span class="bb-live" aria-hidden="true"></span>
									Ready · Production
								</span>
								<span class="bb-deploy-uptime">{d.uptime}</span>
								<span class="bb-deploy-go">
									{d.url && <Icon width={15} name="mdi:arrow-top-right" />}
								</span>
							</Tag>
						);
					})
				}
				<a class="bb-deploys-all" href="/portfolio">
					View all 65+ projects
					<Icon width={15} name="mdi:arrow-right" />
				</a>
			</div>

			<div class="bb-demo bb-rev">
				<Icon width={30} name="mdi:play-circle-outline" />
				<span class="bb-demo-label">demo.webm — video placeholder</span>
				<span class="bb-demo-sub">Your product walkthrough drops in here</span>
			</div>
		</div>
	</section>

	<!-- ── 05 · the stack ──────────────────────────────────── -->
	<section class="bb-sec" data-cursor="pkg">
		<div class="bb-wrap bb-stackwrap">
			<div class="bb-copy bb-rev">
				<span class="bb-kick">// the_stack</span>
				<h2 class="bb-h">A stack <span class="bb-acc">you'd pick yourself.</span></h2>
				<p class="bb-p">
					Modern, boring-in-the-good-way technology. Chosen for your
					product's next five years — not for our résumés.
				</p>
			</div>

			<div class="bb-pkg bb-rev">
				<div class="bb-winbar">
					<span class="bb-dot bb-dot--r"></span>
					<span class="bb-dot bb-dot--y"></span>
					<span class="bb-dot bb-dot--g"></span>
					<span class="bb-wintitle">stack.config</span>
				</div>
				<div class="bb-stackbody">
					<div class="bb-stackrow">
						<span class="bb-stackkey">frontend:</span>
						<span class="bb-stackchips">
							<span class="bb-stackchip">React</span>
							<span class="bb-stackchip">Next.js</span>
							<span class="bb-stackchip">TypeScript</span>
						</span>
					</div>
					<div class="bb-stackrow">
						<span class="bb-stackkey">mobile:</span>
						<span class="bb-stackchips">
							<span class="bb-stackchip">Flutter</span>
							<span class="bb-stackchip">React Native</span>
						</span>
					</div>
					<div class="bb-stackrow">
						<span class="bb-stackkey">backend:</span>
						<span class="bb-stackchips">
							<span class="bb-stackchip">Node.js</span>
							<span class="bb-stackchip">Python</span>
							<span class="bb-stackchip">PostgreSQL</span>
						</span>
					</div>
					<div class="bb-stackrow">
						<span class="bb-stackkey">cloud:</span>
						<span class="bb-stackchips">
							<span class="bb-stackchip">AWS</span>
							<span class="bb-stackchip">Firebase</span>
						</span>
					</div>
					<div class="bb-stackrow">
						<span class="bb-stackkey">design:</span>
						<span class="bb-stackchips">
							<span class="bb-stackchip">Figma</span>
						</span>
					</div>
					<div class="bb-stackrow bb-stackrow--joke">
						<span class="bb-stackkey">fuel:</span>
						<span class="bb-stackchips">
							<span class="bb-stackchip bb-stackchip--coffee">coffee — non-negotiable ☕</span>
						</span>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- ── 06 · reviews as PR approvals ────────────────────── -->
	<section class="bb-sec" data-cursor="quote">
		<div class="bb-wrap">
			<div class="bb-head bb-rev">
				<span class="bb-kick">// code_review</span>
				<h2 class="bb-h">Approved by <span class="bb-acc">the people who matter.</span></h2>
			</div>
			<div class="bb-prs">
				{
					reviews.map((r) => (
						<article class="bb-pr bb-rev">
							<div class="bb-pr-top">
								<img src={r.img} alt="" loading="lazy" />
								<span class="bb-pr-who">
									<strong>{r.name}</strong>
									<em>approved these changes</em>
								</span>
								<span class="bb-pr-badge">
									<Icon width={13} name="mdi:check-bold" />
									Approved
								</span>
							</div>
							<p class="bb-pr-body">“{r.body}”</p>
							<span class="bb-pr-files">{r.files}</span>
						</article>
					))
				}
			</div>
		</div>
	</section>

	<!-- ── 06b · proof strip: sectors + brands, fine & framed ── -->
	<section class="bb-sec bb-sec--tight" data-cursor="pkg">
		<div class="bb-wrap">
			<div class="bb-proof bb-rev">
				<div class="bb-winbar">
					<span class="bb-dot bb-dot--r"></span>
					<span class="bb-dot bb-dot--y"></span>
					<span class="bb-dot bb-dot--g"></span>
					<span class="bb-wintitle">proof-of-work.log</span>
				</div>
				<div class="bb-proof-row">
					<span class="bb-proof-tag">sectors:</span>
					<div class="bb-mq" aria-hidden="true">
						<div class="bb-mq-track bb-mq-track--code">
							{
								[0, 1].map(() =>
									sectors.map((s) => (
										<span class="bb-mq-item">
											<span class="tk-str">'{s}'</span><span class="tk-plain">,</span>
										</span>
									))
								)
							}
