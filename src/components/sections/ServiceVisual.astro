---
// The signature visual for a discipline — a bespoke, themed illustration that
// reflects what that discipline actually does. Self-contained so it can be
// dropped into different layouts (a full-width band, or beside intro copy).
// Themed via the inherited --c / --bd-* custom properties from .bdbody.
import type { Discipline } from '../../data/disciplines';
interface Props { d: Discipline; }
const { d } = Astro.props;
---

<div class="det-viz-wrap" data-cursor={d.cursor}>
	<span class="det-viz-glow" aria-hidden="true"></span>

	{d.visual === 'code' && (
		<div class="det-viz det-viz-code">
			<div class="dvc-bar"><i></i><i></i><i></i><span>app.tsx</span></div>
			<div class="dvc-body">
				<p class="dvc-ln"><b class="k">export</b> <b class="k">default</b> <b class="fn">build</b>() &#123;</p>
				<p class="dvc-ln">&nbsp;&nbsp;<b class="k">const</b> app = <b class="fn">create</b>(<b class="s">'swizel'</b>);</p>
				<p class="dvc-ln">&nbsp;&nbsp;app.<b class="fn">scale</b>(&#123; users: <b class="n">10_000</b> &#125;);</p>
				<p class="dvc-ln">&nbsp;&nbsp;<b class="k">return</b> app.<b class="fn">ship</b>();</p>
				<p class="dvc-ln">&#125;</p>
			</div>
			<div class="dvc-foot"><span class="dvc-dot" /> Deployed · build passed</div>
		</div>
	)}

	{d.visual === 'metrics' && (
		<div class="det-viz det-viz-metrics">
			<div class="dvm-card">
				<span class="dvm-up"><svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M12 4l8 10h-5v6H9v-6H4z" /></svg></span>
				<strong>+186%</strong><em>Organic traffic</em>
				<svg class="dvm-spark" viewBox="0 0 100 32" preserveAspectRatio="none"><polyline points="0,28 20,24 40,26 60,14 80,12 100,4" /></svg>
			</div>
			<div class="dvm-card">
				<span class="dvm-up"><svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M12 4l8 10h-5v6H9v-6H4z" /></svg></span>
				<strong>4.2×</strong><em>Return on ad spend</em>
				<svg class="dvm-spark" viewBox="0 0 100 32" preserveAspectRatio="none"><polyline points="0,26 20,20 40,22 60,16 80,9 100,6" /></svg>
			</div>
			<div class="dvm-card dvm-card--wide">
				<span class="dvm-up"><svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M12 4l8 10h-5v6H9v-6H4z" /></svg></span>
				<strong>+62k</strong><em>New followers this quarter</em>
				<svg class="dvm-spark" viewBox="0 0 100 32" preserveAspectRatio="none"><polyline points="0,30 25,25 50,20 75,11 100,3" /></svg>
			</div>
		</div>
	)}

	{d.visual === 'roadmap' && (
		<ol class="det-viz det-viz-roadmap">
			<li class="dvr-step"><span class="dvr-dot" /><div><strong>Discover</strong><em>Research, users &amp; workshops</em></div></li>
			<li class="dvr-step"><span class="dvr-dot" /><div><strong>Define</strong><em>Positioning &amp; priorities</em></div></li>
			<li class="dvr-step"><span class="dvr-dot" /><div><strong>Roadmap</strong><em>MVP scope &amp; estimates</em></div></li>
			<li class="dvr-step dvr-step--end"><span class="dvr-dot" /><div><strong>Build-ready</strong><em>A plan you can fund</em></div></li>
		</ol>
	)}

	{d.visual === 'status' && (
		<div class="det-viz det-viz-status">
			<div class="dvs-head"><span class="dvs-live" /> All systems operational</div>
			<div class="dvs-uptime">
				<strong>99.98%</strong><em>uptime · last 90 days</em>
				<div class="dvs-bars">{Array.from({ length: 40 }).map((_, i) => (<span class:list={['dvs-bar', { 'dvs-bar--dip': i === 27 }]} />))}</div>
			</div>
			<ul class="dvs-rows">
				<li><span class="dvs-ok" /> API <b>142 ms</b></li>
				<li><span class="dvs-ok" /> Database <b>healthy</b></li>
				<li><span class="dvs-ok" /> Backups <b>nightly</b></li>
			</ul>
		</div>
	)}

	{d.visual === 'flow' && (
		<div class="det-viz det-viz-flow">
			<span class="dvf-node"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h7l-1 8 10-12h-7z" /></svg>Trigger</span>
			<span class="dvf-wire" />
			<span class="dvf-node dvf-node--ai"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="7" width="16" height="13" rx="3" /><path d="M12 7V3M9 13h.01M15 13h.01" /></svg>AI engine</span>
			<span class="dvf-wire" />
			<span class="dvf-outs">
				<span class="dvf-out">Reply sent</span>
				<span class="dvf-out">Record updated</span>
				<span class="dvf-out">Team notified</span>
			</span>
		</div>
	)}

	{d.visual === 'gallery' && (
		<div class="det-viz det-viz-specimen">
			<div class="dvg-swatches">
				<span style="--s:#28a6ec" /><span style="--s:#7c5cff" /><span style="--s:#10b981" /><span style="--s:#f59e0b" /><span style="--s:#0b0d18" />
			</div>
			<div class="dvg-type"><b>Aa</b><span>Display / 700<br />The quick brown fox.</span></div>
			<div class="dvg-ui"><span class="dvg-btn">Get started</span><span class="dvg-chip">Components</span></div>
		</div>
	)}
</div>

<style>
	/* ════ Signature visual — themed by inherited --c / --bd-* ════ */
	.det-viz-wrap { position: relative; isolation: isolate; }
	.det-viz-glow { position: absolute; inset: -12% -8%; z-index: -1; pointer-events: none; background: radial-gradient(420px 300px at 65% 25%, color-mix(in srgb, var(--c) 28%, transparent), transparent 65%); filter: blur(36px); opacity: 0.75; }
	:global(html:not(.dark)) .det-viz-glow { opacity: 0.4; }
	.det-viz {
		position: relative; border-radius: 1.5rem; overflow: hidden;
		background: var(--bd-glass); border: 1px solid color-mix(in srgb, var(--c) 24%, var(--bd-glass-border));
		box-shadow: var(--bd-shadow); backdrop-filter: blur(20px) saturate(130%); -webkit-backdrop-filter: blur(20px) saturate(130%);
		padding: clamp(1.2rem, 2.5vw, 1.7rem);
	}

	/* —— Development: code editor —— */
	.det-viz-code { padding: 0; font-family: ui-monospace, 'SF Mono', 'JetBrains Mono', Menlo, monospace; }
	.dvc-bar { display: flex; align-items: center; gap: 0.5rem; padding: 0.7rem 1rem; background: color-mix(in srgb, var(--bd-ink) 8%, transparent); border-bottom: 1px solid var(--bd-glass-border); }
	.dvc-bar i { width: 11px; height: 11px; border-radius: 50%; background: color-mix(in srgb, var(--bd-muted) 45%, transparent); }
	.dvc-bar i:first-child { background: #ff5f57; } .dvc-bar i:nth-child(2) { background: #febc2e; } .dvc-bar i:nth-child(3) { background: #28c840; }
	.dvc-bar span { margin-left: auto; font-size: 0.74rem; color: var(--bd-muted); }
	.dvc-body { padding: 1.1rem 1.2rem; font-size: clamp(0.78rem, 1.5vw, 0.92rem); line-height: 1.85; }
	.dvc-ln { margin: 0; white-space: pre; color: color-mix(in srgb, var(--bd-ink) 78%, transparent); }
	.dvc-ln .k { color: color-mix(in srgb, var(--c) 75%, #c792ea); font-weight: 600; }
	.dvc-ln .fn { color: #82aaff; font-weight: 600; }
	.dvc-ln .s { color: #c3e88d; }
	.dvc-ln .n { color: #f78c6c; }
	:global(html:not(.dark)) .dvc-ln .fn { color: #2563eb; }
	:global(html:not(.dark)) .dvc-ln .s { color: #0a7d3c; }
	:global(html:not(.dark)) .dvc-ln .n { color: #c2410c; }
	.dvc-foot { display: flex; align-items: center; gap: 0.5rem; padding: 0.7rem 1.2rem; border-top: 1px solid var(--bd-glass-border); font-size: 0.78rem; color: var(--bd-muted); }
	.dvc-dot { width: 8px; height: 8px; border-radius: 50%; background: #28c840; box-shadow: 0 0 0 0 rgba(40, 200, 64, 0.5); animation: dv-pulse 2.2s ease-out infinite; }
	@keyframes dv-pulse { 0%{ box-shadow: 0 0 0 0 rgba(40, 200, 64, 0.5); } 70%,100%{ box-shadow: 0 0 0 7px rgba(40, 200, 64, 0); } }

	/* —— Marketing: growth metrics —— */
	.det-viz-metrics { background: none; border: none; box-shadow: none; backdrop-filter: none; -webkit-backdrop-filter: none; padding: 0; display: grid; grid-template-columns: 1fr 1fr; gap: 0.8rem; }
	.dvm-card { position: relative; overflow: hidden; padding: 1.1rem 1.2rem 1.4rem; border-radius: 1.2rem; background: var(--bd-glass); border: 1px solid color-mix(in srgb, var(--c) 22%, var(--bd-glass-border)); box-shadow: var(--bd-shadow); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); }
	.dvm-card--wide { grid-column: 1 / -1; }
	.dvm-up { display: inline-grid; place-items: center; width: 24px; height: 24px; border-radius: 7px; color: #28c840; background: rgba(40, 200, 64, 0.14); margin-bottom: 0.5rem; }
	.dvm-card strong { display: block; font-size: clamp(1.5rem, 3.5vw, 2.1rem); font-weight: 800; letter-spacing: -0.02em; line-height: 1; }
	.dvm-card em { font-style: normal; font-size: 0.8rem; color: var(--bd-muted); }
	.dvm-spark { position: absolute; right: 0; bottom: 0; width: 55%; height: 34px; opacity: 0.85; }
	.dvm-spark polyline { fill: none; stroke: var(--c); stroke-width: 2.5; stroke-linecap: round; stroke-linejoin: round; }
	.dvm-card--wide .dvm-spark { width: 40%; }

	/* —— Strategy: roadmap —— */
	.det-viz-roadmap { list-style: none; margin: 0; display: grid; gap: 0; background: var(--bd-glass); border: 1px solid color-mix(in srgb, var(--c) 22%, var(--bd-glass-border)); box-shadow: var(--bd-shadow); backdrop-filter: blur(18px); -webkit-backdrop-filter: blur(18px); border-radius: 1.5rem; padding: clamp(1.3rem, 3vw, 1.9rem); }
	.dvr-step { position: relative; display: flex; align-items: flex-start; gap: 0.9rem; padding-bottom: 1.4rem; }
	.dvr-step::before { content: ''; position: absolute; left: 9px; top: 20px; bottom: -4px; width: 2px; background: linear-gradient(180deg, var(--c), color-mix(in srgb, var(--c) 25%, transparent)); }
	.dvr-step--end::before { display: none; }
	.dvr-step--end { padding-bottom: 0; }
	.dvr-dot { position: relative; z-index: 1; flex-shrink: 0; width: 20px; height: 20px; margin-top: 1px; border-radius: 50%; background: var(--c); box-shadow: 0 0 0 4px color-mix(in srgb, var(--c) 20%, transparent); }
	.dvr-step--end .dvr-dot { background: linear-gradient(135deg, color-mix(in srgb, var(--c) 90%, #fff), var(--c)); }
	.dvr-step strong { display: block; font-size: 1.02rem; font-weight: 700; letter-spacing: -0.01em; }
	.dvr-step em { font-style: normal; font-size: 0.85rem; color: var(--bd-muted); }

	/* —— Maintenance: status dashboard —— */
	.det-viz-status { display: grid; gap: 1.1rem; }
	.dvs-head { display: flex; align-items: center; gap: 0.55rem; font-size: 0.98rem; font-weight: 700; }
	.dvs-live { width: 10px; height: 10px; border-radius: 50%; background: #28c840; box-shadow: 0 0 0 0 rgba(40, 200, 64, 0.5); animation: dv-pulse 2.2s ease-out infinite; }
	.dvs-uptime strong { font-size: clamp(1.7rem, 4vw, 2.3rem); font-weight: 800; letter-spacing: -0.02em; }
	.dvs-uptime em { font-style: normal; font-size: 0.82rem; color: var(--bd-muted); margin-left: 0.5rem; }
	.dvs-bars { display: flex; gap: 2px; margin-top: 0.7rem; height: 34px; align-items: flex-end; }
	.dvs-bar { flex: 1; height: 100%; border-radius: 2px; background: linear-gradient(180deg, color-mix(in srgb, var(--c) 75%, transparent), color-mix(in srgb, var(--c) 35%, transparent)); }
	.dvs-bar--dip { background: linear-gradient(180deg, #f59e0b, color-mix(in srgb, #f59e0b 40%, transparent)); height: 62%; }
	.dvs-rows { list-style: none; margin: 0; padding: 0.6rem 0 0; display: grid; gap: 0.55rem; border-top: 1px solid var(--bd-glass-border); }
	.dvs-rows li { display: flex; align-items: center; gap: 0.55rem; font-size: 0.88rem; color: var(--bd-muted); }
	.dvs-rows b { margin-left: auto; color: var(--bd-ink); font-weight: 600; }
	.dvs-ok { width: 8px; height: 8px; border-radius: 50%; background: #28c840; }

	/* —— AI: automation flow —— */
	.det-viz-flow { display: flex; flex-direction: column; align-items: center; gap: 0; padding: clamp(1.5rem, 3vw, 2.2rem); }
	.dvf-node { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.7rem 1.1rem; border-radius: 0.9rem; font-size: 0.92rem; font-weight: 600; background: color-mix(in srgb, var(--bd-ink) 6%, transparent); border: 1px solid var(--bd-glass-border); color: var(--bd-ink); }
	.dvf-node :global(svg) { color: var(--c); }
	.dvf-node--ai { background: linear-gradient(135deg, color-mix(in srgb, var(--c) 26%, transparent), color-mix(in srgb, var(--c) 10%, transparent)); border-color: color-mix(in srgb, var(--c) 45%, transparent); box-shadow: 0 0 30px -8px color-mix(in srgb, var(--c) 60%, transparent); }
	.dvf-node--ai :global(svg) { color: var(--bd-ink); }
	.dvf-wire { width: 2px; height: 26px; background: linear-gradient(180deg, color-mix(in srgb, var(--c) 70%, transparent), color-mix(in srgb, var(--c) 30%, transparent)); }
	.dvf-outs { display: flex; flex-wrap: wrap; justify-content: center; gap: 0.5rem; }
	.dvf-out { padding: 0.45rem 0.8rem; border-radius: 9999px; font-size: 0.8rem; font-weight: 600; color: color-mix(in srgb, var(--c) 80%, var(--bd-ink)); background: color-mix(in srgb, var(--c) 12%, transparent); border: 1px solid color-mix(in srgb, var(--c) 28%, transparent); }

	/* —— Design: type & colour specimen —— */
	.det-viz-specimen { display: grid; gap: 1.1rem; }
	.dvg-swatches { display: flex; gap: 0.5rem; }
	.dvg-swatches span { flex: 1; height: 40px; border-radius: 0.6rem; background: var(--s); border: 1px solid rgba(255, 255, 255, 0.12); box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.15); }
	.dvg-type { display: flex; align-items: center; gap: 1rem; }
	.dvg-type b { font-size: clamp(2.8rem, 7vw, 3.8rem); font-weight: 800; line-height: 0.9; letter-spacing: -0.04em; color: var(--c); }
	.dvg-type span { font-size: 0.92rem; line-height: 1.4; color: var(--bd-muted); }
	.dvg-ui { display: flex; align-items: center; gap: 0.7rem; }
	.dvg-btn { padding: 0.6rem 1.2rem; border-radius: 9999px; font-size: 0.88rem; font-weight: 600; color: #fff; background: linear-gradient(180deg, color-mix(in srgb, var(--c) 88%, #fff), var(--c)); box-shadow: 0 10px 24px -10px color-mix(in srgb, var(--c) 70%, transparent); }
	.dvg-chip { padding: 0.6rem 1.1rem; border-radius: 9999px; font-size: 0.88rem; font-weight: 600; color: var(--bd-ink); border: 1px solid color-mix(in srgb, var(--c) 40%, var(--bd-glass-border)); }

	@media (prefers-reduced-motion: reduce) {
		.dvc-dot, .dvs-live { animation: none; }
	}
</style>
