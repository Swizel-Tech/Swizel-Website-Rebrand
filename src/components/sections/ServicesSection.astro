---
import { Icon } from 'astro-icon';
import AccentHeader from '../HTML/AccentHeader.astro';
import Heading from '../HTML/Heading.astro';
import Section from '../HTML/Section.astro';
import PortfolioCTA from '../blocks/PortfolioCTA.astro';
// import CustomButton from '../CustomButton.astro';

const services = [
	{
		icon: 'design',
		title: 'Design',
		desc: 'A team skilled in brand design, graphics and user interface & experience design that makes your product unforgettable.',
	},
	{
		icon: 'development',
		title: 'Development',
		desc: 'Web and mobile engineers who build, test and scale fast — sit back as we turn your idea into a real product.',
	},
	{
		icon: 'market',
		title: 'Marketing',
		desc: 'We go beyond development to help you reach new audiences and grow across every media platform.',
	},
	{
		icon: 'maintain',
		title: 'Maintenance',
		desc: 'We also improve existing products and keep complex systems running smoothly and securely.',
	},
];
---

