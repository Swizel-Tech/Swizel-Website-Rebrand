<!-- Keep "<n> years" correct even if the static build is a year stale -->
<script is:inline>
	(function () {
		var words = ['zero','one','two','three','four','five','six','seven','eight','nine','ten','eleven','twelve','thirteen','fourteen','fifteen','sixteen','seventeen','eighteen','nineteen','twenty'];
		document.querySelectorAll('[data-years-since]').forEach(function (el) {
			var founded = parseInt(el.getAttribute('data-years-since'), 10);
			if (!founded) return;
			var n = Math.max(1, new Date().getFullYear() - founded);
			var w = words[n] ? words[n].charAt(0).toUpperCase() + words[n].slice(1) : String(n);
			el.textContent = w;
		});
	})();
</script>

