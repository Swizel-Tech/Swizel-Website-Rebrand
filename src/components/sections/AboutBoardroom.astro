---
// About — rendered in the Boardroom world: deep, glossy, cinematic. Reuses the
// boardroom engine (initBoardroomBody → reveals, counters, rotating quotes) and
// the themed custom cursor. Locked to the boardroom blue accent so the page
// always reads as "Swizel for business", whatever view the visitor last chose.
import { Icon } from 'astro-icon/components';
import { teamDetails } from '../../consts';

// Years in business, computed from the founding year so it self-increments
// every year (build-time value; a tiny runtime script below also corrects it).
const FOUNDED_YEAR = 2019;
const NUMBER_WORDS = [
	'zero', 'one', 'two', 'three', 'four', 'five', 'six', 'seven', 'eight',
	'nine', 'ten', 'eleven', 'twelve', 'thirteen', 'fourteen', 'fifteen',
	'sixteen', 'seventeen', 'eighteen', 'nineteen', 'twenty',
];
const yearsInBusiness = Math.max(1, new Date().getFullYear() - FOUNDED_YEAR);
const yearsWordRaw = NUMBER_WORDS[yearsInBusiness] || String(yearsInBusiness);
const yearsWord = yearsWordRaw.charAt(0).toUpperCase() + yearsWordRaw.slice(1);

const glance = [
	{ k: 'Since', v: '2019' },
	{ k: 'Products shipped', v: '65+' },
	{ k: 'Countries served', v: '10+' },
];

const numbers = [
	{ to: 65, suffix: '+', label: 'Products shipped' },
	{ to: yearsInBusiness, suffix: '+', label: 'Years in business' },
	{ to: 25, suffix: '+', label: 'Specialists on the team' },
	{ to: 98, suffix: '%', label: 'On-time delivery' },
	{ to: 5, decimals: 1, suffix: '', label: 'Average client rating' },
];

const values = [
	{
		icon: 'mdi:account-heart-outline',
		title: 'Client-first, always',
		desc: 'Your goals set the brief. We build for the people who use the thing, not for our portfolio.',
	},
	{
		icon: 'mdi:rocket-launch-outline',
		title: 'Ship, then sharpen',
		desc: 'We get a real product into real hands fast, then improve it with what the market tells us.',
		loud: true,
	},
	{
		icon: 'mdi:clock-check-outline',
		title: 'On time, on budget',
		desc: 'No surprises on the invoice or the calendar. You always know what ships next, and when.',
	},
	{
		icon: 'mdi:shield-check-outline',
		title: 'Built to last',
		desc: 'Secure, monitored and maintained for years, long after launch day is forgotten.',
	},
];

const milestones = [
	{
		year: '2019',
		title: 'The first line of code.',
		desc: 'Swizel starts in Nigeria, a small, stubborn team taking on its first builds for local businesses.',
	},
	{
		year: '2020',
		title: 'Products, not projects.',
		desc: 'We stop thinking in deliverables and start thinking in products, software meant to live and grow.',
	},
	{
		year: '2022',
		title: 'Mobile, everywhere.',
		desc: 'Native iOS and Android join the practice. The same team now ships across web and phone.',
	},
	{
		year: '2023',
		title: 'At home in every sector.',
		desc: 'Fintech, real estate, sports, education, logistics, the work spreads across the industries that move Africa.',
	},
	{
		year: '2025',
		title: 'Teaching the next ones.',
		desc: 'We open a free tech bootcamp, training new engineers, designers and marketers on real products.',
	},
	{
		year: '2026',
		title: '65+ and counting.',
		desc: 'Seven years in, more than sixty-five products live in the market, and we are only warming up.',
	},
];

// Leads first, then the wider team. Photos live in /teammates/<Name>.jpg
// Bio + experience are pulled from consts (same data as swizel.co's team modal).
const teamOrder = [
	{ name: 'Azoro', role: 'Business Development Lead' },
	{ name: 'Ruke', role: 'Product Manager' },
	{ name: 'Dennis', role: 'UI/UX Designer' },
	{ name: 'Mary', role: 'Software Engineer' },
	{ name: 'Stephen', role: 'Fullstack Developer' },
	{ name: 'Nathaniel', role: 'Frontend Developer' },
	{ name: 'Precious', role: 'Mobile Developer' },
	{ name: 'Linda', role: 'Marketing Lead' },
];
const team = teamOrder.map((m) => {
	const d = (teamDetails as any[]).find((t) => t.name === m.name) || {};
	return {
		...m,
		bio: d.bio || '',
		experience: (d.experience || []) as { company: string; jobDesc: string }[],
		linkedin: d.linkedinURL && d.linkedinURL !== '#' ? d.linkedinURL : '',
	};
});

const quotes = [
	{
		text: '“Warm, responsive and a true extension of our team. They took the worry out of shipping software.”',
		name: 'Chidimma',
		role: 'Client, education sector',
		img: '/testimonial/chidima.jpeg',
	},
	{
		text: '“Geniuses, honestly. Working with them was effortless from the first call to launch day.”',
		name: 'Favour',
		role: 'Client, marketing',
		img: '/testimonial/favour.jpeg',
	},
	{
		text: '“Thorough, polite and always on time. They make hard things feel easy.”',
		name: 'Cheta',
		role: 'Client, e-commerce',
		img: '/testimonial/cheta.jpeg',
	},
	{
		text: '“Friendly and efficient. I have trusted them with my products for years.”',
		name: 'Russell',
		role: 'Client, real estate',
		img: '/testimonial/russell.jpeg',
	},
];

const sectors = [
	'Fintech', 'Real estate', 'Sports', 'E-commerce', 'Education',
	'Logistics', 'Healthcare', 'Beauty', 'Energy', 'Agritech',
	'Hospitality', 'Media', 'Retail', 'Travel', 'Gaming', 'Legal',
];

const logos = [
	'betslipswitch.svg',
	'trueverdict.png',
	'brix market logo.svg',
	'ejike-fc.svg',
	'purple-panda.svg',
	'saros-sgp.svg',
	'my eya homes.svg',
	'the-presidential-diary.png',
	'hemamsynergy.png',
];

// What we do — the disciplines, American-Eagle-style "expertise" grid → /services
const services = [
	{
		icon: 'mdi:palette-outline',
		title: 'Design',
		desc: 'Brand identity, graphics and product design, interfaces your customers find effortless.',
		tag: 'Brand · UI/UX · Motion',
	},
	{
		icon: 'mdi:code-tags',
		title: 'Development',
		desc: 'Web and mobile engineering built to scale. We build, test and ship fast, without breaking things.',
		tag: 'Web · iOS · Android · APIs',
	},
	{
		icon: 'mdi:bullhorn-outline',
		title: 'Marketing',
		desc: 'We grow your audience across every platform that matters, and co-market the products we ship.',
		tag: 'SEO · Ads · Social · Content',
	},
	{
		icon: 'mdi:compass-outline',
		title: 'Strategy',
		desc: 'Research, define and lock the goal, a tailored product roadmap before a line of code is written.',
		tag: 'Research · Roadmaps · MVP',
	},
	{
		icon: 'mdi:wrench-outline',
		title: 'Maintenance',
		desc: 'Improving existing products and keeping complex systems healthy, secure and online, year after year.',
		tag: 'Support · DevOps · Uptime',
	},
	{
		icon: 'mdi:school-outline',
		title: 'Education',
		desc: 'A free bootcamp and The Brevarium, putting real, job-ready skills in the hands of the next builders.',
		tag: 'Bootcamp · Brevarium · Mentoring',
	},
];

// The Brevarium — latest plus past editions, all free to download. Swap the
// hrefs as new editions are released; older issues stay available here.
const brevariumEditions = [
	{ vol: 'Vol. 3', date: 'Latest · 2026', latest: true, href: '/brevarium/the-brevarium-latest.pdf' },
	{ vol: 'Vol. 2', date: '2025', latest: false, href: '/The Brevarium by Swizel.pdf' },
	{ vol: 'Vol. 1', date: '2024', latest: false, href: '/The Brevarium by Swizel.pdf' },
];

// Footer — four offices, uncompressed, with live local clocks
const offices = [
	{ flag: '🇳🇬', country: 'Nigeria', city: 'Abuja', lines: ['2155 Peculiar Estate', 'Lokogoma, Abuja'], tz: 'Africa/Lagos' },
	{ flag: '🇮🇪', country: 'Ireland', city: 'Cork', lines: ['Eden Hall, Modern Farm Road', 'Cork, Ireland'], tz: 'Europe/Dublin' },
	{ flag: '🇬🇧', country: 'United Kingdom', city: 'Sheffield', lines: ['1 Sheffield, South Yorkshire', 'S2 3DB, England'], tz: 'Europe/London' },
	{ flag: '🇺🇸', country: 'United States', city: 'New York', lines: ['Tiemann Ave', 'Bronx, New York'], tz: 'America/New_York' },
];

const footerSocials = [
	{ name: 'X (Twitter)', handle: '@swizelhq', icon: 'twitter', href: 'https://twitter.com/swizelhq' },
	{ name: 'Instagram', handle: '@swizelhq', icon: 'instagram', href: 'https://instagram.com/swizelhq' },
	{ name: 'LinkedIn', handle: 'Swizel Technologies', icon: 'linkedin', href: 'https://www.linkedin.com/company/swizel-technologies-limited/' },
	{ name: 'Facebook', handle: 'Swizel Technologies', icon: 'facebook', href: 'https://www.facebook.com/SWIZELTECHNOLOGIESLIMITED/' },
];

const footerPhones = [
	{ num: '+234 810 020 4570', flag: '🇳🇬' },
	{ num: '+1 701 498 1811', flag: '🇺🇸' },
];

const footerNav = ['Home', 'About', 'Services', 'Portfolio', 'Blog', 'Bootcamp', 'Contact'];
const currentYear = new Date().getFullYear();
---

<div class="bdbody bd-about view-body view-body-boardroom">
	<!-- ── Hero — immersive, two-column, alive ─────────────── -->
	<header class="bd-about-hero bd-reveal">
		<span class="bd-hero-aurora" aria-hidden="true"></span>
		<span class="bd-hero-orbs" aria-hidden="true">
			<i style="--x:8%; --d:0s; --s:1.1"></i>
			<i style="--x:24%; --d:-3s; --s:0.7"></i>
			<i style="--x:62%; --d:-6s; --s:1.3"></i>
			<i style="--x:82%; --d:-2s; --s:0.85"></i>
			<i style="--x:92%; --d:-8s; --s:1"></i>
		</span>

		<div class="bd-hero-grid">
			<div class="bd-hero-text">
				<span class="bd-hero-overline"><i></i>About Swizel</span>
				<h1 class="bd-display bd-about-h1">
					<span data-years-since={FOUNDED_YEAR}>{yearsWord}</span> years building the software
					<span class="bd-grad">Africa runs on.</span>
				</h1>
				<p class="bd-sub">
					Swizel is one product team, designers, engineers, analysts
					and marketers, turning ambitious ideas into software that
					ships, scales and keeps earning long after launch.
				</p>
				<div class="bd-links">
					<a href="/contact" class="bd-pill">Start a project</a>
					<a href="#bd-team" class="bd-link">
						Meet the team
						<Icon width={15} name="mdi:chevron-down" />
					</a>
				</div>
			</div>

			<div class="bd-hero-stage">
				<div class="bd-hero-chip bd-hero-chip--tr">
					<strong>65+</strong>
					<span>products shipped</span>
				</div>
				<div class="bd-hero-team-card">
					<div class="bd-hero-faces">
						{
							team.slice(0, 6).map((t) => (
								<span class="bd-hero-face">
									<img src={`/teammates/${t.name}.jpg`} alt="" loading="lazy" />
								</span>
							))
						}
						<span class="bd-hero-face bd-hero-face--more">
							<Icon width={20} name="mdi:plus" />
						</span>
					</div>
					<strong class="bd-hero-team-n">Outstanding specialists</strong>
					<span class="bd-hero-team-s">around the globe · since 2019</span>
					<a href="#bd-team" class="bd-link bd-hero-team-go">
						Meet a few
						<Icon width={14} name="mdi:arrow-down" />
					</a>
				</div>
				<div class="bd-hero-chip bd-hero-chip--bl">
					<strong>Global</strong>
					<span>clients worldwide</span>
				</div>
			</div>
		</div>

		<span class="bd-scroll-cue" aria-hidden="true">
			<Icon width={20} name="mdi:chevron-down" />
		</span>
	</header>

	<!-- ── Origin story — split, editorial ─────────────────── -->
	<div class="bd-grid">
		<section class="bd-tile bd-tile--row bd-about-story bd-reveal" data-cursor="clock">
			<div class="bd-tile-copy">
				<span class="bd-eyebrow">Our story</span>
				<h2 class="bd-h">It started with a stubborn belief.</h2>
				<p class="bd-p">
					That businesses across Africa deserved software as good as
					anything built anywhere else, fast, beautiful and built to
					last. So in 2019 a small team set out to prove it, one product
					at a time.
				</p>
				<p class="bd-p">
					We never wanted to be a vendor you hire and forget. We wanted
					to be the team you call first, the one that designs the idea,
					builds it, takes it to market, and stays to grow it. Sixty-five
					products later, that is still exactly what we do.
				</p>
				<a href="#bd-timeline" class="bd-link">
					How we got here
					<Icon width={15} name="mdi:chevron-right" />
				</a>
			</div>
			<div class="bd-media bd-media--tall">
				<span class="bd-media-sheen" aria-hidden="true"></span>
				<Icon width={26} name="mdi:image-outline" />
				<span class="bd-media-label">Image placeholder</span>
				<span class="bd-media-sub">The founding team, 2019</span>
			</div>
		</section>
	</div>

	<!-- ── Mission + Vision — on the deepest black for contrast ─ -->
	<div class="bd-grid bd-grid--narrow">
		<section class="bd-tile bd-tile--full bd-tile--void bd-reveal" data-cursor="chart">
			<span class="bd-eyebrow bd-eyebrow--center">Why we exist</span>
			<div class="bd-mv">
				<div class="bd-mv-item">
					<span class="bd-mv-tag">Mission</span>
					<p class="bd-mv-text">
						To help businesses turn their ideas into
						<span class="bd-grad">successful products</span>,
						driving the digitalisation of African enterprise, one
						launch at a time.
					</p>
				</div>
				<span class="bd-mv-divide" aria-hidden="true"></span>
				<div class="bd-mv-item">
					<span class="bd-mv-tag">Vision</span>
					<p class="bd-mv-text">
						A world where any ambitious business, wherever it is,
						can ship software <span class="bd-grad">as good as the
						giants</span>, and keep it growing for years.
					</p>
				</div>
			</div>
		</section>
	</div>

	<!-- ── Mantra — shock and awe, full-bleed electric band ──── -->
	<section class="bd-mantra bd-reveal" data-cursor="pulse">
		<span class="bd-mantra-glow" aria-hidden="true"></span>
		<span class="bd-mantra-kicker">The Swizel mantra</span>
		<h2 class="bd-mantra-words">
			<span>You imagine.</span>
			<span class="bd-mantra-build">We build.</span>
		</h2>
		<p class="bd-mantra-sub">
			Three words we have lived by since 2019. You bring the ambition,
			we turn it into something real, shipped and loved.
		</p>
	</section>

	<!-- ── By the numbers ──────────────────────────────────── -->
	<div class="bd-grid">
		<section class="bd-tile bd-tile--full bd-tile--inverse bd-reveal" id="bd-numbers" data-cursor="chart">
			<div class="bd-tile-copy">
				<h2 class="bd-h">The numbers behind the calm.</h2>
				<p class="bd-p">
					Seven years of shipping for ambitious businesses, measured the
					only way that matters.
				</p>
			</div>
			<ul class="bd-numbers">
				{
					numbers.map((n) => (
						<li class="bd-number">
							<strong
								data-count={n.to}
								data-suffix={n.suffix}
								data-decimals={n.decimals || 0}
							>
								0{n.suffix}
							</strong>
							<span>{n.label}</span>
						</li>
					))
				}
			</ul>
		</section>
	</div>

	<!-- ── What we do — services / expertise grid ──────────── -->
	<section class="bd-head bd-reveal" id="bd-services">
		<h2 class="bd-h bd-h--center">Everything under one roof.</h2>
		<p class="bd-p bd-p--center">
			One team across every discipline you need to launch and grow, no
			hiring, no hand-offs, no finger-pointing.
		</p>
	</section>
	<div class="bd-svc-grid bd-reveal">
		{
			services.map((s) => (
				<a href="/services" class="bd-svc-card" data-cursor="layers">
					<span class="bd-svc-ic">
						<Icon width={28} name={s.icon} />
					</span>
					<h3 class="bd-svc-title">{s.title}</h3>
					<p class="bd-svc-desc">{s.desc}</p>
					<span class="bd-svc-tag">{s.tag}</span>
					<span class="bd-svc-more">
						Learn more
						<Icon width={15} name="mdi:arrow-right" />
					</span>
				</a>
			))
		}
	</div>

	<!-- ── Values ──────────────────────────────────────────── -->
	<section class="bd-head bd-reveal" id="bd-values">
		<h2 class="bd-h bd-h--center">What we believe.</h2>
		<p class="bd-p bd-p--center">
			Four rules we have not broken in seven years, they are why clients
			stay.
		</p>
	</section>
	<div class="bd-mosaic bd-mosaic--svc">
		{
			values.map((v) => (
				<section
					class:list={['bd-tile', 'bd-tile--svc', 'bd-w6', 'bd-reveal', { 'bd-tile--loud': v.loud }]}
					data-cursor="shield"
				>
					<span class="bd-svc-ic">
						<Icon width={28} name={v.icon} />
					</span>
					<h3 class="bd-h bd-h--sm">{v.title}</h3>
					<p class="bd-p bd-svc-p">{v.desc}</p>
				</section>
			))
		}
	</div>

	<!-- ── Timeline — the road so far (animated aurora bg) ──── -->
	<section class="bd-timeline-wrap" id="bd-timeline">
		<span class="bd-tl-aurora" aria-hidden="true"></span>
		<span class="bd-tl-grid-lines" aria-hidden="true"></span>
		<div class="bd-head bd-reveal">
			<h2 class="bd-h bd-h--center">The road so far.</h2>
			<p class="bd-p bd-p--center">
				From a single line of code to software carrying businesses across
				the continent.
			</p>
		</div>
		<div class="bd-grid bd-grid--narrow">
			<ol class="bd-timeline">
				{
					milestones.map((m) => (
						<li class="bd-tl-item bd-reveal" data-cursor="branch">
							<span class="bd-tl-node" aria-hidden="true" />
							<div class="bd-tl-card">
								<span class="bd-tl-year">{m.year}</span>
								<h3 class="bd-tl-title">{m.title}</h3>
								<p class="bd-tl-desc">{m.desc}</p>
							</div>
						</li>
					))
				}
			</ol>
		</div>
	</section>

	<!-- ── Team — Apple-clean, real faces ──────────────────── -->
	<section class="bd-head bd-reveal" id="bd-team">
		<h2 class="bd-h bd-h--center">The people who build it.</h2>
		<p class="bd-p bd-p--center">
			Twenty-five specialists strong, here are just a few of the faces
			behind the work.
		</p>
	</section>
	<div class="bd-team-grid bd-reveal">
		{
			team.map((t) => (
				<button
					type="button"
					class="bd-member"
					data-cursor="repo"
					data-member
					data-name={t.name}
					data-role={t.role}
					data-bio={t.bio}
					data-linkedin={t.linkedin}
					data-exp={JSON.stringify(t.experience)}
					aria-label={`View ${t.name}'s profile`}
				>
					<div class="bd-member-photo">
						<img src={`/teammates/${t.name}.jpg`} alt={t.name} loading="lazy" />
						<span class="bd-member-veil" aria-hidden="true" />
						<span class="bd-member-view">
							View profile
							<Icon width={14} name="mdi:arrow-top-right" />
						</span>
					</div>
					<span class="bd-member-meta">
						<strong>{t.name}</strong>
						<em>{t.role}</em>
					</span>
				</button>
			))
		}
	</div>

	<!-- Team profile modal (filled on click) -->
	<div class="bd-modal" id="bd-member-modal" hidden>
		<div class="bd-modal-overlay" data-modal-close></div>
		<div class="bd-modal-card" role="dialog" aria-modal="true" aria-labelledby="bd-modal-name">
			<button type="button" class="bd-modal-x" data-modal-close aria-label="Close">
				<Icon width={20} name="mdi:close" />
			</button>
			<div class="bd-modal-body">
				<div class="bd-modal-side">
					<div class="bd-modal-photo">
						<img id="bd-modal-photo" src="" alt="" />
					</div>
					<h3 class="bd-modal-name" id="bd-modal-name"></h3>
					<p class="bd-modal-role" id="bd-modal-role"></p>
					<a class="bd-modal-linkedin" id="bd-modal-linkedin" href="#" target="_blank" rel="noopener noreferrer" hidden>
						<Icon width={18} name="linkedin" />
						Connect on LinkedIn
					</a>
				</div>
				<div class="bd-modal-main">
					<span class="bd-eyebrow">Bio</span>
					<p class="bd-modal-bio" id="bd-modal-bio"></p>
					<div id="bd-modal-exp-wrap" hidden>
						<span class="bd-eyebrow bd-modal-exp-h">Experience</span>
						<ul class="bd-modal-exp" id="bd-modal-exp"></ul>
					</div>
				</div>
			</div>
		</div>
	</div>
	<div class="bd-join bd-reveal">
		<div class="bd-join-copy">
			<strong>We're always hiring builders.</strong>
			<span>Designers, engineers and marketers, come build real products with us.</span>
		</div>
		<a href="/contact" class="bd-pill bd-join-btn">
			Join the team
			<Icon width={16} name="mdi:arrow-right" />
		</a>
	</div>

	<!-- ── Culture / behind the scenes ─────────────────────── -->
	<div class="bd-mosaic">
		<section class="bd-tile bd-tile--row bd-tile--row-rev bd-w7 bd-reveal" data-cursor="play">
			<div class="bd-tile-copy">
				<span class="bd-eyebrow">Inside Swizel</span>
				<h2 class="bd-h">A studio, not a factory.</h2>
				<p class="bd-p">
					We share one room, one standard and a lot of coffee. Designers
					sit with engineers, marketers sit with both, so the thing we
					ship is the thing we all believed in.
				</p>
				<a href="/contact" class="bd-link">
					Work with us
					<Icon width={15} name="mdi:chevron-right" />
				</a>
			</div>
			<div class="bd-media bd-media--tall">
				<span class="bd-media-sheen" aria-hidden="true"></span>
				<Icon width={34} name="mdi:play-circle-outline" />
				<span class="bd-media-label">Video placeholder</span>
				<span class="bd-media-sub">A day at the studio</span>
