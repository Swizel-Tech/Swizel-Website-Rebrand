	}
	@keyframes bd-bob {
		0%, 100% { transform: translateY(0); }
		50% { transform: translateY(6px); }
	}

	/* ── Layout grids ── */
	.bd-grid,
	.bd-mosaic {
		display: grid;
		gap: clamp(0.9rem, 2vw, 1.4rem);
		max-width: 88rem;
		margin: 0 auto clamp(0.9rem, 2vw, 1.4rem);
	}
	.bd-mosaic {
		grid-template-columns: repeat(12, minmax(0, 1fr));
	}
	.bd-grid--narrow,
	.bd-mosaic--svc {
		max-width: 72rem;
	}
	.bd-mosaic--svc {
		gap: clamp(1.25rem, 2.5vw, 2rem);
	}
	.bd-w7 { grid-column: span 7; }
	.bd-w6 { grid-column: span 6; }
	.bd-w5 { grid-column: span 5; }
	@media (max-width: 940px) {
		.bd-w7, .bd-w6, .bd-w5 { grid-column: span 12; }
	}
	.bd-tile--full { grid-column: 1 / -1; }

	/* ── Glass tiles ── */
	.bd-tile {
		position: relative;
		display: flex;
		flex-direction: column;
		gap: 1.4rem;
		text-align: center;
		padding: clamp(2rem, 4vw, 3rem) clamp(1.25rem, 3vw, 2.25rem)
			clamp(1.4rem, 3vw, 2rem);
		border-radius: 1.75rem;
		background: var(--bd-glass);
		border: 1px solid var(--bd-glass-border);
		box-shadow: var(--bd-shadow);
		backdrop-filter: blur(22px) saturate(130%);
		-webkit-backdrop-filter: blur(22px) saturate(130%);
		overflow: hidden;
		transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1),
			box-shadow 0.4s ease, border-color 0.4s ease;
	}
	.bd-tile::before {
		content: '';
		position: absolute;
		inset: 0 0 auto 0;
		height: 1px;
		background: linear-gradient(
			90deg,
			transparent 5%,
			rgba(255, 255, 255, 0.5) 50%,
			transparent 95%
		);
		opacity: 0.55;
		pointer-events: none;
	}
	.bd-tile:hover {
		transform: translateY(-5px);
		border-color: color-mix(in srgb, var(--bd-accent) 38%, rgba(255, 255, 255, 0.12));
		box-shadow: 0 40px 90px -36px color-mix(in srgb, var(--bd-accent) 32%, rgba(0, 0, 0, 0.85));
	}
	.bd-tile-copy {
		max-width: 40rem;
		margin: 0 auto;
	}
	.bd-tile--row {
		flex-direction: row;
		align-items: center;
		text-align: left;
		gap: clamp(1.25rem, 3vw, 2.5rem);
	}
	.bd-tile--row .bd-tile-copy { flex: 1 1 46%; margin: 0; }
	.bd-tile--row .bd-p { margin-inline: 0; }
	.bd-tile--row .bd-media { flex: 1 1 54%; }
	.bd-tile--row-rev { flex-direction: row-reverse; }
	@media (max-width: 720px) {
		.bd-tile--row,
		.bd-tile--row-rev {
			flex-direction: column;
			text-align: center;
		}
		.bd-tile--row .bd-p { margin-inline: auto; }
		.bd-tile--row .bd-eyebrow { text-align: center; }
		.bd-tile--row .bd-media { width: 100%; }
	}

	/* ── Media placeholders ── */
	.bd-media {
		position: relative;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 0.35rem;
		width: 100%;
		aspect-ratio: 4 / 3;
		max-height: 320px;
		border-radius: 1.25rem;
		border: 1.5px dashed color-mix(in srgb, var(--bd-ink) 18%, transparent);
		background:
			radial-gradient(420px 200px at 70% 10%, color-mix(in srgb, var(--bd-accent) 10%, transparent), transparent),
			color-mix(in srgb, var(--bd-ink) 3%, transparent);
		color: var(--bd-muted);
		overflow: hidden;
	}
	.bd-media--tall { aspect-ratio: 16 / 11; max-height: 360px; }
	.bd-media-label {
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0.1em;
		text-transform: uppercase;
	}
	.bd-media-sub {
		font-size: 0.78rem;
		color: color-mix(in srgb, var(--bd-muted) 70%, transparent);
	}
	.bd-media-sheen {
		position: absolute;
		inset: 0;
		background: linear-gradient(
			115deg,
			transparent 30%,
			color-mix(in srgb, var(--bd-ink) 5%, transparent) 48%,
			transparent 64%
		);
		transform: translateX(-100%);
		animation: bd-sheen 5.5s ease-in-out infinite;
		pointer-events: none;
	}
	@keyframes bd-sheen {
		0%, 55% { transform: translateX(-100%); }
		85%, 100% { transform: translateX(100%); }
	}

	/* ── Mission band ── */
	.bd-tile--mission {
		background:
			radial-gradient(720px 320px at 50% -20%, color-mix(in srgb, var(--bd-accent) 22%, transparent), transparent 70%),
			linear-gradient(160deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.015) 55%);
		padding-block: clamp(2.5rem, 5vw, 4rem);
	}
	.bd-about-mission {
		max-width: 30ch;
		margin: 0.4rem auto 0;
		font-size: clamp(1.5rem, 3.4vw, 2.5rem);
		font-weight: 600;
		line-height: 1.3;
		letter-spacing: -0.015em;
	}

	/* ── Inverse numbers tile ── */
	.bd-tile--inverse {
		background:
			radial-gradient(720px 320px at 50% -10%, color-mix(in srgb, var(--bd-accent) 34%, transparent), transparent 70%),
			linear-gradient(180deg, rgba(21, 26, 48, 0.9), rgba(5, 6, 13, 0.95));
		color: #f5f5f7;
		border-color: color-mix(in srgb, var(--bd-accent) 30%, rgba(255, 255, 255, 0.1));
	}
	.bd-tile--inverse .bd-p { color: rgba(245, 245, 247, 0.62); }
	.bd-numbers {
		display: grid;
		grid-template-columns: repeat(5, minmax(0, 1fr));
		gap: 1.25rem;
		list-style: none;
		margin: 0.5rem 0 0.75rem;
		padding: 0;
	}
	@media (max-width: 880px) {
		.bd-numbers { grid-template-columns: repeat(2, minmax(0, 1fr)); }
		.bd-number:last-child { grid-column: 1 / -1; }
	}
	.bd-number strong {
		display: block;
		font-size: clamp(2.4rem, 5vw, 3.6rem);
		font-weight: 700;
		letter-spacing: -0.03em;
		background: linear-gradient(135deg, #9bd8ff, var(--bd-accent));
		-webkit-background-clip: text;
		background-clip: text;
		-webkit-text-fill-color: transparent;
	}
	.bd-number span {
		font-size: 0.85rem;
		color: rgba(245, 245, 247, 0.6);
	}
	:global(html:not(.dark)) .bd-tile--inverse .bd-number span {
		color: rgba(245, 245, 247, 0.6);
	}

	/* ── Section heads ── */
	.bd-head {
		max-width: 56rem;
		margin: clamp(2.5rem, 6vw, 4rem) auto clamp(1.5rem, 3vw, 2rem);
		text-align: center;
	}

	/* ── Value tiles (svc) ── */
	.bd-tile--svc {
		text-align: left;
		align-items: flex-start;
		gap: 0;
		padding: clamp(2rem, 4vw, 3rem);
	}
	.bd-tile--svc .bd-h--sm { margin: 1.2rem 0 0.5rem; }
	.bd-svc-p { margin: 0; margin-inline: 0; max-width: 34rem; }
	.bd-svc-ic {
		display: grid;
		place-items: center;
		width: 58px;
		height: 58px;
		flex-shrink: 0;
		border-radius: 1.1rem;
		background: linear-gradient(
			135deg,
			color-mix(in srgb, var(--bd-accent) 26%, transparent),
			color-mix(in srgb, var(--bd-accent) 8%, transparent)
		);
		border: 1px solid color-mix(in srgb, var(--bd-accent) 35%, transparent);
		color: #9bd8ff;
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.2);
	}
	.bd-tile--loud {
		background:
			radial-gradient(480px 260px at 85% -10%, rgba(255, 255, 255, 0.28), transparent 60%),
			linear-gradient(135deg, #0ea5e9 0%, #2563eb 60%, #22d3ee 130%);
		border-color: rgba(255, 255, 255, 0.45);
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 0.45),
			0 40px 90px -30px rgba(14, 165, 233, 0.65);
	}
	.bd-tile--loud:hover {
		border-color: rgba(255, 255, 255, 0.7);
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 0.5),
			0 48px 110px -30px rgba(14, 165, 233, 0.85);
	}
	.bd-tile--loud .bd-h--sm { color: #ffffff; }
	.bd-tile--loud .bd-svc-p { color: rgba(255, 255, 255, 0.88); }
	.bd-tile--loud .bd-svc-ic {
		background: rgba(255, 255, 255, 0.18);
		border-color: rgba(255, 255, 255, 0.5);
		color: #ffffff;
	}
	@media (max-width: 720px) {
		.bd-tile--svc { text-align: center; align-items: center; }
		.bd-svc-p { margin-inline: auto; }
	}

	/* ── Timeline ── */
	/* timeline section — animated aurora backdrop, full-bleed */
	.bd-timeline-wrap {
		position: relative;
		margin: clamp(2rem, 5vw, 3.5rem) calc(-1 * clamp(1rem, 3vw, 2rem)) 0;
		padding: clamp(2.5rem, 6vw, 4rem) clamp(1rem, 3vw, 2rem) clamp(3rem, 6vw, 4.5rem);
		overflow: hidden;
		isolation: isolate;
	}
	.bd-tl-aurora {
		position: absolute;
		inset: -20% -10%;
		z-index: -2;
		pointer-events: none;
		background:
			radial-gradient(540px 380px at 18% 22%, color-mix(in srgb, var(--bd-accent) 30%, transparent), transparent 60%),
			radial-gradient(520px 420px at 82% 38%, rgba(124, 58, 237, 0.26), transparent 62%),
			radial-gradient(460px 400px at 60% 88%, color-mix(in srgb, var(--bd-accent) 22%, transparent), transparent 60%);
		filter: blur(34px);
		opacity: 0.55;
		animation: bd-aurora 18s ease-in-out infinite;
	}
	:global(html:not(.dark)) .bd-tl-aurora { opacity: 0.4; }
	@keyframes bd-aurora {
		0%, 100% { transform: translate3d(0, 0, 0) scale(1); }
		33% { transform: translate3d(3%, -2%, 0) scale(1.08); }
		66% { transform: translate3d(-3%, 2%, 0) scale(1.04); }
	}
	.bd-tl-grid-lines {
		position: absolute;
		inset: 0;
		z-index: -1;
		pointer-events: none;
		background-image:
			linear-gradient(color-mix(in srgb, var(--bd-ink) 6%, transparent) 1px, transparent 1px),
			linear-gradient(90deg, color-mix(in srgb, var(--bd-ink) 6%, transparent) 1px, transparent 1px);
		background-size: 46px 46px;
		-webkit-mask-image: radial-gradient(70% 60% at 50% 40%, #000, transparent 78%);
		mask-image: radial-gradient(70% 60% at 50% 40%, #000, transparent 78%);
		animation: bd-grid-pan 24s linear infinite;
	}
	@keyframes bd-grid-pan {
		to { background-position: 46px 46px; }
	}

	.bd-timeline {
		position: relative;
		list-style: none;
		margin: 0;
		padding: 0;
		width: 100%;
	}
	.bd-timeline::before {
		content: '';
		position: absolute;
		top: 0.5rem;
		bottom: 0.5rem;
		left: 50%;
		width: 2px;
		transform: translateX(-50%);
		background: linear-gradient(
			180deg,
			transparent,
			color-mix(in srgb, var(--bd-accent) 60%, transparent) 12%,
			color-mix(in srgb, var(--bd-accent) 60%, transparent) 88%,
			transparent
		);
	}
	/* a glowing pulse that travels down the line */
	.bd-timeline::after {
		content: '';
		position: absolute;
		left: 50%;
		top: 0;
		width: 6px;
		height: 22%;
		transform: translateX(-50%);
		border-radius: 9999px;
		background: linear-gradient(180deg, transparent, color-mix(in srgb, var(--bd-accent) 95%, #fff), transparent);
		filter: blur(2px);
		opacity: 0.9;
		animation: bd-tl-travel 4.5s ease-in-out infinite;
	}
	@keyframes bd-tl-travel {
		0% { top: -22%; opacity: 0; }
		15% { opacity: 1; }
		85% { opacity: 1; }
		100% { top: 100%; opacity: 0; }
	}
	.bd-tl-item {
		position: relative;
		width: 50%;
		padding: 0 clamp(1.5rem, 3vw, 2.75rem);
		margin-bottom: clamp(1.4rem, 3vw, 2rem);
		box-sizing: border-box;
	}
	/* alternate sides: odd items on the left, even on the right */
	.bd-tl-item:nth-child(odd) { margin-left: 0; text-align: right; }
	.bd-tl-item:nth-child(even) { margin-left: 50%; text-align: left; }
	.bd-tl-node {
		position: absolute;
		top: 1.6rem;
		width: 15px;
		height: 15px;
		border-radius: 9999px;
		background: var(--c, var(--bd-accent));
		border: 3px solid #070910;
		box-shadow: 0 0 0 4px color-mix(in srgb, var(--c, var(--bd-accent)) 25%, transparent);
		z-index: 1;
		animation: bd-node-pulse 2.8s ease-out infinite;
	}
	@keyframes bd-node-pulse {
		0% { box-shadow: 0 0 0 0 color-mix(in srgb, var(--c, var(--bd-accent)) 45%, transparent); }
		70% { box-shadow: 0 0 0 11px color-mix(in srgb, var(--c, var(--bd-accent)) 0%, transparent); }
		100% { box-shadow: 0 0 0 0 color-mix(in srgb, var(--c, var(--bd-accent)) 0%, transparent); }
	}
	/* each milestone gets its own colour */
	.bd-tl-item:nth-child(1) { --c: #22d3ee; }
	.bd-tl-item:nth-child(2) { --c: #3b82f6; }
	.bd-tl-item:nth-child(3) { --c: #8b5cf6; }
	.bd-tl-item:nth-child(4) { --c: #f59e0b; }
	.bd-tl-item:nth-child(5) { --c: #ec4899; }
	.bd-tl-item:nth-child(6) { --c: #10b981; }
	:global(html:not(.dark)) .bd-tl-node { border-color: #eef2f7; }
	.bd-tl-item:nth-child(odd) .bd-tl-node { right: -7px; }
	.bd-tl-item:nth-child(even) .bd-tl-node { left: -7px; }
	.bd-tl-card {
		position: relative;
		display: inline-block;
		text-align: left;
		padding: clamp(1.25rem, 2.5vw, 1.75rem);
		border-radius: 1.25rem;
		background:
			radial-gradient(340px 180px at 0% 0%, color-mix(in srgb, var(--c, var(--bd-accent)) 16%, transparent), transparent 72%),
			var(--bd-glass);
		border: 1px solid color-mix(in srgb, var(--c, var(--bd-accent)) 30%, var(--bd-glass-border));
		box-shadow: var(--bd-shadow);
		backdrop-filter: blur(18px) saturate(130%);
		-webkit-backdrop-filter: blur(18px) saturate(130%);
		transition: transform 0.35s ease, border-color 0.35s ease, box-shadow 0.35s ease;
	}
	.bd-tl-card:hover {
		transform: translateY(-4px);
		border-color: color-mix(in srgb, var(--c, var(--bd-accent)) 60%, var(--bd-glass-border));
		box-shadow: 0 36px 80px -36px color-mix(in srgb, var(--c, var(--bd-accent)) 38%, rgba(0,0,0,0.85));
	}
	.bd-tl-year {
		display: inline-block;
		font-size: clamp(1.6rem, 3.4vw, 2.4rem);
		font-weight: 700;
		letter-spacing: -0.02em;
		line-height: 1;
		background: linear-gradient(135deg, color-mix(in srgb, var(--c, var(--bd-accent)) 55%, #fff), var(--c, var(--bd-accent)));
		-webkit-background-clip: text;
		background-clip: text;
		-webkit-text-fill-color: transparent;
		margin-bottom: 0.5rem;
	}
	.bd-tl-title {
		font-size: 1.1rem;
		font-weight: 700;
		margin: 0 0 0.35rem;
	}
	.bd-tl-desc {
		font-size: 0.92rem;
		line-height: 1.55;
		color: var(--bd-muted);
		margin: 0;
		max-width: 30rem;
	}
	@media (max-width: 720px) {
		.bd-timeline::before { left: 9px; }
		.bd-tl-item,
		.bd-tl-item:nth-child(even),
		.bd-tl-item:nth-child(odd) {
			width: 100%;
			margin-left: 0;
			text-align: left;
			padding-left: 2.4rem;
			padding-right: 0;
		}
		.bd-tl-item:nth-child(even) .bd-tl-node,
		.bd-tl-item:nth-child(odd) .bd-tl-node { left: 2px; right: auto; }
		.bd-tl-card { display: block; }
	}

	/* ── Team grid (Apple-clean) ── */
	.bd-team-grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: clamp(0.9rem, 2vw, 1.4rem);
		max-width: 80rem;
		margin: 0 auto;
	}
	@media (max-width: 860px) {
		.bd-team-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
	}
	@media (max-width: 560px) {
		.bd-team-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 0.8rem; }
	}
	.bd-member {
		/* it's a <button> — reset and make it a card */
		font: inherit;
		color: inherit;
		text-align: left;
		padding: 0;
		cursor: pointer;
		width: 100%;
		display: block;
		margin: 0;
		border-radius: 1.4rem;
		overflow: hidden;
		background: var(--bd-glass);
		border: 1px solid var(--bd-glass-border);
		box-shadow: var(--bd-shadow);
		transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1),
			border-color 0.4s ease, box-shadow 0.4s ease;
	}
	.bd-member:hover {
		transform: translateY(-6px);
		border-color: color-mix(in srgb, var(--bd-accent) 45%, var(--bd-glass-border));
		box-shadow: 0 40px 90px -36px color-mix(in srgb, var(--bd-accent) 36%, rgba(0,0,0,0.85));
	}
	.bd-member-photo {
		position: relative;
		aspect-ratio: 3 / 3.4;
		overflow: hidden;
	}
	.bd-member-photo img {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center top;
		filter: grayscale(0.25) contrast(1.02);
		transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1), filter 0.5s ease;
	}
	.bd-member:hover .bd-member-photo img {
		transform: scale(1.06);
		filter: grayscale(0) contrast(1.05);
	}
	.bd-member-veil {
		position: absolute;
		inset: 0;
		background: linear-gradient(180deg, transparent 45%, rgba(5, 6, 14, 0.55));
		opacity: 0.8;
		transition: opacity 0.4s ease;
	}
	.bd-member:hover .bd-member-veil { opacity: 1; }
	.bd-member-meta {
		display: flex;
		flex-direction: column;
		gap: 0.1rem;
		padding: 0.85rem 1rem 1rem;
	}
	.bd-member-meta strong {
		font-size: 1.02rem;
		font-weight: 700;
		letter-spacing: -0.01em;
	}
	.bd-member-meta em {
		font-style: normal;
		font-size: 0.8rem;
		color: var(--bd-muted);
	}
	/* "View profile" affordance, revealed on hover/focus */
	.bd-member-view {
		position: absolute;
		left: 0.85rem;
		bottom: 0.85rem;
		display: inline-flex;
		align-items: center;
		gap: 0.3rem;
		padding: 0.4rem 0.7rem;
		border-radius: 9999px;
		font-size: 0.74rem;
		font-weight: 700;
		letter-spacing: 0.02em;
		color: #fff;
		background: color-mix(in srgb, var(--bd-accent) 80%, transparent);
		backdrop-filter: blur(6px);
		-webkit-backdrop-filter: blur(6px);
		opacity: 0;
		transform: translateY(8px);
		transition: opacity 0.3s ease, transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
		pointer-events: none;
	}
	.bd-member:hover .bd-member-view,
	.bd-member:focus-visible .bd-member-view { opacity: 1; transform: translateY(0); }

	/* ── Team profile modal ── */
	.bd-modal { position: fixed; inset: 0; z-index: 200; display: grid; place-items: center; padding: clamp(0.75rem, 3vw, 2rem); }
	.bd-modal[hidden] { display: none; }
	.bd-modal-overlay {
		position: absolute;
		inset: 0;
		background: rgba(3, 4, 10, 0.72);
		backdrop-filter: blur(6px);
		-webkit-backdrop-filter: blur(6px);
		opacity: 0;
		transition: opacity 0.3s ease;
	}
	.bd-modal.is-open .bd-modal-overlay { opacity: 1; }
	.bd-modal-card {
		position: relative;
		width: min(720px, 100%);
		max-height: 90vh;
		overflow-y: auto;
		border-radius: 1.5rem;
		padding: clamp(1.5rem, 4vw, 2.5rem);
		background:
			radial-gradient(620px 320px at 90% -10%, color-mix(in srgb, var(--bd-accent) 22%, transparent), transparent 65%),
			linear-gradient(165deg, #12152a, #06070e);
		border: 1px solid color-mix(in srgb, var(--bd-accent) 24%, rgba(255, 255, 255, 0.12));
		box-shadow: 0 50px 120px -40px rgba(0, 0, 0, 0.85);
		color: #f4f6fb;
		transform: translateY(14px) scale(0.97);
		opacity: 0;
		transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.3s ease;
	}
	.bd-modal.is-open .bd-modal-card { transform: translateY(0) scale(1); opacity: 1; }
	.bd-modal-x {
		position: sticky;
		top: 0.4rem;
		margin: -0.4rem -0.4rem -2.6rem auto;
		width: 40px;
		height: 40px;
		display: grid;
		place-items: center;
		border-radius: 9999px;
		border: 1px solid rgba(255, 255, 255, 0.2);
		background: rgba(18, 21, 42, 0.82);
		-webkit-backdrop-filter: blur(8px);
		backdrop-filter: blur(8px);
		color: #f4f6fb;
		cursor: pointer;
		z-index: 5;
		transition: background 0.25s ease, transform 0.25s ease;
	}
	.bd-modal-x:hover { background: rgba(255, 255, 255, 0.14); transform: rotate(90deg); }
	.bd-modal-body { display: grid; gap: clamp(1.25rem, 3vw, 2rem); }
	@media (min-width: 620px) { .bd-modal-body { grid-template-columns: 200px 1fr; align-items: start; } }
	.bd-modal-photo { border-radius: 1.1rem; overflow: hidden; aspect-ratio: 3 / 3.4; box-shadow: 0 20px 44px -18px rgba(0, 0, 0, 0.7); }
	.bd-modal-photo img { width: 100%; height: 100%; object-fit: cover; object-position: center top; }
	.bd-modal-name { font-size: clamp(1.4rem, 3vw, 1.8rem); font-weight: 700; letter-spacing: -0.02em; margin: 0.9rem 0 0.2rem; }
	.bd-modal-role { font-size: 0.9rem; color: var(--bd-accent); font-weight: 600; margin: 0; }
	.bd-modal-linkedin {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		margin-top: 1rem;
		padding: 0.5rem 0.9rem;
		border-radius: 9999px;
		font-size: 0.82rem;
		font-weight: 600;
		color: #fff;
		background: rgba(255, 255, 255, 0.07);
		border: 1px solid rgba(255, 255, 255, 0.14);
		transition: background 0.25s ease, border-color 0.25s ease;
	}
	.bd-modal-linkedin:hover { background: color-mix(in srgb, var(--bd-accent) 24%, transparent); border-color: var(--bd-accent); }
	.bd-modal-linkedin[hidden] { display: none; }
	.bd-modal-main .bd-eyebrow { margin-bottom: 0.5rem; }
	.bd-modal-bio { font-size: 0.96rem; line-height: 1.65; color: rgba(244, 246, 251, 0.78); margin: 0 0 1.4rem; }
	.bd-modal-exp-h { display: block; margin-bottom: 0.6rem; }
	.bd-modal-exp { list-style: none; padding: 0; margin: 0; display: grid; gap: 0.7rem; }
	/* these <li>/<strong>/<span> are created in JS, so they need :global to be styled */
	.bd-modal-exp :global(li) { padding-left: 0.9rem; border-left: 2px solid color-mix(in srgb, var(--bd-accent) 45%, transparent); }
	.bd-modal-exp :global(strong) { display: block; font-size: 0.92rem; font-weight: 700; margin-bottom: 0.1rem; }
	.bd-modal-exp :global(span) { display: block; font-size: 0.82rem; color: rgba(244, 246, 251, 0.6); }
	#bd-modal-exp-wrap[hidden] { display: none; }

	/* ── Rotating quotes ── */
	.bd-tile--quote {
		height: clamp(15rem, 26vw, 17rem);
		padding: 0;
		justify-content: center;
		width: min(100%, 72rem);
		margin: 0 auto;
		z-index: 2;
	}
	.bd-quote {
		max-width: 44rem;
		margin: 0 auto;
		opacity: 0;
		transform: translateY(14px);
		transition: opacity 0.6s ease, transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
		position: absolute;
		inset: 0;
		display: flex;
		flex-direction: column;
		justify-content: center;
		padding: clamp(1.5rem, 3vw, 2.25rem) clamp(1.25rem, 4vw, 4rem) 2.8rem;
		pointer-events: none;
	}
	.bd-quote.is-live { opacity: 1; transform: translateY(0); pointer-events: auto; }
	.bd-quote.is-leaving { opacity: 0; transform: translateY(-14px); }
	.bd-quote p {
		font-size: clamp(1.3rem, 2.6vw, 1.9rem);
		font-weight: 600;
		letter-spacing: -0.015em;
		line-height: 1.35;
		margin: 0 0 1.4rem;
	}
	.bd-quote footer {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.75rem;
	}
	.bd-quote img {
		width: 44px;
		height: 44px;
		border-radius: 9999px;
		object-fit: cover;
		border: 2px solid color-mix(in srgb, var(--bd-accent) 50%, transparent);
	}
	.bd-quote footer span {
		display: flex;
		flex-direction: column;
		text-align: left;
		line-height: 1.25;
	}
	.bd-quote footer strong { font-size: 0.92rem; }
	.bd-quote footer em {
		font-style: normal;
		font-size: 0.78rem;
		color: var(--bd-muted);
	}
	.bd-quote-dots {
		position: absolute;
		bottom: 1.4rem;
		left: 50%;
		transform: translateX(-50%);
		display: flex;
		gap: 0.45rem;
	}
	.bd-qdot {
		width: 7px;
		height: 7px;
		border-radius: 9999px;
		background: color-mix(in srgb, var(--bd-ink) 20%, transparent);
		transition: background 0.3s ease, transform 0.3s ease;
	}
	.bd-qdot.is-on { background: var(--bd-accent); transform: scale(1.25); }
	@media (max-width: 640px) {
		.bd-tile--quote { height: 21rem; }
		.bd-quote p { font-size: 1.12rem; }
	}

	/* ── Marquees ── */
	.bd-marquee {
		overflow: hidden;
		-webkit-mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
		mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
	}
	.bd-marquee-track {
		display: flex;
		align-items: center;
		width: max-content;
	}
	.bd-marquee-track--sectors { animation: bd-drift 38s linear infinite; }
	.bd-marquee-track--logos { animation: bd-drift 30s linear infinite; }
	.bd-marquee:hover .bd-marquee-track { animation-play-state: paused; }
	@keyframes bd-drift { to { transform: translateX(-50%); } }
	.bd-sectors {
		max-width: 88rem;
		margin: clamp(2.5rem, 6vw, 4rem) auto clamp(2rem, 5vw, 3.5rem);
		text-align: center;
	}
	.bd-sectors .bd-h { margin-bottom: 1.4rem; }
	.bd-sector {
		flex-shrink: 0;
		margin-right: clamp(1.6rem, 3vw, 2.8rem);
		font-size: clamp(1.2rem, 2.4vw, 1.7rem);
		font-weight: 700;
		letter-spacing: -0.01em;
		color: color-mix(in srgb, var(--bd-ink) 34%, transparent);
		transition: color 0.3s ease;
		cursor: default;
	}
	.bd-sector:hover { color: var(--bd-accent); }
	.bd-logos {
		max-width: 88rem;
		margin: clamp(2.5rem, 5vw, 3.5rem) auto 0;
		text-align: center;
	}
	.bd-logos-line {
		font-size: 0.8rem;
		font-weight: 700;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: color-mix(in srgb, var(--bd-ink) 38%, transparent);
		margin: 0 0 1.3rem;
	}
	.bd-logo {
		flex-shrink: 0;
		display: grid;
		place-items: center;
		margin-right: clamp(2rem, 4vw, 3.5rem);
	}
	.bd-logo img {
		height: 34px;
		width: auto;
		max-width: 140px;
		object-fit: contain;
		filter: grayscale(1) brightness(0) invert(1);
		opacity: 0.5;
		transition: opacity 0.3s ease, filter 0.3s ease, transform 0.3s ease;
	}
	.bd-logo:hover img { filter: none; opacity: 1; transform: scale(1.06); }

	.bd-work-all { text-align: center; margin: 1.6rem 0 0; }

	/* ── CTA ── */
	.bd-tile--cta {
		background:
			radial-gradient(820px 380px at 50% 130%, color-mix(in srgb, var(--bd-accent) 38%, transparent), transparent 72%),
			linear-gradient(180deg, rgba(18, 22, 42, 0.92), rgba(5, 6, 13, 0.96));
		color: #f5f5f7;
		border-color: color-mix(in srgb, var(--bd-accent) 26%, rgba(255, 255, 255, 0.1));
		padding-block: clamp(3rem, 6vw, 5rem);
	}
	.bd-display--cta { font-size: clamp(2.2rem, 5vw, 3.8rem); }
	.bd-tile--cta .bd-sub { color: rgba(245, 245, 247, 0.62); }
	.bd-call {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.2rem;
		margin-top: 1.6rem;
	}
	.bd-call-hint {
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: rgba(245, 245, 247, 0.5);
	}
	.bd-call-num {
		display: inline-flex;
		align-items: center;
		gap: 0.7rem;
		font-size: clamp(1.8rem, 4.5vw, 3.2rem);
		font-weight: 700;
		letter-spacing: -0.02em;
		background: linear-gradient(135deg, #ffffff, #9bd8ff 60%, var(--bd-accent));
		-webkit-background-clip: text;
		background-clip: text;
		-webkit-text-fill-color: transparent;
		transition: transform 0.3s ease, filter 0.3s ease;
	}
	.bd-call-num :global(svg) {
		color: var(--bd-accent);
		-webkit-text-fill-color: initial;
	}
	.bd-call:hover .bd-call-num {
		transform: scale(1.03);
		filter: drop-shadow(0 10px 30px color-mix(in srgb, var(--bd-accent) 55%, transparent));
	}

	/* ── Mission + Vision — deepest black for contrast ── */
	.bd-tile--void {
		background:
			radial-gradient(720px 360px at 50% -12%, color-mix(in srgb, var(--bd-accent) 18%, transparent), transparent 70%),
			linear-gradient(180deg, #000000 0%, #05060c 100%);
		color: #f4f6fb;
		border-color: rgba(255, 255, 255, 0.1);
		padding-block: clamp(2.6rem, 5vw, 4rem);
	}
	:global(html:not(.dark)) .bd-tile--void {
		color: #f4f6fb;
		border-color: rgba(255, 255, 255, 0.12);
	}
	.bd-mv {
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		gap: clamp(1.5rem, 4vw, 3.5rem);
		align-items: stretch;
		margin-top: 1.2rem;
		text-align: left;
	}
	.bd-mv-item { display: flex; flex-direction: column; gap: 0.7rem; }
	.bd-mv-tag {
		font-size: 0.75rem;
		font-weight: 800;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--bd-accent);
	}
	.bd-mv-text {
		font-size: clamp(1.15rem, 2.2vw, 1.6rem);
		font-weight: 600;
		line-height: 1.4;
		color: #eef1f8;
		margin: 0;
	}
	.bd-mv-divide { width: 1px; background: linear-gradient(180deg, transparent, rgba(255, 255, 255, 0.18), transparent); }
	@media (max-width: 720px) {
		.bd-mv { grid-template-columns: 1fr; text-align: center; }
		.bd-mv-item { align-items: center; }
		.bd-mv-divide { width: auto; height: 1px; background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.18), transparent); }
	}

	/* ── Mantra — shock & awe, full-bleed electric band ── */
	.bd-mantra {
		position: relative;
		margin: clamp(3rem, 7vw, 5rem) calc(-1 * clamp(1rem, 3vw, 2rem));
		padding: clamp(3.5rem, 9vw, 7rem) clamp(1.5rem, 5vw, 3rem);
		text-align: center;
		overflow: hidden;
		color: #fff;
		background:
			radial-gradient(900px 480px at 12% 8%, rgba(255, 255, 255, 0.22), transparent 58%),
			radial-gradient(700px 420px at 92% 100%, rgba(125, 240, 255, 0.18), transparent 60%),
			linear-gradient(118deg, #06e6ff 0%, #1f6bff 48%, #3a25ff 100%);
	}
	.bd-mantra-glow {
		position: absolute;
		top: -30%;
		left: 50%;
		width: 70%;
		height: 90%;
		transform: translateX(-50%);
		background: radial-gradient(closest-side, rgba(255, 255, 255, 0.28), transparent);
		filter: blur(24px);
		pointer-events: none;
		animation: bd-mantra-drift 9s ease-in-out infinite;
	}
	@keyframes bd-mantra-drift {
		0%, 100% { transform: translateX(-50%) translateY(0) scale(1); opacity: 0.9; }
		50% { transform: translateX(-42%) translateY(4%) scale(1.12); opacity: 1; }
	}
	.bd-mantra-kicker {
		position: relative;
		display: inline-block;
		font-size: 0.8rem;
		font-weight: 800;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.88);
		margin-bottom: 1.1rem;
	}
	.bd-mantra-words {
		position: relative;
		margin: 0;
		font-size: clamp(2.8rem, 9vw, 6.5rem);
		font-weight: 800;
		line-height: 0.98;
		letter-spacing: -0.025em;
	}
	.bd-mantra-words span { display: block; }
	.bd-mantra-build { text-shadow: 0 0 48px rgba(255, 255, 255, 0.45); }
	.bd-mantra-sub {
		position: relative;
		max-width: 34rem;
		margin: 1.5rem auto 0;
		font-size: clamp(1rem, 2vw, 1.2rem);
		line-height: 1.55;
		color: rgba(255, 255, 255, 0.92);
	}

	/* ── What we do — services grid ── */
	.bd-svc-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: clamp(0.9rem, 2vw, 1.4rem);
		max-width: 80rem;
		margin: 0 auto;
	}
	@media (max-width: 880px) { .bd-svc-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
	@media (max-width: 560px) { .bd-svc-grid { grid-template-columns: 1fr; } }
	.bd-svc-card {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		padding: clamp(1.6rem, 3vw, 2.2rem);
		border-radius: 1.4rem;
		background: var(--bd-glass);
		border: 1px solid var(--bd-glass-border);
		box-shadow: var(--bd-shadow);
		backdrop-filter: blur(18px) saturate(130%);
		-webkit-backdrop-filter: blur(18px) saturate(130%);
		transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1), border-color 0.35s ease, box-shadow 0.35s ease;
	}
	.bd-svc-card:hover {
		transform: translateY(-5px);
		border-color: color-mix(in srgb, var(--bd-accent) 42%, var(--bd-glass-border));
		box-shadow: 0 40px 90px -36px color-mix(in srgb, var(--bd-accent) 30%, rgba(0, 0, 0, 0.85));
	}
	.bd-svc-card .bd-svc-ic { margin-bottom: 1.1rem; }
	.bd-svc-title { font-size: 1.3rem; font-weight: 700; letter-spacing: -0.01em; margin: 0 0 0.5rem; }
	.bd-svc-desc { font-size: 0.95rem; line-height: 1.55; color: var(--bd-muted); margin: 0 0 1rem; }
	.bd-svc-tag {
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: color-mix(in srgb, var(--bd-ink) 50%, transparent);
		margin-bottom: 1rem;
	}
	.bd-svc-more {
		display: inline-flex;
		align-items: center;
		gap: 0.3rem;
		margin-top: auto;
		font-size: 0.9rem;
		font-weight: 700;
		color: var(--bd-accent);
		transition: gap 0.25s ease;
	}
	.bd-svc-card:hover .bd-svc-more { gap: 0.55rem; }

	/* ── Join the team banner ── */
	.bd-join {
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: clamp(1.5rem, 4vw, 3rem);
		max-width: 80rem;
		margin: clamp(2.5rem, 5vw, 4rem) auto clamp(3rem, 6vw, 5rem);
		padding: clamp(2.5rem, 5vw, 4rem) clamp(2rem, 5vw, 4rem);
		border-radius: 1.75rem;
		background:
			radial-gradient(560px 240px at 100% 0%, color-mix(in srgb, var(--bd-accent) 18%, transparent), transparent 70%),
			var(--bd-glass);
		border: 1px solid var(--bd-glass-border);
		box-shadow: var(--bd-shadow);
		backdrop-filter: blur(18px);
		-webkit-backdrop-filter: blur(18px);
	}
	.bd-join-copy { display: flex; flex-direction: column; gap: 0.6rem; text-align: left; max-width: 34rem; }
	.bd-join-copy strong { font-size: clamp(1.4rem, 2.8vw, 2rem); font-weight: 700; letter-spacing: -0.015em; line-height: 1.15; }
	.bd-join-copy span { font-size: clamp(0.98rem, 1.6vw, 1.1rem); line-height: 1.5; color: var(--bd-muted); }
	.bd-join-btn { flex-shrink: 0; padding: 0.95rem 1.9rem; font-size: 1rem; }
	@media (max-width: 640px) {
		.bd-join { flex-direction: column; align-items: flex-start; }
		.bd-join-btn { width: 100%; justify-content: center; }
	}

	/* ── Brevarium showcase ── */
	.bd-brev {
		flex-direction: row;
		align-items: center;
		gap: clamp(1.5rem, 4vw, 3.5rem);
		text-align: left;
		background:
			radial-gradient(700px 400px at 85% -10%, color-mix(in srgb, var(--bd-accent) 22%, transparent), transparent 70%),
			linear-gradient(160deg, rgba(18, 22, 42, 0.92), rgba(5, 6, 13, 0.96));
		color: #f4f6fb;
		border-color: color-mix(in srgb, var(--bd-accent) 26%, rgba(255, 255, 255, 0.1));
	}
	.bd-brev-cover {
		position: relative;
		flex: 0 0 auto;
		width: clamp(170px, 26%, 250px);
		border-radius: 0.9rem;
		overflow: hidden;
		box-shadow: 0 30px 60px -20px rgba(0, 0, 0, 0.75);
		transform: rotate(-3deg);
		transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
	}
	.bd-brev:hover .bd-brev-cover { transform: rotate(0deg) scale(1.03); }
	.bd-brev-cover img { display: block; width: 100%; height: auto; }
	.bd-brev-shine {
		position: absolute;
		inset: 0;
		background: linear-gradient(115deg, transparent 35%, rgba(255, 255, 255, 0.28) 50%, transparent 62%);
		transform: translateX(-120%);
		animation: bd-sheen 5s ease-in-out infinite 1s;
		pointer-events: none;
	}
	.bd-brev-copy { flex: 1 1 auto; }
	.bd-brev-copy .bd-p { color: rgba(244, 246, 251, 0.66); margin-inline: 0; }
	.bd-brev-actions { display: flex; align-items: center; gap: 1.2rem; flex-wrap: wrap; margin-top: 0.4rem; }
	.bd-brev-meta { font-size: 0.78rem; letter-spacing: 0.04em; color: rgba(244, 246, 251, 0.5); }
	.bd-brev-back { margin-top: 1.5rem; }
	.bd-brev-back-h { display: block; font-size: 0.72rem; font-weight: 800; letter-spacing: 0.14em; text-transform: uppercase; color: rgba(244, 246, 251, 0.5); margin-bottom: 0.7rem; }
	.bd-brev-eds { list-style: none; padding: 0; margin: 0; display: grid; gap: 0.5rem; }
	.bd-brev-ed {
		display: flex; align-items: center; gap: 0.7rem; padding: 0.6rem 0.85rem; border-radius: 0.8rem;
		background: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255, 255, 255, 0.1); color: #f4f6fb;
		transition: background 0.25s ease, border-color 0.25s ease, transform 0.25s ease;
	}
	.bd-brev-ed:hover { background: color-mix(in srgb, var(--bd-accent) 14%, transparent); border-color: color-mix(in srgb, var(--bd-accent) 40%, transparent); transform: translateY(-1px); }
	.bd-brev-ed > :global(svg):first-child { color: var(--bd-accent); flex-shrink: 0; }
	.bd-brev-ed-meta { display: flex; flex-direction: column; line-height: 1.2; flex: 1; min-width: 0; }
	.bd-brev-ed-meta strong { font-size: 0.9rem; font-weight: 600; }
	.bd-brev-ed-meta em { font-style: normal; font-size: 0.75rem; color: rgba(244, 246, 251, 0.5); }
	.bd-brev-ed-dl { color: rgba(244, 246, 251, 0.5); flex-shrink: 0; }
	.bd-brev-ed:hover .bd-brev-ed-dl { color: var(--bd-accent); }
	:global(html:not(.dark)) .bd-brev-back-h { color: color-mix(in srgb, var(--bd-ink) 45%, transparent); }
	:global(html:not(.dark)) .bd-brev-ed { background: color-mix(in srgb, var(--bd-ink) 4%, transparent); border-color: var(--bd-glass-border); color: var(--bd-ink); }
	:global(html:not(.dark)) .bd-brev-ed-meta em,
	:global(html:not(.dark)) .bd-brev-ed-dl { color: color-mix(in srgb, var(--bd-ink) 50%, transparent); }
	/* Light mode: don't punch a dark hole into the light page — go glassy,
	   keep the cover crisp with a soft frame. */
	:global(html:not(.dark)) .bd-brev {
		background:
			radial-gradient(700px 400px at 85% -10%, color-mix(in srgb, var(--bd-accent) 14%, transparent), transparent 70%),
			var(--bd-glass);
		color: var(--bd-ink);
		border-color: var(--bd-glass-border);
	}
	:global(html:not(.dark)) .bd-brev-copy .bd-p { color: var(--bd-muted); }
	:global(html:not(.dark)) .bd-brev-meta { color: color-mix(in srgb, var(--bd-ink) 45%, transparent); }
	:global(html:not(.dark)) .bd-brev-cover {
