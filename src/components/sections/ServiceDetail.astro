---
// A single service/discipline detail page — Boardroom world, themed in the
// discipline's own colour. Reuses initBoardroomBody reveals + the boardroom
// cursor (.bd-services). Self-contained .bd-* base styles.
import { Icon } from 'astro-icon';
import type { Discipline } from '../../data/disciplines';
import ServiceVisual from './ServiceVisual.astro';

interface Props {
	discipline: Discipline;
	others: Discipline[];
}
const { discipline: d, others } = Astro.props;
// The Design page leads with the work (show, don't tell); others keep the
// standard "selected work" lower down.
const isDesign = d.slug === 'design';

// Per-discipline layout so the pages differ in STRUCTURE, not just colour/copy:
// the hero is split (copy + signature visual), and we alternate which side the
// visual sits on and vary the shape of the "included" block.
type Lay = { incl: 2 | 3 | 'list'; heroRev?: boolean };
const layouts: Record<string, Lay> = {
	design: { incl: 2 },
	development: { incl: 3, heroRev: true },
	marketing: { incl: 2 },
	strategy: { incl: 'list', heroRev: true },
	maintenance: { incl: 2 },
	'ai-automation': { incl: 3, heroRev: true },
};
const L: Lay = layouts[d.slug] ?? { incl: 2 };
// kind of media slot for this discipline's "in action" placeholder
const mediaIsVideo = d.media?.kind === 'video';
---

<div class="bdbody bd-services bd-detail view-body view-body-boardroom" style={`--c:${d.color}`}>
	<!-- ── Hero — split: copy on one side, signature visual on the other ── -->
	<header class:list={['det-hero', 'bd-reveal', { 'det-hero--rev': L.heroRev }]} data-cursor={d.cursor}>
		<span class="det-aurora" aria-hidden="true"></span>
		<div class="det-hero-text">
			<a href="/services" class="det-back">
				<Icon width={15} name="mdi:arrow-left" />
				All services
			</a>
			<span class="det-kicker">
				<span class="det-kicker-ic"><Icon width={17} name={d.icon} /></span>
				{d.title}
			</span>
			<h1 class="bd-display det-h1">{d.tagline}</h1>
			<p class="bd-sub det-sub">{d.heroDesc}</p>
			<p class="det-clarify">{d.clarifier}</p>
			<div class="bd-links det-links">
				<a href="/contact" class="bd-pill">Start a project</a>
				<a href="#det-included" class="bd-link">
					What's included
					<Icon width={15} name="mdi:chevron-down" />
				</a>
			</div>
		</div>
		<div class="det-hero-visual">
			<ServiceVisual d={d} />
		</div>
	</header>

	{
		isDesign && (
			<section class="det-gallery bd-reveal" data-cursor={d.cursor}>
				<div class="det-gallery-grid">
					{d.projects.map((p, i) => (
						<a href="/portfolio" class:list={['det-gallery-card', { 'det-gallery-card--lead': i === 0 }]}>
							<img src={p.img} alt={p.name} loading={i === 0 ? 'eager' : 'lazy'} />
							<span class="det-gallery-veil" aria-hidden="true" />
							<span class="det-gallery-meta">
								<strong>{p.name}</strong>
								<em>{p.sector}</em>
							</span>
						</a>
					))}
				</div>
				<p class="det-gallery-cap">
					A few things we've designed.
					<a href="/portfolio" class="bd-link">See the full portfolio <Icon width={15} name="mdi:chevron-right" /></a>
				</p>
			</section>
		)
	}

	<!-- ── What it is ──────────────────────────────────────── -->
	<section class="det-about bd-reveal" data-cursor="vector">
		<span class="bd-eyebrow">What it is</span>
		<p class="det-overview-text">{d.overview}</p>
		<p class="det-outcome">
			<svg class="det-outcome-spark" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l1.9 5.6L19 9.5l-5.1 1.9L12 17l-1.9-5.6L5 9.5l5.1-1.9z" /></svg>
			{d.outcome}
		</p>
	</section>

	<!-- ── What's included ─────────────────────────────────── -->
	<section class="bd-head bd-reveal" id="det-included">
		<h2 class="bd-h bd-h--center">What's included.</h2>
		<p class="bd-p bd-p--center">Everything under {d.title}, handled by one team.</p>
	</section>
	{
		L.incl === 'list' ? (
			<ol class="det-list">
				{d.included.map((s, i) => (
					<li class="det-list-item bd-reveal" data-cursor="layers">
						<span class="det-list-n">{String(i + 1).padStart(2, '0')}</span>
						<div class="det-list-body">
							<h3 class="det-card-t">{s.title}</h3>
							<p class="det-card-d">{s.desc}</p>
							<ul class="det-card-items">
								{s.items.map((it) => (
									<li><Icon width={14} name="mdi:check" /> {it}</li>
								))}
							</ul>
						</div>
					</li>
				))}
			</ol>
		) : (
			<div class:list={['det-grid', L.incl === 3 ? 'det-grid--3' : 'det-grid--2']}>
				{d.included.map((s) => (
					<article class="det-card bd-reveal" data-cursor="layers">
						<h3 class="det-card-t">{s.title}</h3>
						<p class="det-card-d">{s.desc}</p>
						<ul class="det-card-items">
							{s.items.map((it) => (
								<li><Icon width={14} name="mdi:check" /> {it}</li>
							))}
						</ul>
					</article>
				))}
			</div>
		)
	}

	<!-- ── Ways we can work together ───────────────────────── -->
	<section class="bd-head bd-reveal">
		<h2 class="bd-h bd-h--center">However you want to work.</h2>
		<p class="bd-p bd-p--center">Hands-on or hands-off — we shape the engagement around you, and nothing ships until you're happy.</p>
	</section>
	<div class="det-ways">
		{
			d.ways.map((w) => (
				<article class="det-way bd-reveal" data-cursor="branch">
					<span class="det-way-ic"><Icon width={24} name={w.icon} /></span>
					<h3 class="det-way-t">{w.title}</h3>
					<p class="det-way-d">{w.desc}</p>
				</article>
			))
		}
	</div>

	<!-- ── How we approach it ──────────────────────────────── -->
	<section class="det-approach bd-reveal" data-cursor="chart">
		<span class="det-approach-aurora" aria-hidden="true"></span>
		<div class="bd-head">
			<h2 class="bd-h bd-h--center">How we approach it.</h2>
		</div>
		<ol class="det-steps">
			<span class="det-steps-line" aria-hidden="true"></span>
			{
				d.approach.map((p) => (
					<li class="det-step">
						<span class="det-step-n">{p.n}</span>
						<h3 class="det-step-t">{p.title}</h3>
						<p class="det-step-d">{p.desc}</p>
					</li>
				))
			}
		</ol>
	</section>

	<!-- ── Selected work (Design leads with its gallery instead) ── -->
	{
		!isDesign && (
			<section class="det-work-wrap bd-reveal" data-cursor="repo">
				<div class="bd-head">
					<h2 class="bd-h bd-h--center">{d.title} we've shipped.</h2>
					<p class="bd-p bd-p--center">A few of the products this discipline helped build.</p>
				</div>
				<div class="det-work">
					{d.projects.map((p) => (
						<a href="/portfolio" class="det-work-card">
							<img src={p.img} alt={p.name} loading="lazy" />
							<span class="det-work-veil" aria-hidden="true" />
							<span class="det-work-meta">
								<strong>{p.name}</strong>
								<em>{p.sector}</em>
							</span>
							<span class="det-work-go" aria-hidden="true"><Icon width={16} name="mdi:arrow-top-right" /></span>
						</a>
					))}
				</div>
				<p class="det-work-all">
					<a href="/portfolio" class="bd-link">See the full portfolio <Icon width={15} name="mdi:chevron-right" /></a>
				</p>
			</section>
		)
	}

	<!-- ── Media slot — paired with copy; drop in a real clip/shot later ── -->
	<section class="det-media-band bd-reveal" data-cursor={mediaIsVideo ? 'play' : 'repo'}>
		<div class="det-media-grid">
			<div class="det-media-copy">
				<span class="bd-eyebrow">{mediaIsVideo ? 'Watch' : 'See it'}</span>
				<h2 class="det-media-h">{d.media?.label ?? `${d.title} in action`}</h2>
				<p class="det-media-p">A closer look at how {d.title.toLowerCase()} actually comes together — real work, from first move to finished result.</p>
				<button type="button" class="det-media-cta">
					<span class="det-media-cta-ic"><Icon width={16} name={mediaIsVideo ? 'mdi:play' : 'mdi:image-outline'} /></span>
					{mediaIsVideo ? 'Play the clip' : 'View the shots'}
				</button>
			</div>
			<div class="det-media-slot">
				<span class="det-media-sheen" aria-hidden="true"></span>
				<span class="det-media-grid-lines" aria-hidden="true"></span>
				<span class="det-media-ic">
					<Icon width={mediaIsVideo ? 28 : 24} name={mediaIsVideo ? 'mdi:play' : 'mdi:image-outline'} />
				</span>
				<span class="det-media-label">{mediaIsVideo ? 'Video placeholder' : 'Image placeholder'}</span>
			</div>
		</div>
	</section>

	<!-- ── Review ──────────────────────────────────────────── -->
	<div class="bd-grid bd-grid--narrow">
		<section class="det-review bd-reveal" data-cursor="quote">
			<Icon class="det-quote-mark" width={40} name="mdi:format-quote-close" />
			<blockquote>{d.review.quote}</blockquote>
			<footer>
				<img src={d.review.img} alt="" loading="lazy" />
				<span>
					<strong>{d.review.name}</strong>
					<em>{d.review.role}</em>
				</span>
			</footer>
		</section>
	</div>

	<!-- ── FAQ ─────────────────────────────────────────────── -->
	{
		d.faqs && d.faqs.length > 0 && (
			<section class="det-faq bd-reveal" data-cursor="quote">
				<div class="bd-head">
					<h2 class="bd-h bd-h--center">Questions, answered.</h2>
					<p class="bd-p bd-p--center">The things people ask us most about {d.title.toLowerCase()}.</p>
				</div>
				<div class="det-faq-list">
					{d.faqs.map((f, i) => (
						<details class="det-faq-item" open={i === 0}>
							<summary>
								<span class="det-faq-n">{String(i + 1).padStart(2, '0')}</span>
									<span class="det-faq-q">{f.q}</span>
								<span class="det-faq-ic" aria-hidden="true">
									<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M12 5v14M5 12h14" /></svg>
								</span>
							</summary>
							<div class="det-faq-ans"><p>{f.a}</p></div>
						</details>
					))}
				</div>
			</section>
		)
	}

	<!-- ── CTA ─────────────────────────────────────────────── -->
	<section class="bd-grid">
		<div class="bd-tile bd-tile--full det-cta bd-reveal" data-cursor="phone">
			<h2 class="bd-display det-cta-h">Let's talk {d.title}.</h2>
			<p class="bd-sub">Tell us what you have in mind — you'll have a reply within one business day.</p>
			<div class="bd-links bd-links--center">
				<a href="/contact" class="bd-pill bd-pill--light">Start your project</a>
				<a href="tel:+2348100204570" class="bd-link bd-link--invert">
					<Icon width={16} name="mdi:phone" />
					+234 810 020 4570
				</a>
			</div>
		</div>
	</section>

	<!-- ── Explore other disciplines (even grid: + Overview) ── -->
	<section class="det-others bd-reveal" data-cursor="repo">
		<h2 class="bd-h bd-h--center">Explore the rest.</h2>
		<div class="det-others-grid">
			{
				others.map((o) => (
					<a href={`/services/${o.slug}`} class="det-other" style={`--c:${o.color}`} data-cursor={o.cursor}>
						<span class="det-other-ic"><Icon width={22} name={o.icon} /></span>
						<span class="det-other-meta">
							<strong>{o.title}</strong>
							<em>{o.tagline}</em>
						</span>
						<Icon width={18} name="mdi:arrow-right" />
					</a>
				))
			}
			<a href="/services" class="det-other det-other--over" style="--c:#28a6ec">
				<span class="det-other-ic">
					<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1" /><rect x="14" y="3" width="7" height="7" rx="1" /><rect x="14" y="14" width="7" height="7" rx="1" /><rect x="3" y="14" width="7" height="7" rx="1" /></svg>
				</span>
				<span class="det-other-meta">
					<strong>All services</strong>
					<em>The full overview</em>
				</span>
				<Icon width={18} name="mdi:arrow-right" />
			</a>
		</div>
	</section>
</div>

<style>
	/* ════ Boardroom base (self-contained), themed by --c ════ */
	.bdbody {
		--bd-accent: var(--c, #28a6ec);
		--bd-ink: #f4f6fb;
		--bd-muted: rgba(244, 246, 251, 0.62);
		--bd-glass: linear-gradient(160deg, rgba(255, 255, 255, 0.07), rgba(255, 255, 255, 0.02) 55%);
		--bd-glass-border: rgba(255, 255, 255, 0.1);
		--bd-shadow: 0 34px 80px -34px rgba(0, 0, 0, 0.8);
		font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
		position: relative;
		isolation: isolate;
		background:
			radial-gradient(1100px 540px at 78% -6%, color-mix(in srgb, var(--c) 16%, transparent), transparent 62%),
			radial-gradient(900px 520px at 8% 38%, rgba(58, 90, 200, 0.1), transparent 60%),
			linear-gradient(180deg, #070910 0%, #0a0d1c 45%, #05060d 100%);
		color: var(--bd-ink);
		padding: clamp(2.5rem, 6vw, 4.5rem) clamp(1rem, 3vw, 2rem) clamp(2.5rem, 5vw, 4rem);
	}
	:global(html:not(.dark)) .bdbody {
		--bd-ink: #14162a;
		--bd-muted: rgba(20, 22, 40, 0.64);
		--bd-glass: linear-gradient(160deg, rgba(255, 255, 255, 0.82), rgba(255, 255, 255, 0.55) 55%);
		--bd-glass-border: rgba(20, 22, 40, 0.1);
		--bd-shadow: 0 30px 70px -34px rgba(20, 22, 40, 0.25);
		background:
			radial-gradient(1100px 540px at 78% -6%, color-mix(in srgb, var(--c) 12%, transparent), transparent 62%),
			linear-gradient(180deg, #eef2f7 0%, #e7edf6 50%, #eef2f7 100%);
	}

	.bd-display { font-size: clamp(2.4rem, 5.5vw, 4.2rem); font-weight: 700; letter-spacing: -0.025em; line-height: 1.05; margin: 0 0 1.1rem; }
	.bd-sub { font-size: clamp(1.05rem, 2vw, 1.32rem); line-height: 1.5; color: var(--bd-muted); max-width: 40rem; margin: 0 auto 1rem; }
	.bd-h { font-size: clamp(1.7rem, 3.4vw, 2.5rem); font-weight: 700; letter-spacing: -0.02em; line-height: 1.1; margin: 0 0 0.7rem; }
	.bd-h--center { text-align: center; }
	.bd-p { font-size: 1.02rem; line-height: 1.6; color: var(--bd-muted); max-width: 34rem; margin: 0 auto 1.2rem; }
	.bd-p--center { margin-inline: auto; text-align: center; }
	.bd-eyebrow { display: block; font-size: 0.78rem; font-weight: 800; letter-spacing: 0.14em; text-transform: uppercase; color: var(--c); margin-bottom: 0.7rem; }
	.bd-head { max-width: 56rem; margin: clamp(2.5rem, 6vw, 4rem) auto clamp(1.5rem, 3vw, 2rem); text-align: center; }

	.bd-links { display: flex; align-items: center; justify-content: center; gap: 1.4rem; flex-wrap: wrap; margin-top: 1.4rem; }
	.bd-links--center { justify-content: center; }
	.bd-pill {
		display: inline-flex; align-items: center; padding: 0.78rem 1.5rem; border-radius: 9999px;
		background: linear-gradient(180deg, color-mix(in srgb, var(--c) 88%, #fff), var(--c) 45%, color-mix(in srgb, var(--c) 72%, #03244a));
		border: 1px solid color-mix(in srgb, var(--c) 60%, rgba(255, 255, 255, 0.4)); color: #fff; font-size: 0.95rem; font-weight: 600;
		text-shadow: 0 1px 2px rgba(0, 0, 0, 0.25); box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.35), 0 12px 28px -12px color-mix(in srgb, var(--c) 65%, transparent);
		transition: transform 0.25s ease, box-shadow 0.25s ease;
	}
	.bd-pill:hover { transform: translateY(-2px); box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.4), 0 18px 38px -12px color-mix(in srgb, var(--c) 80%, transparent); }
	.bd-pill--light { background: linear-gradient(180deg, #fff, #dfe6f2); border-color: rgba(255, 255, 255, 0.8); color: #0b0d18; text-shadow: none; }
	.bd-link { display: inline-flex; align-items: center; gap: 0.3rem; font-size: 0.98rem; font-weight: 600; color: var(--c); transition: gap 0.25s ease; }
	.bd-link:hover { gap: 0.5rem; }
	.bd-link--invert { color: color-mix(in srgb, var(--c) 60%, #fff); }

	.bd-grid { display: grid; gap: clamp(0.9rem, 2vw, 1.4rem); max-width: 88rem; margin: 0 auto clamp(0.9rem, 2vw, 1.4rem); }
	.bd-grid--narrow { max-width: 60rem; }
	.bd-tile { position: relative; border-radius: 1.75rem; background: var(--bd-glass); border: 1px solid var(--bd-glass-border); box-shadow: var(--bd-shadow); backdrop-filter: blur(22px) saturate(130%); -webkit-backdrop-filter: blur(22px) saturate(130%); overflow: hidden; padding: clamp(2rem, 4vw, 3rem) clamp(1.5rem, 3vw, 2.5rem); }
	.bd-tile--full { grid-column: 1 / -1; }

	/* ── Hero — split: copy + signature visual side by side ── */
	.det-hero { position: relative; overflow: hidden; max-width: 84rem; margin: 0 auto clamp(2rem, 5vw, 3.5rem); padding: clamp(1rem, 3vw, 2.5rem) clamp(0.5rem, 2vw, 1.5rem) clamp(2rem, 4vw, 3rem); display: grid; gap: clamp(2rem, 5vw, 4rem); align-items: center; }
	@media (min-width: 940px) { .det-hero { grid-template-columns: 1.02fr 0.98fr; } .det-hero--rev .det-hero-text { order: 2; } }
	.det-aurora { position: absolute; inset: -25% -10% auto; height: 120%; z-index: -1; pointer-events: none; background: radial-gradient(520px 380px at 30% 14%, color-mix(in srgb, var(--c) 34%, transparent), transparent 62%); filter: blur(54px); opacity: 0.65; animation: det-float 16s ease-in-out infinite; }
	.det-hero--rev .det-aurora { background: radial-gradient(520px 380px at 70% 14%, color-mix(in srgb, var(--c) 34%, transparent), transparent 62%); }
	:global(html:not(.dark)) .det-aurora { opacity: 0.4; }
	@keyframes det-float { 0%,100%{ transform: translateY(0) scale(1); } 50%{ transform: translateY(-3%) scale(1.07); } }
	.det-hero-text { text-align: left; }
	.det-back { display: flex; width: fit-content; align-items: center; gap: 0.35rem; font-size: 0.82rem; font-weight: 600; color: var(--bd-muted); margin-bottom: 1.4rem; padding: 0.4rem 0.85rem 0.4rem 0.7rem; border-radius: 9999px; background: var(--bd-glass); border: 1px solid var(--bd-glass-border); transition: gap 0.25s ease, color 0.25s ease, border-color 0.25s ease; }
	.det-back:hover { border-color: color-mix(in srgb, var(--c) 40%, var(--bd-glass-border)); }
	.det-back:hover { gap: 0.55rem; color: var(--c); }
	.det-kicker { display: inline-flex; align-items: center; gap: 0.55rem; font-size: 0.82rem; font-weight: 800; letter-spacing: 0.16em; text-transform: uppercase; color: var(--c); margin-bottom: 1rem; }
	.det-kicker-ic { display: grid; place-items: center; width: 34px; height: 34px; border-radius: 0.7rem; color: var(--c); background: linear-gradient(135deg, color-mix(in srgb, var(--c) 28%, transparent), color-mix(in srgb, var(--c) 8%, transparent)); border: 1px solid color-mix(in srgb, var(--c) 38%, transparent); }
	.det-h1 { max-width: 14ch; margin: 0 0 1.1rem; }
	.det-sub { margin-inline: 0; }
	.det-clarify { font-size: 0.92rem; font-weight: 600; letter-spacing: 0.01em; color: color-mix(in srgb, var(--c) 78%, var(--bd-ink)); margin: 0 0 0.4rem; max-width: 34rem; }
	.det-links { justify-content: flex-start; }
	.det-hero-visual { width: 100%; }

	/* ── What it is (centered editorial lead, no template bar) ── */
	.det-about { position: relative; max-width: 50rem; margin: clamp(2.5rem, 5vw, 3.5rem) auto clamp(1.5rem, 2vw, 2rem); text-align: center; }
	.det-overview-text { font-size: clamp(1.15rem, 2.4vw, 1.55rem); font-weight: 500; line-height: 1.5; letter-spacing: -0.01em; margin: 0.6rem 0 1.5rem; }
	.det-outcome { display: inline-flex; align-items: center; gap: 0.5rem; font-size: 0.92rem; font-weight: 700; color: var(--c); margin: 0; padding: 0.5rem 1.1rem; border-radius: 9999px; background: color-mix(in srgb, var(--c) 12%, transparent); border: 1px solid color-mix(in srgb, var(--c) 30%, transparent); }
	.det-outcome :global(svg) { color: var(--c); }

	/* ── Media slot — copy paired with the placeholder (never a lone empty box) ── */
	.det-media-band { max-width: 76rem; margin: clamp(2.5rem, 6vw, 4rem) auto; }
	.det-media-grid { display: grid; gap: clamp(1.5rem, 3vw, 2.5rem); align-items: center; }
	@media (min-width: 820px) { .det-media-grid { grid-template-columns: 0.82fr 1.18fr; } }
	.det-media-copy { text-align: left; }
	.det-media-h { font-size: clamp(1.5rem, 3vw, 2.1rem); font-weight: 700; letter-spacing: -0.02em; line-height: 1.12; margin: 0.2rem 0 0.7rem; }
