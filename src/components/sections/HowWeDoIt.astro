---
import AccentHeader from '../HTML/AccentHeader.astro';
import Heading from '../HTML/Heading.astro';
import Section from '../HTML/Section.astro';

interface Props {
	class?: string;
	hideButton?: true;
}

const { class: className = '', hideButton } = Astro.props;

const steps = [
	{
		title: 'Discover, research, define',
		desc: 'We dig into your goals, users and market to define exactly what to build — and why.',
	},
	{
		title: 'Design, build, test',
		desc: 'We design, develop and rigorously test your product so we can launch your MVP fast.',
	},
	{
		title: 'Market, manage, scale',
		desc: 'We take your product to market, then manage and scale it as your business grows.',
	},
] as const;
---

<Section>
	<div
		class:list={[
			'grid gap-12 lg:gap-16 md:grid-cols-2 py-16 my-8 items-start',
			className,
		]}
	>
		<div>
			<div class="space-y-6 md:max-w-lg md:sticky md:top-28">
				<AccentHeader>How we work</AccentHeader>
				<Heading type="h3">Bring your projects to life</Heading>
				<p class="text-darker/70 leading-relaxed">
					Our team works closely with you to understand your needs and
					provide cost-effective, innovative solutions that help you
					achieve your goals. We'll launch your MVP as quickly as
					possible, then test and refine it to take your business to the
					next level.
				</p>
				{
					!hideButton && (
						<div>
							<a
								href="/about"
								class="inline-flex items-center gap-2 text-swizelGreen uppercase text-sm font-bold tracking-wide px-6 py-3 rounded-full border border-swizelGreen/40 transition hover:border-swizelGreen hover:bg-swizelGreen hover:text-white"
							>
								Read more
							</a>
						</div>
					)
				}
			</div>
		</div>
		<ol class="about--list grid gap-5">
			{
				steps.map((step, i) => (
					<li class="step--card hover-lift">
						<span class="step--num">{`0${i + 1}`}</span>
						<div class="step--body">
							<h4 class="text-xl font-bold text-darker uppercase tracking-wide leading-tight">
								{step.title}
							</h4>
							<p class="text-darker/60 mt-2 leading-relaxed">
								{step.desc}
							</p>
						</div>
					</li>
				))
			}
		</ol>
	</div>
</Section>

<style>
	.step--card {
		display: grid;
		grid-template-columns: auto 1fr;
		gap: 1.25rem;
		align-items: start;
		padding: 1.75rem;
		background: #fff;
		border: 1px solid #f0e7e1;
		border-radius: 1.25rem;
		box-shadow: 0 10px 30px -20px rgba(40, 41, 62, 0.18);
		transition: box-shadow 0.4s ease, border-color 0.4s ease,
			transform 0.4s ease;
	}
	.step--card:hover {
		border-color: #d8f5ee;
		box-shadow: 0 22px 46px -22px rgba(40, 41, 62, 0.28);
	}
	.step--num {
		font-size: 2.75rem;
		font-weight: 800;
		line-height: 1;
		background: linear-gradient(135deg, #18debe, #28a6ec);
		-webkit-background-clip: text;
		background-clip: text;
		-webkit-text-fill-color: transparent;
		color: transparent;
	}
</style>
