---
import { Icon } from 'astro-icon';
import CustomButton from '../CustomButton.astro';
import Section from '../HTML/Section.astro';
import RotatingHeadline from '../RotatingHeadline.astro';
import TeamChip from '../TeamChip.astro';

const stats = [
	{ to: 3, suffix: ' mo', label: 'Free bootcamp' },
	{ to: 65, suffix: '+', label: 'Real products to learn from' },
	{ to: 7, suffix: '+', label: 'Years mentoring' },
];

const levels = [
	{ name: 'Learn', pct: 20 },
	{ name: 'Build', pct: 50 },
	{ name: 'Ship', pct: 80 },
	{ name: 'Hired', pct: 100 },
];

const badges = [
	{ name: 'Web', pct: 18 },
	{ name: 'Mobile', pct: 42 },
	{ name: 'Design', pct: 66 },
	{ name: 'Marketing', pct: 88 },
];

const builds = [
	{ name: 'Food delivery', tag: 'like OGGMA' },
	{ name: 'Sports platform', tag: 'like Betslipswitch' },
	{ name: 'Online store', tag: 'like Brixmarket' },
	{ name: 'Brand campaign', tag: 'like Purple Panda' },
];
---

<Section
	sectionClass="hero--stage hero-view hero-campus campus--stage relative overflow-hidden"
	divClass="relative z-10 pb-16 sm:pb-24"
>
	<div class="campus--bg" aria-hidden="true">
		<span class="campus--glow"></span>
		{Array.from({ length: 10 }).map((_, i) => <span class="campus--dot" style={`--i:${i}`} />)}
	</div>

	<div class="campus--layout">
		<div class="campus--copy">
			<span class="campus--eyebrow">
				<Icon width={15} name="mdi:school-outline" />
				Free bootcamp · learn, build, get hired
			</span>

			<RotatingHeadline class="campus--head" />

			<p class="campus--sub">
				Start from zero and level up with the same team that ships real
				products. Learn by building things people actually use.
			</p>

			<div class="campus--cta">
				<CustomButton
					variant="accent"
					elementType="a"
					href="/bootcamp"
					class="flex items-center justify-center gap-2"
				>
					Join the bootcamp
					<Icon width={18} name="mdi:arrow-right" />
				</CustomButton>
				<button class="campus--tour" type="button" data-tour-start="campus">
					<Icon width={16} name="mdi:compass-outline" />
					Take the 20s tour
				</button>
			</div>

			<ul class="campus--stats" data-tour="stats">
				{
					stats.map((s) => (
						<li class="campus--stat">
							<span class="campus--statnum" data-count-to={s.to} data-suffix={s.suffix}>
								{s.to}
								{s.suffix}
							</span>
							<span class="campus--statlabel">{s.label}</span>
						</li>
					))
				}
			</ul>

			<TeamChip kicker="// the mentors in your corner" label="Meet your mentors" />
		</div>

		<!-- Gamified journey widget -->
		<div class="campus--widget" id="campus-widget" data-tour="game">
			<div class="cw--confetti" aria-hidden="true">
				{Array.from({ length: 14 }).map((_, i) => <span style={`--i:${i}`} />)}
			</div>

			<div class="cw--head">
				<div>
					<span class="cw--title">Your tech journey</span>
					<span class="cw--subt">from newbie to hired</span>
				</div>
				<button class="cw--start" type="button" data-cw-start>
					<Icon width={14} name="mdi:play" />
					<span class="cw--start-txt">Start</span>
				</button>
			</div>

			<div class="cw--xprow">
				<span class="cw--level" id="cw-level">Level 0 · Newbie</span>
				<span class="cw--xp" id="cw-xp">0 XP</span>
			</div>

			<div class="cw--track" data-tour="track">
				<div class="cw--bar"><span class="cw--fill" id="cw-fill"></span></div>
				<span class="cw--avatar" id="cw-avatar"><Icon width={16} name="mdi:rocket-launch" /></span>
				<ol class="cw--levels">
					{
						levels.map((l) => (
							<li class="cw--node" data-pct={l.pct}>
								<span class="cw--nodedot" />
								<span class="cw--nodename">{l.name}</span>
							</li>
						))
					}
				</ol>
			</div>

			<div class="cw--badges" data-tour="badges">
				{
					badges.map((bdg) => (
						<span class="cw--badge" data-pct={bdg.pct}>
							<Icon width={13} name="mdi:check-decagram" />
							{bdg.name}
						</span>
					))
				}
			</div>

			<div class="cw--builds" data-tour="builds">
				<span class="cw--builds-label">You will build, across sectors</span>
				<div class="cw--buildcards">
					{
						builds.map((bld, i) => (
							<span class="cw--buildcard" style={`--i:${i}`}>
								<span class="cw--build-name">{bld.name}</span>
								<span class="cw--build-tag">{bld.tag}</span>
							</span>
						))
					}
				</div>
			</div>
		</div>
	</div>
</Section>

<style>
	.campus--stage {
		background:
			radial-gradient(900px 520px at 78% -10%, rgba(245, 158, 11, 0.22), transparent 60%),
			linear-gradient(180deg, #1d1606 0%, #16110a 55%, #100c08 100%);
		color: #fdf3e3;
		isolation: isolate;
	}
	.campus--bg {
		position: absolute; top: 0; left: 50%; transform: translateX(-50%);
		width: 100vw; height: 100%; z-index: 0; overflow: hidden; pointer-events: none;
		background:
			radial-gradient(900px 520px at 78% -10%, rgba(245, 158, 11, 0.22), transparent 60%),
			linear-gradient(180deg, #1d1606 0%, #16110a 55%, #100c08 100%);
	}
	.campus--glow {
		position: absolute; top: -18%; left: 50%; transform: translateX(-50%);
		width: 70vw; max-width: 820px; height: 460px;
		background: radial-gradient(ellipse at center, rgba(245, 158, 11, 0.26), transparent 70%);
		filter: blur(50px);
	}
	.campus--dot {
		position: absolute;
		top: -8%;
		left: calc((var(--i) + 1) * 9%);
		width: 8px; height: 8px; border-radius: 2px;
		background: hsl(calc(20 + var(--i) * 28) 90% 60%);
		opacity: 0.7;
		animation: cdrop 11s linear infinite;
		animation-delay: calc(var(--i) * -1.1s);
	}
	@keyframes cdrop {
		0% { transform: translateY(0) rotate(0); opacity: 0; }
		12% { opacity: 0.8; }
		100% { transform: translateY(112vh) rotate(360deg); opacity: 0; }
	}

	.campus--layout { position: relative; z-index: 1; display: grid; gap: 2.5rem; align-items: center; min-height: calc(100vh - 90px); padding-top: 2rem; }
	@media (min-width: 1024px) { .campus--layout { grid-template-columns: 0.92fr 1.08fr; gap: 3rem; } }

	.campus--eyebrow { display: inline-flex; align-items: center; gap: 0.5rem; font-size: 0.78rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: #fcd34d; margin-bottom: 1.2rem; }
	.campus--head { font-size: clamp(2.6rem, 6vw, 5.2rem); margin-bottom: 1.4rem; }
	.campus--sub { max-width: 30rem; color: rgba(253, 243, 227, 0.7); font-size: 1.08rem; line-height: 1.65; margin-bottom: 1.8rem; }
	.campus--cta { display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; margin-bottom: 2rem; }
	.campus--tour { display: inline-flex; align-items: center; gap: 0.5rem; font-size: 0.82rem; font-weight: 600; color: #fdf3e3; padding: 0.85rem 1.2rem; border-radius: 9999px; border: 1px dashed rgba(252, 211, 77, 0.5); transition: 0.25s ease; }
	.campus--tour:hover { border-color: #f59e0b; color: #fcd34d; background: rgba(245, 158, 11, 0.1); }
	.campus--stats { display: flex; gap: clamp(1.5rem, 4vw, 3rem); flex-wrap: wrap; padding-top: 1.5rem; border-top: 1px solid rgba(255, 255, 255, 0.08); }
	.campus--statnum { font-family: 'Bebas Neue', sans-serif; font-size: clamp(2.2rem, 4vw, 3rem); line-height: 1; background: linear-gradient(135deg, #fde68a, #f59e0b); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent; color: transparent; }
	.campus--statlabel { display: block; font-size: 0.74rem; text-transform: uppercase; letter-spacing: 0.08em; color: rgba(253, 243, 227, 0.5); margin-top: 0.3rem; max-width: 9rem; }

	/* ===== gamified widget ===== */
	.campus--widget { position: relative; border-radius: 1.25rem; padding: 1.4rem; background: rgba(29, 22, 6, 0.6); border: 1px solid rgba(245, 158, 11, 0.25); backdrop-filter: blur(14px); box-shadow: 0 40px 90px -40px rgba(0, 0, 0, 0.85); overflow: hidden; }
	.cw--head { display: flex; align-items: center; justify-content: space-between; gap: 1rem; margin-bottom: 1rem; }
	.cw--title { font-size: 1.15rem; font-weight: 800; color: #fff; }
	.cw--subt { display: block; font-size: 0.8rem; color: rgba(253, 243, 227, 0.55); }
	.cw--start { display: inline-flex; align-items: center; gap: 0.45rem; font-size: 0.8rem; font-weight: 800; color: #2a1c02; background: linear-gradient(95deg, #fde68a, #f59e0b); padding: 0.6rem 1.1rem; border-radius: 9999px; cursor: pointer; transition: transform 0.2s ease, filter 0.2s ease; }
	.cw--start:hover { transform: translateY(-1px); filter: brightness(1.05); }

	.cw--xprow { display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.6rem; }
	.cw--level { font-size: 0.82rem; font-weight: 700; color: #fcd34d; }
	.cw--xp { font-family: 'Bebas Neue', sans-serif; font-size: 1.4rem; color: #fff; letter-spacing: 1px; }

	.cw--track { position: relative; margin-bottom: 1.6rem; }
	.cw--bar { height: 12px; border-radius: 9999px; background: rgba(255, 255, 255, 0.08); overflow: hidden; }
	.cw--fill { display: block; height: 100%; width: 0%; border-radius: 9999px; background: linear-gradient(90deg, #fde68a, #f59e0b, #fb7185); }
	.cw--avatar { position: absolute; top: -8px; left: 0%; transform: translateX(-50%); width: 30px; height: 30px; display: grid; place-items: center; border-radius: 9999px; background: #f59e0b; color: #2a1c02; box-shadow: 0 6px 16px -4px rgba(245, 158, 11, 0.7); }
	.cw--levels { display: flex; justify-content: space-between; margin-top: 0.9rem; }
	.cw--node { display: flex; flex-direction: column; align-items: center; gap: 0.3rem; }
	.cw--nodedot { width: 11px; height: 11px; border-radius: 9999px; background: rgba(255, 255, 255, 0.15); transition: background 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease; }
	.cw--node.is-on .cw--nodedot { background: #f59e0b; transform: scale(1.3); box-shadow: 0 0 0 4px rgba(245, 158, 11, 0.25); }
	.cw--nodename { font-size: 0.72rem; color: rgba(253, 243, 227, 0.5); }
	.cw--node.is-on .cw--nodename { color: #fcd34d; font-weight: 700; }

	.cw--badges { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1.4rem; }
	.cw--badge { display: inline-flex; align-items: center; gap: 0.3rem; font-size: 0.76rem; font-weight: 600; padding: 0.35rem 0.7rem; border-radius: 9999px; border: 1px solid rgba(255, 255, 255, 0.12); background: rgba(255, 255, 255, 0.03); color: rgba(253, 243, 227, 0.55); opacity: 0.45; transform: scale(0.92); transition: all 0.3s ease; }
	.cw--badge :global(svg) { opacity: 0.5; }
	.cw--badge.is-on { opacity: 1; transform: scale(1); border-color: rgba(245, 158, 11, 0.5); background: rgba(245, 158, 11, 0.12); color: #fcd34d; }

	.cw--builds { padding-top: 1rem; border-top: 1px dashed rgba(255, 255, 255, 0.1); }
	.cw--builds-label { display: block; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.08em; color: rgba(253, 243, 227, 0.5); margin-bottom: 0.7rem; }
	.cw--buildcards { display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.55rem; }
	.cw--buildcard { display: flex; flex-direction: column; padding: 0.6rem 0.75rem; border-radius: 0.7rem; border: 1px solid rgba(245, 158, 11, 0.22); background: rgba(245, 158, 11, 0.07); opacity: 0; transform: translateY(8px); }
	.campus--widget.is-complete .cw--buildcard { animation: cwcard 0.45s ease forwards; animation-delay: calc(var(--i) * 0.1s); }
	@keyframes cwcard { to { opacity: 1; transform: translateY(0); } }
	.cw--build-name { font-size: 0.84rem; font-weight: 700; color: #fff; }
	.cw--build-tag { font-size: 0.7rem; color: #fcd34d; }

	/* confetti */
	.cw--confetti { position: absolute; inset: 0; pointer-events: none; }
	.cw--confetti span { position: absolute; top: 30%; left: calc(8% + var(--i) * 6.5%); width: 8px; height: 8px; border-radius: 2px; background: hsl(calc(20 + var(--i) * 26) 90% 60%); opacity: 0; }
	.campus--widget.is-complete .cw--confetti span { animation: cwfetti 1.1s ease-out forwards; animation-delay: calc(var(--i) * 0.03s); }
	@keyframes cwfetti {
		0% { opacity: 1; transform: translateY(0) rotate(0); }
		100% { opacity: 0; transform: translateY(220px) rotate(540deg); }
	}

	@media (max-width: 1023px) { .campus--layout { min-height: auto; } }
	@media (max-width: 768px) {
		.campus--layout { gap: 1.75rem; padding-top: 0.5rem; }
		.campus--head { font-size: clamp(2.2rem, 9.5vw, 3.2rem); }
		.campus--sub { font-size: 1rem; margin-bottom: 1.4rem; }
	}
	@media (prefers-reduced-motion: reduce) { .campus--dot { animation: none !important; } }
</style>
