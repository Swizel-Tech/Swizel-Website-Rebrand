---
// Services hub — the Boardroom world. An "adventure" into everything Swizel
// does: each discipline is a door into its own world (per-service pages come
// next). Reuses the boardroom engine (initBoardroomBody → reveals/counters)
// and the themed cursor; locked to boardroom blue. Self-contained .bd-* styles.
import { Icon } from 'astro-icon/components';
import { disciplines } from '../../data/disciplines';
// Each discipline links to its own detail page (/services/<slug>).

const process = [
	{ n: '01', title: 'Discover', desc: 'We research, define and lock the goal together, so we build the right thing.' },
	{ n: '02', title: 'Design & build', desc: 'Design, engineer and test in tight, visible loops you can follow every week.' },
	{ n: '03', title: 'Launch & scale', desc: 'Ship it, market it, then maintain and grow what we shipped.' },
];

const stack = [
	{ group: 'Design', icon: 'mdi:palette-outline', tools: ['Figma', 'Illustrator', 'Photoshop', 'After Effects', 'Framer', 'Sketch'] },
	{ group: 'Web', icon: 'mdi:language-html5', tools: ['React', 'Next.js', 'Vue', 'Nuxt', 'Astro', 'Svelte', 'Tailwind', 'TypeScript'] },
	{ group: 'Mobile', icon: 'mdi:cellphone', tools: ['Flutter', 'React Native', 'Swift', 'Kotlin', 'Expo'] },
	{ group: 'Backend', icon: 'mdi:server-network', tools: ['Node', 'Python', 'PHP', 'Laravel', 'Django', 'Go', 'Express'] },
	{ group: 'Cloud & DevOps', icon: 'mdi:cloud-outline', tools: ['AWS', 'Vercel', 'Docker', 'Kubernetes', 'Cloudflare', 'GitHub Actions'] },
	{ group: 'Data & AI', icon: 'mdi:database-outline', tools: ['PostgreSQL', 'MongoDB', 'Redis', 'Supabase', 'OpenAI', 'Prisma'] },
	{ group: 'Commerce', icon: 'mdi:cart-outline', tools: ['Stripe', 'Shopify', 'WooCommerce', 'Paystack', 'PayPal'] },
	{ group: 'CMS & content', icon: 'mdi:file-document-edit-outline', tools: ['WordPress', 'Sanity', 'Contentful', 'Strapi', 'Webflow'] },
	{ group: 'Quality & tooling', icon: 'mdi:check-decagram-outline', tools: ['Git', 'Jest', 'Playwright', 'Storybook', 'Sentry'] },
];

const stats = [
	{ to: 65, suffix: '+', label: 'Products shipped' },
	{ to: 98, suffix: '%', label: 'On-time delivery' },
	{ to: 7, suffix: '+', label: 'Years building' },
	{ to: 5, decimals: 1, suffix: '', label: 'Average rating' },
];

const sectors = [
	'Fintech', 'Real estate', 'Sports', 'E-commerce', 'Education', 'Logistics',
	'Healthcare', 'Beauty', 'Energy', 'Agritech', 'Hospitality', 'Media',
	'Retail', 'Travel', 'Gaming', 'Legal',
];
---

<div class="bdbody bd-services view-body view-body-boardroom">
	<!-- ── Hero — split: copy + an animated disciplines panel ── -->
	<header class="svc-hero bd-reveal">
		<span class="svc-hero-aurora" aria-hidden="true"></span>
		<div class="svc-hero-grid">
			<div class="svc-hero-copy">
				<span class="bd-kicker">What we do</span>
				<h1 class="bd-display svc-h1">
					One team for the
					<span class="bd-grad">whole journey.</span>
				</h1>
				<p class="bd-sub svc-hero-sub">
					Design, build, market and maintain, every discipline you need to
					launch and grow, under one roof.
				</p>
				<div class="bd-links svc-hero-links">
					<a href="/contact" class="bd-pill">Start a project</a>
					<a href="#svc-disciplines" class="bd-link">
						Explore what we do
						<Icon width={15} name="mdi:chevron-down" />
					</a>
				</div>
			</div>
			<div class="svc-hero-panel">
				<span class="svc-hero-panel-top">
					<span class="svc-hero-panel-dot" aria-hidden="true"></span>
					Six disciplines · one contract
				</span>
				<div class="svc-hero-tiles">
					{
						disciplines.map((d, i) => (
							<a href={`/services/${d.slug}`} class="svc-hero-tile" style={`--c:${d.color}; --i:${i}`} data-cursor={d.cursor} aria-label={d.title}>
								<span class="svc-hero-tile-ic"><Icon width={20} name={d.icon} /></span>
								<span class="svc-hero-tile-name">{d.title}</span>
								<Icon class="svc-hero-tile-go" width={15} name="mdi:arrow-right" />
							</a>
						))
					}
				</div>
			</div>
		</div>
	</header>

	<!-- ── The disciplines — doors into each world ─────────── -->
	<section class="bd-head bd-reveal" id="svc-disciplines">
		<h2 class="bd-h bd-h--center">Six disciplines. One contract.</h2>
		<p class="bd-p bd-p--center">
			No hiring, no hand-offs, no finger-pointing, every capability you
			need lives in the same room.
		</p>
	</section>
	<div class="svc-grid">
		{
			disciplines.map((d) => (
				<a
					href={`/services/${d.slug}`}
					class="svc-card bd-reveal"
					data-cursor={d.cursor}
					style={`--c:${d.color}`}
				>
					<span class="svc-card-glow" aria-hidden="true" />
					<span class="svc-card-n">{d.n}</span>
					<span class="svc-card-ic">
						<Icon width={30} name={d.icon} />
					</span>
					<h3 class="svc-card-title">{d.title}</h3>
					<p class="svc-card-tag">{d.tagline}</p>
					<p class="svc-card-desc">{d.desc}</p>
					<ul class="svc-card-items">
						{d.items.map((it) => (
							<li>
								<Icon width={14} name="mdi:check" />
								{it}
							</li>
						))}
					</ul>
					<span class="svc-card-go">
						Explore {d.title}
						<Icon width={16} name="mdi:arrow-right" />
					</span>
				</a>
			))
		}
	</div>

	<!-- ── How we work — the journey ───────────────────────── -->
	<section class="svc-journey bd-reveal" data-cursor="branch">
		<span class="svc-journey-aurora" aria-hidden="true"></span>
		<div class="bd-head">
			<h2 class="bd-h bd-h--center">How the adventure goes.</h2>
			<p class="bd-p bd-p--center">
				The same three moves on every project, visible, predictable, yours
				to follow.
			</p>
		</div>
		<ol class="svc-steps">
			<span class="svc-steps-line" aria-hidden="true"></span>
			{
				process.map((p) => (
					<li class="svc-step">
						<span class="svc-step-n">{p.n}</span>
						<h3 class="svc-step-t">{p.title}</h3>
						<p class="svc-step-d">{p.desc}</p>
					</li>
				))
			}
		</ol>
	</section>

	<!-- ── Showreel — copy paired with the video placeholder ── -->
	<section class="svc-reel bd-reveal" data-cursor="play">
		<div class="svc-reel-grid">
			<div class="svc-reel-copy">
				<span class="bd-kicker">Inside the studio</span>
				<h2 class="bd-h">See how we build.</h2>
				<p class="bd-p">A two-minute look from first sketch to launch day, the messy, honest middle included.</p>
				<ol class="svc-reel-chapters">
					<li><span>01</span> Discovery &amp; sketches</li>
					<li><span>02</span> Design &amp; build loops</li>
					<li><span>03</span> Launch day</li>
				</ol>
				<span class="svc-reel-meta"><Icon width={15} name="mdi:clock-outline" /> 2:00 · studio showreel</span>
			</div>
			<div class="svc-reel-frame">
				<span class="svc-reel-sheen" aria-hidden="true"></span>
				<span class="svc-reel-gridlines" aria-hidden="true"></span>
				<button type="button" class="svc-reel-play" aria-label="Play showreel">
					<Icon width={32} name="mdi:play" />
				</button>
				<span class="svc-reel-label">Video placeholder</span>
			</div>
		</div>
	</section>

	<!-- ── Numbers ─────────────────────────────────────────── -->
	<div class="bd-grid">
		<section class="bd-tile bd-tile--full bd-tile--inverse bd-reveal" id="svc-numbers" data-cursor="chart">
			<div class="bd-tile-copy">
				<h2 class="bd-h">Measured the only way that matters.</h2>
				<p class="bd-p">Seven years of shipping for ambitious businesses.</p>
			</div>
			<ul class="bd-numbers">
				{
					stats.map((n) => (
						<li class="bd-number">
							<strong data-count={n.to} data-suffix={n.suffix} data-decimals={n.decimals || 0}>
								0{n.suffix}
							</strong>
							<span>{n.label}</span>
						</li>
					))
				}
			</ul>
		</section>
	</div>

	<!-- ── The stack — a static, grouped capability grid ────── -->
	<section class="svc-stack bd-reveal" data-cursor="layers">
		<div class="bd-head">
			<h2 class="bd-h bd-h--center">The tools in our hands.</h2>
			<p class="bd-p bd-p--center">A modern, proven toolkit, picked for the job, not for the hype.</p>
		</div>
		<div class="svc-stack-grid">
			{
				stack.map((cat) => (
					<div class="svc-stack-cat">
						<span class="svc-stack-head">
							<span class="svc-stack-ic"><Icon width={18} name={cat.icon} /></span>
							<span class="svc-stack-label">{cat.group}</span>
							<span class="svc-stack-count">{cat.tools.length}</span>
						</span>
						<div class="svc-stack-chips">
							{cat.tools.map((t) => <span class="svc-chip">{t}</span>)}
						</div>
					</div>
				))
			}
		</div>
		<p class="svc-stack-note">…and whatever else the job calls for. We pick tools to fit your product, not our comfort zone.</p>
	</section>

	<!-- ── Sectors ─────────────────────────────────────────── -->
	<section class="bd-sectors bd-reveal" data-cursor="repo">
		<h2 class="bd-h bd-h--center">At home in your industry.</h2>
		<div class="bd-marquee" aria-hidden="true">
			<div class="bd-marquee-track bd-marquee-track--sectors">
				{
					[0, 1].map(() =>
						sectors.map((s) => <span class="bd-sector">{s}</span>)
					)
				}
			</div>
		</div>
	</section>

	<!-- ── CTA ─────────────────────────────────────────────── -->
	<section class="bd-grid">
		<div class="bd-tile bd-tile--full bd-tile--cta bd-reveal" data-cursor="phone">
			<h2 class="bd-display bd-display--cta">Ready to build?</h2>
			<p class="bd-sub">
				Tell us what you have in mind. You'll have a reply within one
				business day.
			</p>
			<div class="bd-links bd-links--center">
				<a href="/contact" class="bd-pill bd-pill--light">Start your project</a>
				<a href="/portfolio" class="bd-link bd-link--invert">
					See the work
					<Icon width={15} name="mdi:chevron-right" />
				</a>
			</div>
			<a href="tel:+2348100204570" class="bd-call">
				<span class="bd-call-hint">or call us now</span>
				<span class="bd-call-num">
					<Icon width={30} name="mdi:phone" />
					+234 810 020 4570
				</span>
			</a>
		</div>
	</section>
</div>

<style>
	/* ════ Boardroom base (self-contained, mirrors AboutBoardroom) ════ */
	.bdbody {
		--bd-accent: #28a6ec;
		--bd-ink: #f4f6fb;
		--bd-muted: rgba(244, 246, 251, 0.62);
		--bd-glass: linear-gradient(160deg, rgba(255, 255, 255, 0.07), rgba(255, 255, 255, 0.02) 55%);
		--bd-glass-border: rgba(255, 255, 255, 0.1);
		--bd-shadow: 0 34px 80px -34px rgba(0, 0, 0, 0.8);
		font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
		position: relative;
		isolation: isolate;
		background:
			radial-gradient(1100px 540px at 78% -6%, color-mix(in srgb, var(--bd-accent) 13%, transparent), transparent 62%),
			radial-gradient(900px 520px at 8% 38%, rgba(58, 90, 200, 0.1), transparent 60%),
			linear-gradient(180deg, #070910 0%, #0a0d1c 45%, #05060d 100%);
		color: var(--bd-ink);
		padding: clamp(2.5rem, 6vw, 4.5rem) clamp(1rem, 3vw, 2rem) clamp(2.5rem, 5vw, 4rem);
		transition: background 0.4s ease, color 0.4s ease;
	}
	:global(html:not(.dark)) .bdbody {
		--bd-ink: #14162a;
		--bd-muted: rgba(20, 22, 40, 0.64);
		--bd-glass: linear-gradient(160deg, rgba(255, 255, 255, 0.82), rgba(255, 255, 255, 0.55) 55%);
		--bd-glass-border: rgba(20, 22, 40, 0.1);
		--bd-shadow: 0 30px 70px -34px rgba(20, 22, 40, 0.25);
		background:
			radial-gradient(1100px 540px at 78% -6%, color-mix(in srgb, var(--bd-accent) 10%, transparent), transparent 62%),
			linear-gradient(180deg, #eef2f7 0%, #e7edf6 50%, #eef2f7 100%);
	}

	.bd-kicker { display: inline-block; font-size: 0.78rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--bd-accent); margin-bottom: 1rem; }
	.bd-display { font-size: clamp(2.6rem, 6vw, 4.6rem); font-weight: 700; letter-spacing: -0.025em; line-height: 1.04; margin: 0 0 1.1rem; }
	.bd-grad {
		background: linear-gradient(110deg, #9bd8ff 0%, var(--bd-accent) 38%, #7ef0d2 64%, #9bd8ff 100%);
		background-size: 220% 100%;
		-webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;
		animation: svc-grad 7s ease infinite;
	}
	@keyframes svc-grad { 0%,100%{ background-position:0% 50%; } 50%{ background-position:100% 50%; } }
	.bd-sub { font-size: clamp(1.05rem, 2vw, 1.35rem); line-height: 1.5; color: var(--bd-muted); max-width: 40rem; margin: 0 auto 1.6rem; }
	.bd-h { font-size: clamp(1.7rem, 3.4vw, 2.5rem); font-weight: 700; letter-spacing: -0.02em; line-height: 1.1; margin: 0 0 0.7rem; }
	.bd-h--center { text-align: center; }
	.bd-p { font-size: 1.02rem; line-height: 1.6; color: var(--bd-muted); max-width: 30rem; margin: 0 auto 1.2rem; }
	.bd-p--center { margin-inline: auto; text-align: center; }
	.bd-head { max-width: 56rem; margin: clamp(2.5rem, 6vw, 4rem) auto clamp(1.5rem, 3vw, 2rem); text-align: center; }

	.bd-links { display: flex; align-items: center; justify-content: center; gap: 1.4rem; flex-wrap: wrap; }
	.bd-links--center { justify-content: center; }
	.bd-pill {
		position: relative; display: inline-flex; align-items: center; padding: 0.78rem 1.5rem; border-radius: 9999px;
		background: linear-gradient(180deg, color-mix(in srgb, var(--bd-accent) 88%, #fff), var(--bd-accent) 45%, color-mix(in srgb, var(--bd-accent) 72%, #03244a));
		border: 1px solid color-mix(in srgb, var(--bd-accent) 60%, rgba(255, 255, 255, 0.4));
		color: #fff; font-size: 0.95rem; font-weight: 600; text-shadow: 0 1px 2px rgba(0, 0, 0, 0.25);
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.35), 0 12px 28px -12px color-mix(in srgb, var(--bd-accent) 65%, transparent);
		transition: transform 0.25s ease, box-shadow 0.25s ease;
	}
	.bd-pill:hover { transform: translateY(-2px); box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.4), 0 18px 38px -12px color-mix(in srgb, var(--bd-accent) 80%, transparent); }
	.bd-pill--light { background: linear-gradient(180deg, #ffffff, #dfe6f2); border-color: rgba(255, 255, 255, 0.8); color: #0b0d18; text-shadow: none; }
	.bd-link { display: inline-flex; align-items: center; gap: 0.15rem; font-size: 0.98rem; font-weight: 600; color: var(--bd-accent); transition: gap 0.25s ease; }
	.bd-link:hover { gap: 0.4rem; }
	.bd-link--invert { color: #9bd8ff; }

	.bd-grid { display: grid; gap: clamp(0.9rem, 2vw, 1.4rem); max-width: 88rem; margin: 0 auto clamp(0.9rem, 2vw, 1.4rem); }
	.bd-tile {
		position: relative; display: flex; flex-direction: column; gap: 1.4rem; text-align: center;
		padding: clamp(2rem, 4vw, 3rem) clamp(1.25rem, 3vw, 2.25rem) clamp(1.4rem, 3vw, 2rem);
		border-radius: 1.75rem; background: var(--bd-glass); border: 1px solid var(--bd-glass-border); box-shadow: var(--bd-shadow);
		backdrop-filter: blur(22px) saturate(130%); -webkit-backdrop-filter: blur(22px) saturate(130%); overflow: hidden;
	}
	.bd-tile--full { grid-column: 1 / -1; }
	.bd-tile-copy { max-width: 40rem; margin: 0 auto; }
	.bd-tile--inverse {
		background: radial-gradient(720px 320px at 50% -10%, color-mix(in srgb, var(--bd-accent) 34%, transparent), transparent 70%), linear-gradient(180deg, rgba(21, 26, 48, 0.9), rgba(5, 6, 13, 0.95));
		color: #f5f5f7; border-color: color-mix(in srgb, var(--bd-accent) 30%, rgba(255, 255, 255, 0.1));
	}
	.bd-tile--inverse .bd-p { color: rgba(245, 245, 247, 0.62); }
	.bd-numbers { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 1.25rem; list-style: none; margin: 0.5rem 0 0.75rem; padding: 0; }
	@media (max-width: 760px) { .bd-numbers { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
	.bd-number strong {
		display: block; font-size: clamp(2.4rem, 5vw, 3.6rem); font-weight: 700; letter-spacing: -0.03em;
		background: linear-gradient(135deg, #9bd8ff, var(--bd-accent)); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;
	}
	.bd-number span { font-size: 0.85rem; color: rgba(245, 245, 247, 0.6); }

	/* ── Hero — full-bleed bg, elegant split content ── */
	.svc-hero {
		position: relative;
		overflow: hidden;
		margin: calc(-1 * clamp(2.5rem, 6vw, 4.5rem)) calc(-1 * clamp(1rem, 3vw, 2rem)) clamp(2.5rem, 6vw, 4rem);
		padding: clamp(3.5rem, 8vw, 6rem) clamp(1rem, 3vw, 2rem) clamp(3rem, 6vw, 4.5rem);
	}
	.svc-hero-grid { position: relative; z-index: 1; max-width: 78rem; margin-inline: auto; display: grid; gap: clamp(2.5rem, 5vw, 4rem); align-items: center; }
	@media (min-width: 940px) { .svc-hero-grid { grid-template-columns: 1.05fr 0.95fr; } }
	.svc-hero-grid > * { min-width: 0; }
	.svc-hero-copy { text-align: left; min-width: 0; }
	.svc-h1 { max-width: 14ch; margin: 0 0 1.1rem; }
	.svc-hero-sub { margin: 0 0 1.6rem; }
	.svc-hero-links { justify-content: flex-start; }
	.svc-hero-aurora {
		position: absolute; inset: -30% -10%; z-index: 0; pointer-events: none;
		background:
			radial-gradient(560px 420px at 18% 26%, rgba(34, 211, 238, 0.24), transparent 60%),
			radial-gradient(620px 460px at 82% 30%, rgba(139, 92, 246, 0.22), transparent 62%),
			radial-gradient(520px 380px at 50% 100%, color-mix(in srgb, var(--bd-accent) 26%, transparent), transparent 60%);
		filter: blur(54px); opacity: 0.6; animation: svc-aurora 17s ease-in-out infinite;
	}
	:global(html:not(.dark)) .svc-hero-aurora { opacity: 0.4; }
	@keyframes svc-aurora { 0%,100%{ transform: translate3d(0,0,0) scale(1); } 50%{ transform: translate3d(2%,-2%,0) scale(1.08); } }

	/* hero disciplines panel */
	.svc-hero-panel {
		position: relative; padding: clamp(1.2rem, 2.5vw, 1.7rem); border-radius: 1.75rem;
		background: var(--bd-glass); border: 1px solid var(--bd-glass-border); box-shadow: var(--bd-shadow);
		backdrop-filter: blur(22px) saturate(130%); -webkit-backdrop-filter: blur(22px) saturate(130%);
	}
	.svc-hero-panel-top { display: flex; align-items: center; gap: 0.5rem; font-size: 0.74rem; font-weight: 800; letter-spacing: 0.1em; text-transform: uppercase; color: var(--bd-muted); margin-bottom: 1rem; padding-inline: 0.2rem; }
	.svc-hero-panel-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--bd-accent); box-shadow: 0 0 0 0 color-mix(in srgb, var(--bd-accent) 55%, transparent); animation: svc-dot 2.4s ease-out infinite; }
	@keyframes svc-dot { 0%{ box-shadow: 0 0 0 0 color-mix(in srgb, var(--bd-accent) 50%, transparent); } 70%,100%{ box-shadow: 0 0 0 8px transparent; } }
	.svc-hero-tiles { display: grid; grid-template-columns: 1fr 1fr; gap: 0.6rem; }
	@media (max-width: 600px) { .svc-hero-tiles { grid-template-columns: 1fr; } }
	.svc-hero-tile { min-width: 0; }
	.svc-hero-tile {
		position: relative; display: flex; align-items: center; gap: 0.6rem; padding: 0.75rem 0.85rem; border-radius: 1rem;
		background: color-mix(in srgb, var(--c) 8%, transparent); border: 1px solid color-mix(in srgb, var(--c) 22%, var(--bd-glass-border));
		transition: transform 0.3s cubic-bezier(0.22,1,0.36,1), border-color 0.3s ease, background 0.3s ease;
		animation: svc-tile-float 5s ease-in-out infinite; animation-delay: calc(var(--i) * 0.4s);
	}
	.svc-hero-tile:hover { transform: translateY(-3px); background: color-mix(in srgb, var(--c) 16%, transparent); border-color: color-mix(in srgb, var(--c) 45%, transparent); }
	@keyframes svc-tile-float { 0%,100%{ transform: translateY(0); } 50%{ transform: translateY(-4px); } }
	.svc-hero-tile-ic { display: grid; place-items: center; width: 34px; height: 34px; flex-shrink: 0; border-radius: 0.65rem; color: var(--c); background: color-mix(in srgb, var(--c) 16%, transparent); border: 1px solid color-mix(in srgb, var(--c) 30%, transparent); }
	.svc-hero-tile-name { flex: 1; font-size: 0.92rem; font-weight: 700; letter-spacing: -0.01em; color: var(--bd-ink); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
