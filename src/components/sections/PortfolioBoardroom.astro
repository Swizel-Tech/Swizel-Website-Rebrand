---
// Portfolio — the Boardroom world. The grand showcase: real shipped work with
// live screenshots, a featured case-study reel (each links to its own /work
// page), the Brevarium magazines, a showreel slot, and a CSS-only sector
// filter over every project. Reuses initBoardroomBody reveals/counters.
import { Icon } from 'astro-icon';
import { projects, featuredProjects, sectorLabels, sectorOrder, type ProjectSector } from '../../data/projects';

const sectors = sectorOrder;
// the real number of cards shown for each sector (drives the actual filter)
const sectorCount = (s: ProjectSector) => projects.filter((p) => p.sector === s).length;
// what we tell visitors — we've shipped far more than the ~20 we showcase here
const sectorShown: Record<ProjectSector, string> = {
	agri: '12+', health: '6+', property: '14+', media: '9+', commerce: '8+', product: '18+',
};
const totalShown = '65+';

const stats = [
	{ to: 65, suffix: '+', label: 'Products shipped' },
	{ to: 15, suffix: '+', label: 'Sectors served' },
	{ to: 7, suffix: '+', label: 'Years building' },
	{ to: 99.9, decimals: 1, suffix: '%', label: 'Uptime upheld' },
];

// a hand-picked, colour-varied deck for the shuffling hero
const deckSlugs = ['binas-residence', 'jobblander', 'hemam-synergy', 'trueverdict', 'anchorstep'];
const deck = deckSlugs.map((s) => projects.find((p) => p.slug === s)).filter(Boolean) as typeof projects;

// the full-bleed scrolling wall under the hero — two rows, opposite directions
const marquee = [...projects, ...projects];
const rot = [...projects.slice(6), ...projects.slice(0, 6)];
const marquee2 = [...rot, ...rot];

// the project's destination: its case study, else the live site
// Case studies open their on-site /work page; other products link to the live
// site — but those external clicks pass through a "you're leaving Swizel"
// confirmation (see [data-leaving]) so people can bounce back and keep exploring.
const dest = (p: (typeof projects)[number]) => (p.caseStudy ? `/work/${p.slug}` : p.url);
// the custom cursor adapts to each project's sector (health ≠ briefcase)
const sectorCursor: Record<ProjectSector, string> = { agri: 'branch', health: 'pulse', property: 'layers', media: 'book', commerce: 'pkg', product: 'repo' };
---

<div class="bdbody bd-services bd-portfolio view-body view-body-boardroom">
	<!-- ── Hero ───────────────────────────────────────────── -->
	<header class="pf-hero bd-reveal">
		<span class="pf-hero-aurora" aria-hidden="true"></span>
		<div class="pf-hero-grid">
			<div class="pf-hero-copy">
				<span class="bd-kicker">Our work · the receipts</span>
				<h1 class="bd-display pf-h1">
					Proof, not
					<span class="bd-grad">promises.</span>
				</h1>
				<p class="bd-sub pf-hero-sub">
					Real products, live on the internet — agritech, health, media, property,
					commerce and platforms we designed, built, launched and still look after.
				</p>
				<div class="bd-links pf-hero-links">
					<a href="#pf-featured" class="bd-pill">See the headliners</a>
					<a href="#pf-work" class="bd-link">Browse everything <Icon width={15} name="mdi:arrow-down" /></a>
				</div>
			</div>
			<div class="pf-deck" aria-hidden="true">
				{deck.map((p, i) => (
					<span class="pf-deck-card" style={`--c:${p.color}; --i:${i}`}>
						<span class="pf-deck-bar"><i></i><i></i><i></i></span>
						<img src={p.img} alt="" loading={i === 0 ? 'eager' : 'lazy'} decoding="async" draggable={false} />
					</span>
				))}
				<span class="pf-deck-hint">
					<svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 8l-4 4 4 4M17 8l4 4-4 4M4 12h16" /></svg>
					<span class="pf-hint-touch">Swipe to shuffle</span>
					<span class="pf-hint-mouse">Drag to shuffle</span>
				</span>
			</div>
		</div>
	</header>

	<!-- ── Full-bleed scrolling wall ───────────────────────── -->
	<section class="pf-wall bd-reveal">
		<p class="pf-wall-head">A wall of work, on loop.</p>
		<div class="pf-marquee" aria-hidden="true">
			<div class="pf-marquee-track">
				{marquee.map((p) => (
					<a href={dest(p) ?? undefined} data-leaving={p.caseStudy ? undefined : p.host} data-leaving-name={p.caseStudy ? undefined : p.name} class="pf-thumb" style={`--c:${p.color}`} tabindex="-1">
						<img src={p.img} alt="" loading="eager" decoding="async" />
					</a>
				))}
			</div>
			<div class="pf-marquee-track pf-marquee-track--rev">
				{marquee2.map((p) => (
					<a href={dest(p) ?? undefined} data-leaving={p.caseStudy ? undefined : p.host} data-leaving-name={p.caseStudy ? undefined : p.name} class="pf-thumb" style={`--c:${p.color}`} tabindex="-1">
						<img src={p.img} alt="" loading="eager" decoding="async" />
					</a>
				))}
			</div>
		</div>
	</section>

	<!-- ── Impact numbers ──────────────────────────────────── -->
	<div class="bd-grid">
		<section class="bd-tile bd-tile--full bd-tile--inverse bd-reveal" data-cursor="chart">
			<ul class="bd-numbers">
				{stats.map((n) => (
					<li class="bd-number">
						<strong data-count={n.to} data-suffix={n.suffix} data-decimals={n.decimals || 0}>0{n.suffix}</strong>
						<span>{n.label}</span>
					</li>
				))}
			</ul>
		</section>
	</div>

	<!-- ── Featured case studies (each → its own page) ─────── -->
	<section class="bd-head bd-reveal" id="pf-featured">
		<span class="bd-kicker">Featured · drumroll</span>
		<h2 class="bd-h bd-h--center">Stories worth the long read.</h2>
		<p class="bd-p bd-p--center">A handful told in full — the brief, the build, the result. And this is just the tip.</p>
	</section>
	<div class="pf-feats">
		{featuredProjects.map((p, i) => (
			<article class:list={['pf-feat', 'bd-reveal', { 'pf-feat--rev': i % 2 === 1 }]} style={`--c:${p.color}`} data-cursor={sectorCursor[p.sector]}>
				<a class:list={['pf-shot', 'pf-shot--lg', { 'pf-shot--app': p.kind === 'app' }]} href={`/work/${p.slug}`} aria-label={`${p.name} case study`}>
					{p.kind !== 'app' && <span class="pf-bar" aria-hidden="true"><i></i><i></i><i></i><span class="pf-url">{p.host}</span></span>}
					<span class="pf-img"><img src={p.img} alt={`${p.name}`} loading={i === 0 ? 'eager' : 'lazy'} /></span>
					<span class="pf-open" aria-hidden="true"><Icon width={16} name="mdi:arrow-top-right" /></span>
				</a>
				<div class="pf-feat-body">
					<span class="pf-feat-eyebrow">{String(i + 1).padStart(2, '0')} · {sectorLabels[p.sector]}</span>
					<h3 class="pf-feat-name">{p.name}</h3>
					<p class="pf-feat-tagline">{p.tagline}</p>
					<p class="pf-feat-blurb">{p.blurb}</p>
					<ul class="pf-tags">
						{p.tags.map((t) => <li>{t}</li>)}
					</ul>
					<a class="pf-feat-cta" href={`/work/${p.slug}`}>
						Read the case study <Icon width={16} name="mdi:arrow-right" />
					</a>
				</div>
			</article>
		))}
	</div>

	<!-- ── Showreel — room for a video ─────────────────────── -->
	<section class="pf-reel bd-reveal" data-cursor="play">
		<div class="pf-reel-grid">
			<div class="pf-reel-copy">
				<span class="bd-kicker">Showreel</span>
				<h2 class="bd-h">Watch the work move.</h2>
				<p class="bd-p">Drop in a two-minute sizzle of the products, the builds and the launches — proof in motion.</p>
				<a href="/contact" class="bd-link">Want this energy on your project? <Icon width={15} name="mdi:arrow-right" /></a>
			</div>
			<div class="pf-reel-frame">
				<span class="pf-reel-sheen" aria-hidden="true"></span>
				<span class="pf-reel-grid-lines" aria-hidden="true"></span>
				<button type="button" class="pf-reel-play" aria-label="Play showreel"><Icon width={32} name="mdi:play" /></button>
				<span class="pf-reel-label">Video placeholder</span>
			</div>
		</div>
	</section>

	<!-- ── The Brevarium magazines ─────────────────────────── -->
	<section class="bd-head bd-reveal">
		<span class="bd-kicker">In print, too</span>
		<h2 class="bd-h bd-h--center">The Brevarium.</h2>
		<p class="bd-p bd-p--center">Our magazine — the products, the team and the thinking behind the work. Read it cover to cover.</p>
	</section>
	<div class="pf-mags">
		<a class="pf-mag pf-mag--latest bd-reveal" href="/brevarium/the-brevarium-latest.pdf" download data-cursor="book">
			<span class="pf-mag-cover"><img src="/images/portfolio/mag-latest-cover.jpg" alt="The Brevarium — latest edition" loading="lazy" /></span>
			<span class="pf-mag-meta">
				<span class="pf-mag-tag">Latest edition</span>
				<strong>The Brevarium</strong>
				<em>You Imagine. We Build. — featured projects, the team & how we ship.</em>
				<span class="pf-mag-dl"><Icon width={16} name="mdi:download" /> Download PDF</span>
			</span>
		</a>
		<a class="pf-mag bd-reveal" href="/The Brevarium by Swizel.pdf" download data-cursor="book">
			<span class="pf-mag-cover"><img src="/images/portfolio/mag-v1-cover.jpg" alt="The Brevarium — Vol. 1" loading="lazy" /></span>
			<span class="pf-mag-meta">
				<span class="pf-mag-tag">Vol. 1</span>
				<strong>The Brevarium</strong>
				<em>The AppMan story — a full product, start to finish.</em>
				<span class="pf-mag-dl"><Icon width={16} name="mdi:download" /> Download PDF</span>
			</span>
		</a>
	</div>

	<!-- ── Featured work — CSS-only sector filter ──────────── -->
	<section class="bd-head bd-reveal" id="pf-work">
		<span class="bd-kicker">A taste of the shelf</span>
		<h2 class="bd-h bd-h--center">Featured work.</h2>
		<p class="bd-p bd-p--center">We’ve shipped <strong>{totalShown}</strong> products across <strong>15+</strong> sectors. Here are ~{projects.length} of our favourites — filter by sector.</p>
	</section>
	<form class="pf-filter">
		<input class="pf-radio" type="radio" name="pf" id="pf-all" checked />
		{sectors.map((s) => (
			<input class="pf-radio" type="radio" name="pf" id={`pf-${s}`} />
		))}
		<div class="pf-chips bd-reveal">
			<label class="pf-chip pf-chip--all" for="pf-all">Featured work <span>{totalShown}</span></label>
			{sectors.map((s) => (
				<label class="pf-chip" for={`pf-${s}`}>{sectorLabels[s]} <span>{sectorShown[s]}</span></label>
			))}
		</div>
		<div class="pf-grid">
			{projects.map((p) => {
				const href = dest(p);
				const hasCase = !!p.caseStudy;
				const internal = hasCase; // case study = on-site; otherwise a live product
				const Tag = href ? 'a' : 'div';
				return (
					<article class:list={['pf-card', 'bd-reveal', `s-${p.sector}`]} style={`--c:${p.color}`} data-cursor={sectorCursor[p.sector]}>
						<Tag
							class="pf-card-link"
							href={href ?? undefined}
							data-leaving={href && !internal ? p.host : undefined}
							data-leaving-name={href && !internal ? p.name : undefined}
							rel={href && !internal ? 'noopener noreferrer' : undefined}
							aria-label={p.name}
							aria-disabled={href ? undefined : 'true'}
						>
							<span class:list={['pf-shot', { 'pf-shot--app': p.kind === 'app' }]}>
								{p.kind !== 'app' && <span class="pf-bar" aria-hidden="true"><i></i><i></i><i></i><span class="pf-url">{p.host}</span></span>}
								<span class="pf-img"><img src={p.img} alt={`${p.name}`} loading="lazy" /></span>
								<span class="pf-open" aria-hidden="true"><Icon width={15} name="mdi:arrow-right" /></span>
								{hasCase && <span class="pf-badge">Case study</span>}
							</span>
							<div class="pf-card-body">
								<div class="pf-card-head">
									<h3 class="pf-card-name">{p.name}</h3>
									<span class="pf-card-year">{p.year}</span>
								</div>
								<p class="pf-card-tagline">{p.tagline}</p>
								<ul class="pf-tags">
									{p.tags.map((t) => <li>{t}</li>)}
								</ul>
							</div>
						</Tag>
					</article>
				);
			})}
			<a class="pf-card pf-next s-agri s-health s-property s-media s-commerce s-product" href="/contact" data-cursor="phone">
				<span class="pf-next-glow" aria-hidden="true"></span>
				<span class="pf-next-ic"><Icon width={26} name="mdi:rocket-launch-outline" /></span>
				<span class="pf-next-kicker">There’s so much more</span>
				<strong class="pf-next-h">Yours could be next.</strong>
				<span class="pf-next-p">We’ve shipped <b>65+</b> products across <b>15+</b> sectors. Let’s make yours the one we show off.</span>
				<span class="pf-next-cta">Start your project <Icon width={16} name="mdi:arrow-right" /></span>
			</a>
		</div>
	</form>

	<!-- ── CTA ─────────────────────────────────────────────── -->
	<section class="bd-grid">
		<div class="bd-tile bd-tile--full bd-tile--cta bd-reveal" data-cursor="phone">
			<h2 class="bd-display bd-display--cta">Your project, next on this page.</h2>
			<p class="bd-sub">Tell us what you have in mind — you’ll have a reply within one business day.</p>
			<div class="bd-links bd-links--center">
				<a href="/contact" class="bd-pill bd-pill--light">Start your project</a>
				<a href="/services" class="bd-link bd-link--invert">See what we do <Icon width={15} name="mdi:chevron-right" /></a>
			</div>
		</div>
	</section>
</div>

<style>
	/* ════ Boardroom base (self-contained), boardroom blue ════ */
	.bdbody {
		--bd-accent: #28a6ec;
		--bd-ink: #f4f6fb;
		--bd-muted: rgba(244, 246, 251, 0.62);
		--bd-glass: linear-gradient(160deg, rgba(255, 255, 255, 0.07), rgba(255, 255, 255, 0.02) 55%);
		--bd-glass-border: rgba(255, 255, 255, 0.1);
		--bd-shadow: 0 34px 80px -34px rgba(0, 0, 0, 0.8);
		font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
		position: relative; isolation: isolate; overflow: hidden;
		background:
			radial-gradient(1100px 540px at 78% -6%, color-mix(in srgb, var(--bd-accent) 13%, transparent), transparent 62%),
			radial-gradient(900px 520px at 8% 38%, rgba(58, 90, 200, 0.1), transparent 60%),
			linear-gradient(180deg, #070910 0%, #0a0d1c 45%, #05060d 100%);
		color: var(--bd-ink);
		padding: clamp(2.5rem, 6vw, 4.5rem) clamp(1rem, 3vw, 2rem) clamp(2.5rem, 5vw, 4rem);
		transition: background 0.4s ease, color 0.4s ease;
	}
	:global(html:not(.dark)) .bdbody {
		--bd-ink: #0f1120;
		--bd-muted: rgba(28, 32, 52, 0.82);
		--bd-glass: linear-gradient(160deg, #ffffff, #f3f6fb 60%);
		--bd-glass-border: rgba(18, 22, 45, 0.16);
		--bd-shadow: 0 26px 60px -32px rgba(20, 28, 60, 0.4);
		background:
			radial-gradient(1100px 540px at 78% -6%, color-mix(in srgb, var(--bd-accent) 12%, transparent), transparent 62%),
			linear-gradient(180deg, #e4eaf2 0%, #dbe3ee 50%, #e4eaf2 100%);
	}

	/* living background — drifting light blobs + a slow-panning dot grid */
	.bdbody::before {
		content: ''; position: absolute; inset: -12%; z-index: -2; pointer-events: none;
		background:
			radial-gradient(440px 440px at 14% 18%, color-mix(in srgb, var(--bd-accent) 24%, transparent), transparent 60%),
			radial-gradient(400px 400px at 86% 26%, rgba(139, 92, 246, 0.2), transparent 60%),
			radial-gradient(480px 480px at 62% 88%, rgba(34, 211, 238, 0.18), transparent 62%);
		filter: blur(60px); opacity: 0.7; animation: pf-bg-float 26s ease-in-out infinite;
	}
	:global(html:not(.dark)) .bdbody::before { opacity: 0.45; }
	@keyframes pf-bg-float {
		0%, 100% { transform: translate3d(0, 0, 0) scale(1); }
		33% { transform: translate3d(3%, -2%, 0) scale(1.08); }
		66% { transform: translate3d(-2%, 2%, 0) scale(1.04); }
	}
	.bdbody::after {
		content: ''; position: absolute; inset: 0; z-index: -2; pointer-events: none; opacity: 0.5;
		background-image: radial-gradient(circle, color-mix(in srgb, var(--bd-accent) 32%, transparent) 1px, transparent 1px);
		background-size: 36px 36px;
		-webkit-mask-image: radial-gradient(1300px 760px at 50% 2%, #000, transparent 72%);
		mask-image: radial-gradient(1300px 760px at 50% 2%, #000, transparent 72%);
		animation: pf-bg-pan 46s linear infinite;
	}
	:global(html:not(.dark)) .bdbody::after { opacity: 0.3; }
	@keyframes pf-bg-pan { to { background-position: 360px 220px; } }

	.bd-kicker { display: inline-block; font-size: 0.78rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--bd-accent); margin-bottom: 1rem; }
	/* light-mode contrast: brighter accents wash out on the pale bg */
	:global(html:not(.dark)) .bd-kicker { color: #1577b8; }
	:global(html:not(.dark)) .bd-link { color: #1577b8; }
	:global(html:not(.dark)) .pf-tags li { color: color-mix(in srgb, var(--c) 40%, #14162a); background: color-mix(in srgb, var(--c) 15%, transparent); border-color: color-mix(in srgb, var(--c) 38%, transparent); }
	:global(html:not(.dark)) .pf-card-year { color: color-mix(in srgb, var(--c) 55%, #14162a); }
	:global(html:not(.dark)) .pf-feat-tagline { color: color-mix(in srgb, var(--c) 55%, #14162a); }
	.bd-display { font-size: clamp(2.6rem, 6vw, 4.6rem); font-weight: 700; letter-spacing: -0.025em; line-height: 1.04; margin: 0 0 1.1rem; }
	.bd-grad { background: linear-gradient(110deg, #9bd8ff 0%, var(--bd-accent) 38%, #7ef0d2 64%, #9bd8ff 100%); background-size: 220% 100%; -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent; animation: pf-grad 7s ease infinite; }
	@keyframes pf-grad { 0%,100%{ background-position:0% 50%; } 50%{ background-position:100% 50%; } }
	.bd-sub { font-size: clamp(1.05rem, 2vw, 1.35rem); line-height: 1.5; color: var(--bd-muted); max-width: 42rem; margin: 0 auto 1.6rem; }
	.bd-h { font-size: clamp(1.7rem, 3.4vw, 2.5rem); font-weight: 700; letter-spacing: -0.02em; line-height: 1.1; margin: 0 0 0.7rem; }
	.bd-h--center { text-align: center; }
	.bd-p { font-size: 1.02rem; line-height: 1.6; color: var(--bd-muted); max-width: 36rem; margin: 0 auto 1.2rem; }
	.bd-p--center { margin-inline: auto; text-align: center; }
	.bd-head { max-width: 56rem; margin: clamp(2.5rem, 7vw, 4.5rem) auto clamp(1.5rem, 3vw, 2rem); text-align: center; }

	.bd-links { display: flex; align-items: center; justify-content: center; gap: 1.4rem; flex-wrap: wrap; }
	.bd-links--center { justify-content: center; }
	.bd-pill { position: relative; display: inline-flex; align-items: center; gap: 0.4rem; padding: 0.78rem 1.5rem; border-radius: 9999px; background: linear-gradient(180deg, color-mix(in srgb, var(--bd-accent) 88%, #fff), var(--bd-accent) 45%, color-mix(in srgb, var(--bd-accent) 72%, #03244a)); border: 1px solid color-mix(in srgb, var(--bd-accent) 60%, rgba(255, 255, 255, 0.4)); color: #fff; font-size: 0.95rem; font-weight: 600; text-shadow: 0 1px 2px rgba(0, 0, 0, 0.25); box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.35), 0 12px 28px -12px color-mix(in srgb, var(--bd-accent) 65%, transparent); transition: transform 0.25s ease, box-shadow 0.25s ease; }
	.bd-pill:hover { transform: translateY(-2px); box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.4), 0 18px 38px -12px color-mix(in srgb, var(--bd-accent) 80%, transparent); }
	.bd-pill--light { background: linear-gradient(180deg, #ffffff, #dfe6f2); border-color: rgba(255, 255, 255, 0.8); color: #0b0d18; text-shadow: none; }
	.bd-link { display: inline-flex; align-items: center; gap: 0.25rem; font-size: 0.98rem; font-weight: 600; color: var(--bd-accent); transition: gap 0.25s ease; }
	.bd-link:hover { gap: 0.5rem; }
	.bd-link--invert { color: #9bd8ff; }

	.bd-grid { display: grid; gap: clamp(0.9rem, 2vw, 1.4rem); max-width: 88rem; margin: 0 auto clamp(0.9rem, 2vw, 1.4rem); }
	.bd-tile { position: relative; display: flex; flex-direction: column; gap: 1.4rem; text-align: center; padding: clamp(2rem, 4vw, 3rem) clamp(1.25rem, 3vw, 2.25rem); border-radius: 1.75rem; background: var(--bd-glass); border: 1px solid var(--bd-glass-border); box-shadow: var(--bd-shadow); backdrop-filter: blur(22px) saturate(130%); -webkit-backdrop-filter: blur(22px) saturate(130%); overflow: hidden; }
	.bd-tile--full { grid-column: 1 / -1; }
	.bd-tile--inverse { background: radial-gradient(720px 320px at 50% -10%, color-mix(in srgb, var(--bd-accent) 34%, transparent), transparent 70%), linear-gradient(180deg, rgba(21, 26, 48, 0.9), rgba(5, 6, 13, 0.95)); color: #f5f5f7; border-color: color-mix(in srgb, var(--bd-accent) 30%, rgba(255, 255, 255, 0.1)); }
	/* Stats as glossy chips with depth + an accent sheen — premium dashboard feel,
	   and compact 2×2 on phones. */
	.bd-numbers { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 0.8rem; list-style: none; margin: 0; padding: 0; width: 100%; }
	@media (max-width: 760px) { .bd-numbers { grid-template-columns: 1fr 1fr; gap: 0.65rem; } }
	.bd-number {
		position: relative;
		padding: clamp(0.95rem, 3vw, 1.4rem) clamp(0.9rem, 3vw, 1.3rem);
		border-radius: 1.1rem;
		background: linear-gradient(180deg, rgba(255, 255, 255, 0.09), rgba(255, 255, 255, 0.015));
		border: 1px solid var(--bd-glass-border);
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.13), 0 18px 40px -28px rgba(0, 0, 0, 0.7);
		overflow: hidden;
		transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1), border-color 0.35s ease;
	}
	.bd-number::before { content: ''; position: absolute; inset: 0 0 auto 0; height: 2px; background: linear-gradient(90deg, transparent, var(--bd-accent), transparent); opacity: 0.55; }
	.bd-number:hover { transform: translateY(-4px); border-color: color-mix(in srgb, var(--bd-accent) 42%, var(--bd-glass-border)); }
	.bd-number strong { display: block; font-size: clamp(1.9rem, 6vw, 3rem); font-weight: 700; letter-spacing: -0.03em; line-height: 1; background: linear-gradient(135deg, #9bd8ff, var(--bd-accent)); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent; }
	.bd-number span { display: block; margin-top: 0.45rem; font-size: 0.82rem; color: rgba(245, 245, 247, 0.62); }

	/* ── Hero ── */
	.pf-hero { position: relative; overflow: hidden; margin: calc(-1 * clamp(2.5rem, 6vw, 4.5rem)) calc(-1 * clamp(1rem, 3vw, 2rem)) clamp(2rem, 4vw, 3rem); padding: clamp(3rem, 7vw, 5.5rem) clamp(1.75rem, 5vw, 5rem) clamp(2.5rem, 5vw, 3.5rem); }
	.pf-hero-aurora { position: absolute; inset: -30% -10% auto; height: 100%; z-index: 0; pointer-events: none; background: radial-gradient(620px 440px at 22% 30%, rgba(34, 211, 238, 0.22), transparent 60%), radial-gradient(620px 460px at 82% 24%, rgba(139, 92, 246, 0.2), transparent 62%); filter: blur(54px); opacity: 0.6; animation: pf-aurora 18s ease-in-out infinite; }
	:global(html:not(.dark)) .pf-hero-aurora { opacity: 0.4; }
	@keyframes pf-aurora { 0%,100%{ transform: translate3d(0,0,0) scale(1); } 50%{ transform: translate3d(2%,-2%,0) scale(1.08); } }
	.pf-hero-grid { position: relative; z-index: 1; max-width: 94rem; margin-inline: auto; display: grid; gap: clamp(2rem, 4vw, 3.5rem); align-items: center; }
	@media (min-width: 940px) { .pf-hero-grid { grid-template-columns: 0.78fr 1.22fr; } }
	.pf-hero-copy { text-align: left; }
	.pf-h1 { max-width: 11ch; font-size: clamp(2.9rem, 7vw, 5.4rem); }
	.pf-hero-sub { margin: 0 0 1.6rem; }
	.pf-hero-links { justify-content: flex-start; }

	/* ── Shuffling card deck (big, scales with the screen) ── */
	.pf-deck { position: relative; display: grid; place-items: center; min-height: clamp(380px, 50vw, 880px); }
	.pf-deck-card { grid-area: 1 / 1; width: clamp(320px, 46vw, 840px); border-radius: 1.3rem; overflow: hidden; background: #0b0d16; border: 1px solid color-mix(in srgb, var(--c) 38%, var(--bd-glass-border)); box-shadow: 0 60px 130px -44px color-mix(in srgb, var(--c) 52%, rgba(0,0,0,0.9)); will-change: transform; cursor: grab; touch-action: pan-y; user-select: none; -webkit-user-select: none; transition: transform 0.55s cubic-bezier(0.22, 1, 0.36, 1); }
	.pf-deck-card img { -webkit-user-drag: none; user-select: none; }
	:global(html:not(.dark)) .pf-deck-card { background: #f1f3f8; }
	.pf-deck-card.is-front { cursor: grab; }
	.pf-deck-card.is-dragging { cursor: grabbing; transition: none; }
	/* a subtle "swipe me" hint pinned to the deck */
	.pf-deck-hint { position: absolute; bottom: 0.2rem; left: 50%; transform: translateX(-50%); display: inline-flex; align-items: center; gap: 0.4rem; font-size: 0.72rem; font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase; color: var(--bd-muted); pointer-events: none; opacity: 0.75; z-index: 70; white-space: nowrap; }
	/* "Swipe" on touch, "Drag" on mouse — the gesture works on both now */
	.pf-hint-mouse { display: none; }
	@media (pointer: fine) { .pf-hint-touch { display: none; } .pf-hint-mouse { display: inline; } }
	.pf-deck-bar { display: flex; align-items: center; gap: 0.4rem; padding: 0.6rem 0.85rem; background: color-mix(in srgb, var(--bd-ink) 8%, #11131c); }
	:global(html:not(.dark)) .pf-deck-bar { background: #e6eaf2; }
	.pf-deck-bar i { width: 9px; height: 9px; border-radius: 50%; }
	.pf-deck-bar i:first-child { background: #ff5f57; } .pf-deck-bar i:nth-child(2) { background: #febc2e; } .pf-deck-bar i:nth-child(3) { background: #28c840; }
	.pf-deck-card img { display: block; width: 100%; aspect-ratio: 16 / 9; object-fit: cover; object-position: top; }
	@keyframes pf-deal {
		0%   { transform: translate(0, 0) rotate(-3deg) scale(1);             z-index: 50; }
		6%   { transform: translate(-92px, -108px) rotate(-13deg) scale(1.05); z-index: 60; }
		13%  { transform: translate(84px, 84px) rotate(11deg) scale(0.85);    z-index: 10; }
		20%  { transform: translate(84px, 84px) rotate(11deg) scale(0.85);    z-index: 10; }
		40%  { transform: translate(61px, 61px) rotate(7deg) scale(0.895);    z-index: 20; }
		60%  { transform: translate(40px, 40px) rotate(4deg) scale(0.935);    z-index: 30; }
		80%  { transform: translate(20px, 20px) rotate(0.5deg) scale(0.975);  z-index: 40; }
		100% { transform: translate(0, 0) rotate(-3deg) scale(1);             z-index: 50; }
	}
	@media (max-width: 939px) { .pf-deck { margin-top: 1rem; min-height: clamp(300px, 76vw, 460px); padding-bottom: 2.4rem; } .pf-deck-hint { bottom: 0.4rem; } }

	/* ── Full-bleed scrolling wall (two rows, opposite ways, zoom) ── */
	.pf-wall { position: relative; margin: clamp(1rem, 3vw, 2.5rem) calc(-1 * clamp(1rem, 3vw, 2rem)) clamp(1rem, 3vw, 2rem); }
	.pf-wall-head { text-align: center; font-size: 0.78rem; font-weight: 800; letter-spacing: 0.16em; text-transform: uppercase; color: var(--bd-muted); margin: 0 0 1.2rem; }
	.pf-marquee { position: relative; z-index: 1; display: grid; gap: clamp(0.7rem, 1.6vw, 1.1rem); overflow: hidden; -webkit-mask-image: linear-gradient(90deg, transparent, #000 5%, #000 95%, transparent); mask-image: linear-gradient(90deg, transparent, #000 5%, #000 95%, transparent); }
	.pf-marquee-track { display: flex; gap: clamp(0.7rem, 1.6vw, 1.1rem); width: max-content; animation: pf-drift 60s linear infinite; }
	.pf-marquee-track--rev { animation: pf-drift-rev 78s linear infinite; }
	.pf-marquee:hover .pf-marquee-track { animation-play-state: paused; }
	@keyframes pf-drift { to { transform: translateX(-50%); } }
	@keyframes pf-drift-rev { from { transform: translateX(-50%); } to { transform: translateX(0); } }
	.pf-thumb { display: block; flex-shrink: 0; width: clamp(210px, 23vw, 320px); aspect-ratio: 16 / 10; border-radius: 0.9rem; overflow: hidden; border: 1px solid color-mix(in srgb, var(--c) 36%, var(--bd-glass-border)); box-shadow: 0 24px 50px -28px color-mix(in srgb, var(--c) 44%, rgba(0,0,0,0.8)); background: color-mix(in srgb, var(--c) 16%, var(--bd-glass-border)); transition: transform 0.5s cubic-bezier(0.22,1,0.36,1), box-shadow 0.5s ease; }
	.pf-thumb img { width: 100%; height: 100%; object-fit: cover; object-position: top; transition: transform 6s ease; }
	.pf-thumb:hover { transform: scale(1.08); box-shadow: 0 34px 70px -28px color-mix(in srgb, var(--c) 55%, rgba(0,0,0,0.85)); z-index: 2; }
	.pf-thumb:hover img { transform: scale(1.12); }

	/* ── Browser-framed screenshot (shared) ── */
	.pf-shot { position: relative; display: block; border-radius: 1.1rem; overflow: hidden; background: #0b0d16; border: 1px solid color-mix(in srgb, var(--c) 30%, var(--bd-glass-border)); box-shadow: var(--bd-shadow); }
	.pf-bar { display: flex; align-items: center; gap: 0.4rem; padding: 0.55rem 0.8rem; background: color-mix(in srgb, var(--bd-ink) 8%, #11131c); border-bottom: 1px solid var(--bd-glass-border); }
	.pf-bar i { width: 9px; height: 9px; border-radius: 50%; background: rgba(255,255,255,0.25); }
	.pf-bar i:first-child { background: #ff5f57; } .pf-bar i:nth-child(2) { background: #febc2e; } .pf-bar i:nth-child(3) { background: #28c840; }
	.pf-url { margin-left: 0.5rem; font-size: 0.72rem; font-weight: 600; color: color-mix(in srgb, var(--bd-ink) 60%, transparent); font-family: ui-monospace, 'SF Mono', Menlo, monospace; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
	:global(html:not(.dark)) .pf-bar { background: #f1f3f8; }
	:global(html:not(.dark)) .pf-shot { background: #f1f3f8; }
	.pf-img { display: block; aspect-ratio: 16 / 10; overflow: hidden; }
	.pf-img img { width: 100%; height: 100%; object-fit: cover; object-position: top; transition: transform 0.7s cubic-bezier(0.22, 1, 0.36, 1); }
	.pf-open { position: absolute; top: 0.6rem; right: 0.6rem; display: grid; place-items: center; width: 32px; height: 32px; border-radius: 9999px; color: #fff; background: color-mix(in srgb, var(--c) 82%, transparent); opacity: 0; transform: translate(4px, -4px); transition: opacity 0.3s ease, transform 0.3s ease; }
	.pf-badge { position: absolute; top: 0.6rem; left: 0.6rem; font-size: 0.66rem; font-weight: 800; letter-spacing: 0.08em; text-transform: uppercase; padding: 0.28rem 0.6rem; border-radius: 9999px; color: #fff; background: color-mix(in srgb, var(--c) 85%, transparent); box-shadow: 0 6px 16px -6px color-mix(in srgb, var(--c) 70%, transparent); }
	.pf-shot--app .pf-img { background: radial-gradient(130% 130% at 50% 0%, color-mix(in srgb, var(--c) 22%, #0b0d16), #0b0d16); }
	:global(html:not(.dark)) .pf-shot--app .pf-img { background: radial-gradient(130% 130% at 50% 0%, color-mix(in srgb, var(--c) 18%, #eef2f7), #eef2f7); }
	.pf-shot--app .pf-img img { object-fit: contain; object-position: center; padding: 0.5rem; }

	/* ── Featured rows ── */
	.pf-feats { position: relative; max-width: 82rem; margin: 0 auto; display: grid; gap: clamp(2.5rem, 6vw, 4.5rem); }
	.pf-feats::before { content: ''; position: absolute; inset: -10% -14%; z-index: -1; pointer-events: none; background: radial-gradient(620px 420px at 8% 8%, rgba(34, 211, 238, 0.18), transparent 60%), radial-gradient(620px 420px at 92% 55%, rgba(139, 92, 246, 0.18), transparent 60%), radial-gradient(520px 420px at 50% 100%, color-mix(in srgb, var(--bd-accent) 22%, transparent), transparent 62%); filter: blur(60px); opacity: 0.85; animation: pf-bg-float 22s ease-in-out infinite reverse; }
	:global(html:not(.dark)) .pf-feats::before { opacity: 0.5; }
	.pf-feat { position: relative; display: grid; gap: clamp(1.5rem, 4vw, 3rem); align-items: center; padding: clamp(1.25rem, 4vw, 2.4rem); border-radius: 1.7rem; background: var(--bd-glass); border: 1px solid var(--bd-glass-border); box-shadow: var(--bd-shadow); overflow: hidden; transition: border-color 0.35s ease, transform 0.35s ease; }
	.pf-feat::before { content: ''; position: absolute; inset: 0 0 auto 0; height: 3px; background: linear-gradient(90deg, transparent, var(--c), transparent); opacity: 0.7; }
	.pf-feat:hover { border-color: color-mix(in srgb, var(--c) 38%, var(--bd-glass-border)); }
	@media (min-width: 900px) { .pf-feat { grid-template-columns: 1.05fr 0.95fr; } .pf-feat--rev .pf-shot--lg { order: 2; } }
	/* Break the "every card identical / AI-ish" feel: alternate the accent sheen
	   side, and on mobile alternate whether the copy or the mockup leads. */
	.pf-feat:nth-child(even)::before { background: linear-gradient(90deg, var(--c), transparent 72%); }
	.pf-feat:nth-child(odd)::before { background: linear-gradient(90deg, transparent 28%, var(--c)); }
	@media (max-width: 899px) {
		.pf-feat { gap: 1.2rem; padding: 1.1rem 1.1rem 1.3rem; }
		.pf-feat--rev .pf-feat-body { order: -1; }
		.pf-feat-name { font-size: clamp(1.55rem, 6.5vw, 2rem); margin-bottom: 0.4rem; }
		.pf-feat-tagline { font-size: 1rem; }
		.pf-feat-blurb { display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; margin-bottom: 0.95rem; }
	}
	.pf-shot--lg { transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.4s ease; }
	.pf-shot--lg:hover { transform: translateY(-6px); box-shadow: 0 50px 100px -40px color-mix(in srgb, var(--c) 45%, rgba(0,0,0,0.85)); }
	.pf-shot--lg:hover .pf-img img { transform: scale(1.04); }
	.pf-shot--lg:hover .pf-open { opacity: 1; transform: translate(0, 0); }
	.pf-feat-eyebrow { display: inline-block; font-size: 0.74rem; font-weight: 800; letter-spacing: 0.12em; text-transform: uppercase; color: var(--c); margin-bottom: 0.7rem; }
	.pf-feat-name { font-size: clamp(1.7rem, 3.4vw, 2.5rem); font-weight: 700; letter-spacing: -0.02em; line-height: 1.06; margin: 0 0 0.5rem; }
	.pf-feat-tagline { font-size: 1.08rem; font-weight: 600; color: color-mix(in srgb, var(--c) 72%, var(--bd-ink)); margin: 0 0 0.8rem; }
	.pf-feat-blurb { font-size: 0.98rem; line-height: 1.6; color: var(--bd-muted); margin: 0 0 1.1rem; max-width: 34rem; }
	.pf-feat-cta { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.7rem 1.4rem; border-radius: 9999px; font-size: 0.95rem; font-weight: 700; color: #fff; background: linear-gradient(180deg, color-mix(in srgb, var(--c) 88%, #fff), var(--c)); box-shadow: 0 14px 30px -12px color-mix(in srgb, var(--c) 70%, transparent); transition: transform 0.25s ease, gap 0.25s ease; }
	.pf-feat-cta:hover { transform: translateY(-2px); gap: 0.7rem; }

	/* ── Tag pills (shared) ── */
	.pf-tags { list-style: none; display: flex; flex-wrap: wrap; gap: 0.45rem; padding: 0; margin: 0 0 1.2rem; }
	.pf-tags li { font-size: 0.76rem; font-weight: 600; padding: 0.3rem 0.7rem; border-radius: 9999px; color: color-mix(in srgb, var(--c) 80%, var(--bd-ink)); background: color-mix(in srgb, var(--c) 12%, transparent); border: 1px solid color-mix(in srgb, var(--c) 26%, transparent); }

	/* ── Showreel ── */
	.pf-reel { max-width: 80rem; margin: clamp(3rem, 7vw, 5rem) auto; }
	.pf-reel-grid { display: grid; gap: clamp(1.5rem, 3vw, 2.75rem); align-items: center; }
	@media (min-width: 860px) { .pf-reel-grid { grid-template-columns: 0.8fr 1.2fr; } }
	.pf-reel-copy .bd-h { margin: 0.3rem 0 0.6rem; }
	.pf-reel-copy .bd-p { margin: 0 0 1.2rem; max-width: 26rem; }
	.pf-reel-frame { position: relative; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 0.5rem; aspect-ratio: 16 / 9; border-radius: 1.75rem; overflow: hidden; cursor: pointer; border: 1.5px dashed color-mix(in srgb, var(--bd-accent) 38%, transparent); background: radial-gradient(700px 320px at 50% 0%, color-mix(in srgb, var(--bd-accent) 18%, transparent), transparent 65%), linear-gradient(180deg, rgba(18, 22, 42, 0.7), rgba(5, 6, 13, 0.85)); color: var(--bd-muted); box-shadow: var(--bd-shadow); }
	:global(html:not(.dark)) .pf-reel-frame { background: radial-gradient(700px 320px at 50% 0%, color-mix(in srgb, var(--bd-accent) 14%, transparent), transparent 65%), linear-gradient(180deg, rgba(255, 255, 255, 0.72), rgba(255, 255, 255, 0.44)); }
	.pf-reel-grid-lines { position: absolute; inset: 0; pointer-events: none; opacity: 0.5; background-image: linear-gradient(color-mix(in srgb, var(--bd-accent) 12%, transparent) 1px, transparent 1px), linear-gradient(90deg, color-mix(in srgb, var(--bd-accent) 12%, transparent) 1px, transparent 1px); background-size: 42px 42px; -webkit-mask-image: radial-gradient(closest-side at 50% 45%, #000, transparent); mask-image: radial-gradient(closest-side at 50% 45%, #000, transparent); }
	.pf-reel-sheen { position: absolute; inset: 0; background: linear-gradient(115deg, transparent 35%, rgba(255, 255, 255, 0.06) 50%, transparent 64%); transform: translateX(-100%); animation: pf-sheen 6s ease-in-out infinite; pointer-events: none; }
	@keyframes pf-sheen { 0%, 55% { transform: translateX(-100%); } 85%, 100% { transform: translateX(100%); } }
	.pf-reel-play { position: relative; display: grid; place-items: center; width: 78px; height: 78px; border-radius: 9999px; cursor: pointer; color: #fff; background: linear-gradient(180deg, color-mix(in srgb, var(--bd-accent) 90%, #fff), var(--bd-accent)); border: 1px solid color-mix(in srgb, var(--bd-accent) 60%, rgba(255, 255, 255, 0.4)); box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.35), 0 20px 44px -14px color-mix(in srgb, var(--bd-accent) 70%, transparent); transition: transform 0.25s ease; margin-bottom: 0.3rem; }
	.pf-reel-play::after { content: ''; position: absolute; inset: -10px; border-radius: 9999px; border: 1.5px solid color-mix(in srgb, var(--bd-accent) 45%, transparent); animation: pf-ping 2.6s ease-out infinite; }
	@keyframes pf-ping { 0%{ transform: scale(0.85); opacity: 0.8; } 100%{ transform: scale(1.5); opacity: 0; } }
	.pf-reel-frame:hover .pf-reel-play { transform: scale(1.08); }
	.pf-reel-label { position: relative; font-size: 0.76rem; font-weight: 800; letter-spacing: 0.12em; text-transform: uppercase; }

	/* ── Magazines ── */
	.pf-mags { max-width: 72rem; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: clamp(1rem, 2.5vw, 1.6rem); }
	@media (max-width: 720px) { .pf-mags { grid-template-columns: 1fr; } }
	.pf-mag { display: flex; gap: clamp(1rem, 2.5vw, 1.5rem); padding: clamp(1.1rem, 2.5vw, 1.5rem); border-radius: 1.4rem; background: var(--bd-glass); border: 1px solid var(--bd-glass-border); box-shadow: var(--bd-shadow); backdrop-filter: blur(18px); -webkit-backdrop-filter: blur(18px); transition: transform 0.35s ease, border-color 0.35s ease; }
	.pf-mag:hover { transform: translateY(-5px); border-color: color-mix(in srgb, var(--bd-accent) 45%, var(--bd-glass-border)); }
	.pf-mag-cover { flex-shrink: 0; width: clamp(96px, 22vw, 132px); border-radius: 0.7rem; overflow: hidden; box-shadow: 0 18px 40px -18px rgba(0,0,0,0.7); align-self: flex-start; }
	.pf-mag-cover img { width: 100%; height: 100%; object-fit: cover; display: block; }
	.pf-mag-meta { display: flex; flex-direction: column; gap: 0.3rem; min-width: 0; }
	.pf-mag-tag { font-size: 0.7rem; font-weight: 800; letter-spacing: 0.1em; text-transform: uppercase; color: var(--bd-accent); }
	.pf-mag-meta strong { font-size: 1.3rem; font-weight: 700; letter-spacing: -0.01em; }
	.pf-mag-meta em { font-style: normal; font-size: 0.9rem; line-height: 1.5; color: var(--bd-muted); }
	.pf-mag-dl { margin-top: auto; display: inline-flex; align-items: center; gap: 0.35rem; font-size: 0.86rem; font-weight: 700; color: var(--bd-accent); padding-top: 0.6rem; }
	.pf-mag--latest { background: radial-gradient(420px 220px at 90% 0%, color-mix(in srgb, var(--bd-accent) 16%, transparent), transparent 65%), var(--bd-glass); border-color: color-mix(in srgb, var(--bd-accent) 28%, var(--bd-glass-border)); }

	/* ── Filter (pure CSS via radios) ── */
	.pf-filter { max-width: 84rem; margin: 0 auto; }
	.pf-radio { position: absolute; opacity: 0; pointer-events: none; width: 0; height: 0; }
	.pf-chips { display: flex; flex-wrap: wrap; justify-content: center; gap: 0.6rem; margin-bottom: clamp(1.5rem, 3vw, 2.25rem); padding: clamp(0.9rem, 2vw, 1.3rem); border-radius: 1.5rem; background: color-mix(in srgb, var(--bd-accent) 6%, var(--bd-glass)); border: 1px solid color-mix(in srgb, var(--bd-accent) 18%, var(--bd-glass-border)); box-shadow: var(--bd-shadow); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); max-width: 64rem; margin-inline: auto; }
	.pf-chip { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.62rem 1.15rem; border-radius: 9999px; font-size: 0.95rem; font-weight: 700; color: var(--bd-ink); background: var(--bd-glass); border: 1.5px solid color-mix(in srgb, var(--bd-ink) 16%, var(--bd-glass-border)); cursor: pointer; transition: transform 0.2s ease, border-color 0.25s ease, background 0.25s ease, color 0.25s ease, box-shadow 0.25s ease; }
	.pf-chip span { font-size: 0.74rem; font-weight: 800; padding: 0.08rem 0.5rem; border-radius: 9999px; color: var(--bd-accent); background: color-mix(in srgb, var(--bd-accent) 16%, transparent); }
	:global(html:not(.dark)) .pf-chip span { color: #1577b8; background: color-mix(in srgb, #1577b8 16%, transparent); }
	.pf-chip:hover { transform: translateY(-2px); border-color: color-mix(in srgb, var(--bd-accent) 55%, var(--bd-glass-border)); box-shadow: 0 12px 26px -14px color-mix(in srgb, var(--bd-accent) 50%, transparent); }
	.pf-chip--all { border-color: color-mix(in srgb, var(--bd-accent) 40%, transparent); }
	/* On phones, 7 stacked chips ate the screen — make it one compact, swipeable
	   row that scrolls horizontally (fades at the right edge to hint there's more). */
	@media (max-width: 760px) {
		.pf-chips { flex-wrap: nowrap; justify-content: flex-start; overflow-x: auto; gap: 0.45rem; padding: 0.7rem; scrollbar-width: none; -webkit-overflow-scrolling: touch; -webkit-mask-image: linear-gradient(90deg, #000 86%, transparent); mask-image: linear-gradient(90deg, #000 86%, transparent); }
		.pf-chips::-webkit-scrollbar { display: none; }
		.pf-chip { flex-shrink: 0; padding: 0.5rem 0.9rem; font-size: 0.85rem; }
		.pf-chip span { font-size: 0.68rem; }
	}

	#pf-all:checked ~ .pf-chips label[for='pf-all'],
