---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import ToastContainer from '../components/elements/ToastContainer.astro';
import ViewOnboarding from '../components/ViewOnboarding.astro';

export interface Props {
	title?: string;
	description?: string;
	image?: string;
	/** Pages that ship their own footer (e.g. About) suppress the global one. */
	hideFooter?: boolean;
}

const {
	title = SITE_TITLE,
	description = SITE_DESCRIPTION,
	image,
	hideFooter = false,
} = Astro.props;
---

<!DOCTYPE html>
{
/* prettier-ignore */
}
<html lang="en">
	<head>
		<BaseHead title={title} description={description} image={image} />
	</head>
	<body class="leading-loose">
		<script is:inline type="text/javascript">
		var Tawk_API = Tawk_API || {},
			Tawk_LoadStart = new Date();
		// We drive Tawk from our own compact icon launcher (#swizel-chat-fab) so the
		// chat is a clean bubble that never covers content. Hide Tawk's own widget on
		// load, and re-hide it whenever the chat is minimised so only our FAB shows.
		Tawk_API.onLoad = function () {
			if (Tawk_API.hideWidget) Tawk_API.hideWidget();
		};
		Tawk_API.onChatMinimized = function () {
			if (Tawk_API.hideWidget) Tawk_API.hideWidget();
		};
		(function () {
			var s1 = document.createElement('script'),
				s0 = document.getElementsByTagName('script')[0];
			s1.async = true;
			s1.src = 'https://embed.tawk.to/6415ce6d31ebfa0fe7f359e9/1grqisntk';
			s1.charset = 'UTF-8';
			s1.setAttribute('crossorigin', '*');
			s0.parentNode.insertBefore(s1, s0);
		})();
		</script>
		<main id="swup" class="transition-main">
			<Header />
			<slot />
			{!hideFooter && <Footer />}
			<ToastContainer />
			<ViewOnboarding />
		</main>
		<button id="back-to-top" type="button" aria-label="Back to top">
			<svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 19V5M5 12l7-7 7 7"/></svg>
		</button>
		<button id="swizel-chat-fab" type="button" aria-label="Open live chat" title="Chat with us">
			<svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
			<span class="chat-fab-dot" aria-hidden="true"></span>
		</button>
		<div id="swizel-cursor" aria-hidden="true">
			<svg class="cur-builder" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="8 7 3 12 8 17"></polyline><polyline points="16 7 21 12 16 17"></polyline><line x1="14.5" y1="5" x2="9.5" y2="19"></line></svg>
			<svg class="cur-founder" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2c2.5 2.2 4 5.5 4 9 0 1.6-.4 3.2-1 4.6L12 18l-3-2.4C8.4 14.2 8 12.6 8 11c0-3.5 1.5-6.8 4-9z"></path><circle cx="12" cy="9.5" r="1.3" fill="#0b0d18"></circle><path d="M8.6 15.2 6.5 19l3-1M15.4 15.2 17.5 19l-3-1" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"></path></svg>
			<svg class="cur-campus" viewBox="0 0 24 24" fill="currentColor"><path d="M12 4 23 9l-11 5L1 9z"></path><path d="M5 11.5V15c0 1.6 3.1 3 7 3s7-1.4 7-3v-3.5" fill="none" stroke="currentColor" stroke-width="1.7"></path><path d="M23 9v3.5" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"></path></svg>
			<svg class="cur-studio" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21l4-1 11-11-3-3L4 17z"></path><path d="M14 6l3 3"></path></svg>
			<svg class="cur-boardroom" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="8" width="18" height="11" rx="2"></rect><path d="M8 8V6a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><line x1="3" y1="13" x2="21" y2="13"></line><rect x="10.5" y="11.5" width="3" height="3" rx="0.6"></rect></svg>
			<svg class="cur-chart" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 17 9 11 13 14 21 6"></polyline><polyline points="15 6 21 6 21 12"></polyline></svg>
			<svg class="cur-clock" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="9"></circle><path d="M12 7v5l3.5 2"></path></svg>
			<svg class="cur-shield" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l8 3v5c0 5-3.4 8.4-8 10-4.6-1.6-8-5-8-10V6z"></path><path d="M9 12l2.2 2.2L15.5 10"></path></svg>
			<svg class="cur-layers" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l9 5-9 5-9-5z"></path><path d="M3 13l9 5 9-5"></path></svg>
			<svg class="cur-pulse" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12h4l2.5-6 4 12 2.5-6h7"></path></svg>
			<svg class="cur-quote" viewBox="0 0 24 24" fill="currentColor"><path d="M10 7H6a3 3 0 0 0-3 3v7h7v-7H6.5A1.5 1.5 0 0 1 8 8.5h2zM21 7h-4a3 3 0 0 0-3 3v7h7v-7h-3.5A1.5 1.5 0 0 1 19 8.5h2z"></path></svg>
			<svg class="cur-play" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"></circle><path d="M10 8.5l6 3.5-6 3.5z" fill="currentColor" stroke="none"></path></svg>
			<svg class="cur-phone" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 4h4l2 5-2.5 1.5a12 12 0 0 0 5 5L15 13l5 2v4a2 2 0 0 1-2 2A16 16 0 0 1 3 6a2 2 0 0 1 2-2z"></path></svg>
			<svg class="cur-book" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 6c-1.5-1.6-3.8-2.2-7-2v14c3.2-.2 5.5.4 7 2 1.5-1.6 3.8-2.2 7-2V4c-3.2-.2-5.5.4-7 2z"></path><path d="M12 6v14"></path></svg>
			<svg class="cur-pen" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 20l1.2-4.2L16.4 4.6a2 2 0 0 1 2.8 0l.2.2a2 2 0 0 1 0 2.8L8.2 18.8z"></path><path d="M14.5 6.5l3 3"></path></svg>
			<svg class="cur-palette" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a9 9 0 0 0 0 18c1 0 1.7-.8 1.7-1.8 0-.5-.2-.9-.5-1.2-.3-.3-.5-.7-.5-1.2 0-1 .8-1.8 1.8-1.8H16a5 5 0 0 0 5-5c0-3.9-4-7-9-7z"></path><circle cx="7.5" cy="11.5" r="1" fill="currentColor"></circle><circle cx="10" cy="7.5" r="1" fill="currentColor"></circle><circle cx="15" cy="7.5" r="1" fill="currentColor"></circle><circle cx="17.5" cy="11.5" r="1" fill="currentColor"></circle></svg>
			<svg class="cur-vector" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="4" height="4"></rect><rect x="17" y="3" width="4" height="4"></rect><rect x="3" y="17" width="4" height="4"></rect><rect x="17" y="17" width="4" height="4"></rect><path d="M7 5h10M5 7v10M19 7v10M7 19h10" opacity="0.5"></path></svg>
			<svg class="cur-legacy" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.2 6.8L21 11l-6.8 2.2L12 20l-2.2-6.8L3 11l6.8-2.2z"></path></svg>
			<svg class="cur-term" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"><polyline points="5 8 9 12 5 16"></polyline><line x1="11.5" y1="16" x2="18" y2="16"></line></svg>
			<svg class="cur-pkg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 8l-9-5-9 5v8l9 5 9-5z"></path><path d="M3 8l9 5 9-5M12 13v8"></path></svg>
			<svg class="cur-branch" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round"><circle cx="6.5" cy="6" r="2.3"></circle><circle cx="6.5" cy="18" r="2.3"></circle><circle cx="17.5" cy="8" r="2.3"></circle><path d="M6.5 8.3v7.4M9.6 7.2c5 .6 7.9 2.6 7.9 7.3"></path></svg>
			<svg class="cur-repo" viewBox="0 0 24 24" fill="currentColor"><path d="M12 3l2.7 5.5 6 .9-4.3 4.2 1 6L12 16.9 6.6 19.6l1-6L3.3 9.4l6-.9z"></path></svg>
		</div>
	</body>
</html>

<script>
	import Swup from 'swup';
	import SwupA11yPlugin from '@swup/a11y-plugin';
	import SwupHeadPlugin from '@swup/head-plugin';
	import Splide from '@splidejs/splide';
	import SwupScrollPlugin from '@swup/scroll-plugin';
	import { initFlowbite } from 'flowbite';
	import toaster from '../scripts/toast';

	import { isTrue, teamDetails } from '../consts';

	import { handleDropDown } from '../scripts/handleDropDown';
	import { initViewExperience } from '../scripts/viewExperience';
	import { initViewBanner } from '../scripts/viewBanner';
	import { initBuilderView } from '../scripts/builderView';
	import { initBuilderBody } from '../scripts/builderBody';
	import { initFounderBody } from '../scripts/founderBody';
	import { initCampusBody } from '../scripts/campusBody';
	import { initStudioBody } from '../scripts/studioBody';
	import { initBoardroomBody } from '../scripts/boardroomBody';
	import { initFounderView } from '../scripts/founderView';
	import { initCampusView } from '../scripts/campusView';
	import { initStudioView } from '../scripts/studioView';
	import { initBoardroomView } from '../scripts/boardroomView';
	import { initLegacyView } from '../scripts/legacyView';

	const handleMenuToggle = () => {
		const menuWrapper = document.querySelector<HTMLElement>('#mobile-wrapper');
		const wrapperOverlay = document.querySelector<HTMLElement>('#close-overlay');

		const showBtn = document.querySelector<HTMLButtonElement>('#toggler-show');
		const hideBtn = document.querySelector<HTMLButtonElement>('#toggler-hide');

		const toggleMenu = (state: 'true' | 'false') => {
			if (menuWrapper) {
				menuWrapper.dataset.expanded = state;
			}
			document.body.style.overflow = state === 'true' ? 'hidden' : '';
		};

		if (showBtn) {
			showBtn.onclick = () => toggleMenu('true');
		}

		if (hideBtn) {
			hideBtn.onclick = () => toggleMenu('false');
		}

		if (wrapperOverlay) {
			wrapperOverlay.onclick = () => toggleMenu('false');
		}

		// Close the drawer when a destination link is tapped (the Services
		// accordion summary is excluded so it can expand in place).
		const menu = document.getElementById('mobile-menu');
		if (menu) {
			menu.addEventListener('click', (e) => {
				const a = (e.target as HTMLElement).closest('a[href]');
				if (a) toggleMenu('false');
			});
		}
		document.addEventListener('keydown', (e) => {
			if (e.key === 'Escape' && menuWrapper?.dataset.expanded === 'true') toggleMenu('false');
		});
	};

	const handleTeamDialog = () => {
		const teamMatesMember = document.querySelectorAll<HTMLLIElement>('.teammate-member');

		const dialogModal = document.querySelector<HTMLDialogElement>('#member-dialog');

		const dialogCloseBtn = document.getElementById('close-team-dialog') as HTMLButtonElement;

		const dialogContent = document.getElementById('team-dialog--content') as HTMLDivElement;

		// using typecasting because null checks would be verbose
		const memberImage = document.getElementById('dialog--image') as HTMLImageElement;

		const memberRole = document.getElementById('teammate--role') as HTMLParagraphElement;

		const memberBio = document.getElementById('teammate--bio') as HTMLParagraphElement;

		const memberExperienceList = document.getElementById(
			'teammate--experience'
		) as HTMLUListElement;

		const memberName = document.getElementById('teammate--name') as HTMLHeadingElement;
		const memberLinkedin = document.getElementById('teammate--linkedin') as HTMLLinkElement;

		const writeExperienceItem = (company: string, jobDesc: string) => `
		<div class="space-y-2 astro-7KIUVPD3">
			<h4 class="text-xl font-bold text-darker leading-tight">
				${company}
			</h4>
			<p class="astro-7KIUVPD3">${jobDesc}</p>
		</div>`;

		teamMatesMember.forEach((member) => {
			member.onclick = () => {
				const { membername } = member.dataset;

				const selectedMember = teamDetails.find(({ name }) => name === membername);

				if (dialogModal && selectedMember) {
					// open modal
					dialogModal.showModal();

					// remove initial focus when dialog is open: https://stackoverflow.com/a/61855683
					dialogCloseBtn.blur();

					const { bio, experience, linkedinURL, name, role } = selectedMember;

					// insert content into the dom
					memberImage.src = `/teammates/${membername}.jpg`;
					memberRole.textContent = role;
					memberBio.textContent = bio;
					memberName.textContent = name;
					memberLinkedin.href = linkedinURL;

					memberExperienceList.innerHTML = experience
						.map(({ company, jobDesc }) => writeExperienceItem(company, jobDesc))
						.join('');
				} else {
					throw new Error('Please check dialog and member details');
				}
			};
		});

		dialogCloseBtn.onclick = () => {
			dialogModal!.close(); // using nullish operator because the element already exists
		};

		// using this to make sure that onclick outside of the dialog, it closes the modal cc: https://stackoverflow.com/a/73988585
		if (dialogModal) {
			dialogModal.onclick = (_e) => dialogModal.close();
		}

		if (dialogContent) {
			dialogContent.onclick = (e) => e.stopPropagation();
		}
	};

	const setThemeToggleState = () => {
		const isDark = document.documentElement.classList.contains('dark');
		document
			.querySelectorAll<HTMLButtonElement>('[data-theme-toggle]')
			.forEach((btn) => btn.setAttribute('aria-checked', String(isDark)));
	};

	const handleThemeToggle = () => {
		const toggles = document.querySelectorAll<HTMLButtonElement>(
			'[data-theme-toggle]'
		);
		setThemeToggleState();
		toggles.forEach((btn) => {
			btn.onclick = () => {
				const isDark =
					document.documentElement.classList.toggle('dark');
				try {
					localStorage.setItem('theme', isDark ? 'dark' : 'light');
				} catch (e) {}
				setThemeToggleState();
			};
		});
	};

	const handleHero = () => {
		const hero = document.querySelector<HTMLElement>('.hero--stage');
		if (!hero) return;

		// Animated stat counters
		const counters =
			hero.querySelectorAll<HTMLElement>('[data-count-to]');
		if (counters.length) {
			const runCount = (el: HTMLElement) => {
				const target = Number(el.dataset.countTo || '0');
				const suffix = el.dataset.suffix || '';
				const dur = 1400;
				const start = performance.now();
				const tick = (now: number) => {
					const p = Math.min((now - start) / dur, 1);
					const eased = 1 - Math.pow(1 - p, 3);
					el.textContent = Math.round(target * eased) + suffix;
					if (p < 1) requestAnimationFrame(tick);
				};
				requestAnimationFrame(tick);
			};
			const io = new IntersectionObserver(
				(entries) => {
					entries.forEach((e) => {
						if (e.isIntersecting) {
							runCount(e.target as HTMLElement);
							io.unobserve(e.target);
						}
					});
				},
				{ threshold: 0.6 }
			);
			counters.forEach((c) => io.observe(c));
		}

		const reduce = window.matchMedia(
			'(prefers-reduced-motion: reduce)'
		).matches;

		// 3D tilt + cursor spotlight on the team photo
		const card = hero.querySelector<HTMLElement>('#hero-tilt');
		const inner = card?.querySelector<HTMLElement>('.hero--photo-inner');
		const spot = card?.querySelector<HTMLElement>('.hero--photo-spot');
		if (card && !reduce) {
			const max = 7;
			card.addEventListener('pointermove', (ev) => {
				const r = card.getBoundingClientRect();
				const px = (ev.clientX - r.left) / r.width;
				const py = (ev.clientY - r.top) / r.height;
				card.style.transform = `perspective(1100px) rotateY(${
					(px - 0.5) * max
				}deg) rotateX(${(0.5 - py) * max}deg)`;
				if (spot) {
					spot.style.setProperty('--mx', `${px * 100}%`);
					spot.style.setProperty('--my', `${py * 100}%`);
				}
			});
			card.addEventListener('pointerleave', () => {
				card.style.transform =
					'perspective(1100px) rotateY(0) rotateX(0)';
			});
		}

		// Auto-cycling highlight across the industry chips
		const sectorWrap = hero.querySelector<HTMLElement>('#hero-sectors');
		if (sectorWrap && !reduce) {
			const chips = Array.from(
				sectorWrap.querySelectorAll<HTMLElement>(
					'.hero--sector:not(.hero--sector-more)'
				)
			);
			let idx = 0;
			let hovering = false;
			sectorWrap.addEventListener('pointerenter', () => (hovering = true));
			sectorWrap.addEventListener('pointerleave', () => (hovering = false));
			window.setInterval(() => {
				if (hovering || !chips.length) return;
				chips.forEach((c) => c.classList.remove('is-active'));
				chips[idx % chips.length].classList.add('is-active');
				idx++;
			}, 1400);
		}
	};

	const handleFooter = () => {
		const clocks = document.querySelectorAll<HTMLElement>('.ft-clock');
		if (clocks.length) {
			const tick = () => {
				clocks.forEach((c) => {
					const tz = c.dataset.tz;
					const t = c.querySelector('.ft-clock-time');
					if (tz && t) {
						try {
							t.textContent = new Intl.DateTimeFormat('en-GB', {
								timeZone: tz,
								hour: '2-digit',
								minute: '2-digit',
							}).format(new Date());
						} catch (e) {}
					}
				});
			};
			tick();
			const w = window as any;
			if (w.__swizelClock) clearInterval(w.__swizelClock);
			w.__swizelClock = window.setInterval(tick, 1000);
		}
		const nf = document.getElementById('footer-newsletter') as HTMLFormElement | null;
		if (nf) {
			nf.onsubmit = (e) => {
				e.preventDefault();
				const msg = document.getElementById('footer-news-msg');
				if (msg) msg.textContent = 'Thanks! You are on the list.';
				nf.reset();
			};
		}
		const yr = document.getElementById('footer-year');
		if (yr) yr.textContent = new Date().getFullYear().toString();
	};

	// Portfolio hero deck — drag/swipe to shuffle, with ambient auto-advance.
	const initPortfolioDeck = () => {
		const deck = document.querySelector<HTMLElement>('.pf-deck');
		if (!deck || (deck as any).__deckInit) return;
		(deck as any).__deckInit = true;
		const cards = Array.from(deck.querySelectorAll<HTMLElement>('.pf-deck-card'));
		if (!cards.length) return;
		const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
		let order = cards.slice();
		const layout = () => {
			order.forEach((card, p) => {
				card.classList.toggle('is-front', p === 0);
				card.style.zIndex = String(60 - p * 10);
				card.style.transform = `translate(${p * 16}px, ${p * 16}px) rotate(${p * 3}deg) scale(${1 - p * 0.03})`;
				card.style.opacity = p > 3 ? '0' : '1';
				card.style.pointerEvents = p === 0 ? 'auto' : 'none';
			});
		};
		layout();
		const advance = () => { order.push(order.shift()!); layout(); };
		// elegant ambient deal: lift the top card, then let it settle to the back
		// while the rest glide forward — mirrors the original keyframe motion.
		const dealFront = () => {
			const f = order[0];
			f.style.zIndex = '70';
			f.style.transition = 'transform 0.5s cubic-bezier(0.45, 0, 0.2, 1)';
			f.style.transform = 'translate(-48px, -66px) rotate(-9deg) scale(1.05)';
			window.setTimeout(() => {
				if (dragging) return;
				f.style.transition = 'transform 0.66s cubic-bezier(0.22, 1, 0.36, 1)';
				advance();
			}, 540);
		};
		let timer = 0;
		const start = () => { if (!timer && !reduce) timer = window.setInterval(dealFront, 4200); };
		const stop = () => { if (timer) { clearInterval(timer); timer = 0; } };
		start();
		deck.addEventListener('pointerenter', stop);
		deck.addEventListener('pointerleave', start);

		let dragging = false, startX = 0, startY = 0, dx = 0, horiz = false;
		let front: HTMLElement | null = null;
		const onMove = (e: PointerEvent) => {
			if (!dragging || !front) return;
			dx = e.clientX - startX;
			const dy = e.clientY - startY;
			if (!horiz) {
				if (Math.abs(dy) > Math.abs(dx) && Math.abs(dy) > 10) { endDrag(true); return; }
				if (Math.abs(dx) > 6) horiz = true; else return;
			}
			if (e.cancelable) e.preventDefault();
			front.style.transform = `translate(${dx}px, ${Math.abs(dx) * 0.04}px) rotate(${dx * 0.04}deg) scale(1)`;
		};
		const endDrag = (cancel: boolean) => {
			if (!dragging || !front) return;
			dragging = false;
			window.removeEventListener('pointermove', onMove);
			window.removeEventListener('pointerup', onUp);
			front.classList.remove('is-dragging');
			if (!cancel && Math.abs(dx) > 80) {
				const dir = dx > 0 ? 1 : -1;
				front.style.transition = 'transform 0.3s ease';
				front.style.transform = `translate(${dir * 150}%, 0) rotate(${dir * 16}deg) scale(0.9)`;
				const f = front;
				window.setTimeout(() => { f.style.transition = ''; advance(); }, 220);
			} else {
				layout();
			}
			start();
		};
		const onUp = () => endDrag(false);
		deck.addEventListener('pointerdown', (e) => {
			front = order[0];
			const t = (e.target as HTMLElement).closest('.pf-deck-card');
			if (t !== front) return;
				e.preventDefault();
			dragging = true; horiz = false; startX = e.clientX; startY = e.clientY; dx = 0;
			stop();
			front.classList.add('is-dragging');
			window.addEventListener('pointermove', onMove, { passive: false });
			window.addEventListener('pointerup', onUp);
		});
	};

	const init = () => {
		initFlowbite();
		toaster();
		handleThemeToggle();
		handleHero();
		initPortfolioDeck();
		initViewExperience();
		initViewBanner();
		initBuilderView();
		initBuilderBody();
		initFounderBody();
		initCampusBody();
		initStudioBody();
		initBoardroomBody();
		initFounderView();
		initCampusView();
		initStudioView();
		initBoardroomView();
		initLegacyView();
		handleFooter();

		if (document.querySelector('#newsletter')) {
			const newsletterForm = document.getElementById('newsletter') as HTMLFormElement;

			const email = document.getElementById('email') as HTMLInputElement;

			newsletterForm.onsubmit = (e) => {
				e.preventDefault();

				const { name } = email;

				/* should be submitted ::mailchimp */
				console.log(name);
			};
		}

		if (document.querySelector('#teammates-carousel')) {
			const splide = new Splide('.splide', {
				perPage: 1,
				type: 'loop',
				perMove: 1,
				autoplay: true,
				interval: 2000,
				mediaQuery: 'min',
				breakpoints: {
					640: {
						perPage: 2,
						gap: 30,
					},
					768: {
						perPage: 3,
					},
					1024: {
						perPage: 4,
					},
				},
			});
			splide.mount();
		}

		if (document.querySelector('#services--dropdown')) {
			const fields = document.querySelectorAll<HTMLDivElement>('.services--field');

			fields.forEach((field) => {
				field.addEventListener('click', () => {
					const isActive = isTrue(field.dataset.hidden ?? '');
					const fieldName = field.dataset.fieldname;
					const btn = document.getElementById(`btn-${fieldName}`);

					if (btn !== null) {
						if (isActive) {
							btn.firstElementChild!.textContent = `Hide ${fieldName}`;
							btn.setAttribute('aria-expanded', 'true');
						} else {
							btn.firstElementChild!.textContent = `Expand ${fieldName}`;
							btn.setAttribute('aria-expanded', 'false');
						}
					} else {
						throw new Error(`${fieldName} Button is not defined:`);
					}

					field.dataset.hidden = (!isActive).toString();
				});
			});
		}

		if (document.querySelector<HTMLElement>('#mobile-wrapper')) {
			handleMenuToggle();
		}

		if (document.querySelector('#member-dialog')) {
			handleTeamDialog();
		}

		if (document.querySelector('#navbar--header')) {
			const backTop = document.getElementById('back-to-top');
			const header = document.querySelector('#navbar--header');
			const hasHero = !!document.querySelector('.hero-view');
			const onScrollNav = () => {
				const y =
					window.scrollY ||
					window.pageYOffset ||
					document.documentElement.scrollTop ||
					0;
				if (!header) return;
				header.classList.toggle('header-sticky', y > 120);
				// blend onto the hero only while parked near the very top
				header.classList.toggle('at-hero-top', hasHero && y < 40);
				if (backTop) backTop.classList.toggle('is-visible', y > 600);
			};
			// passive listener is reliable across scroll containers
			window.addEventListener('scroll', onScrollNav, { passive: true });
			window.onscroll = onScrollNav;
			onScrollNav();
			if (backTop) {
				backTop.onclick = () =>
					window.scrollTo({ top: 0, behavior: 'smooth' });
			}
		}

		// Our own compact chat launcher drives Tawk (which we keep hidden).
		const chatFab = document.getElementById('swizel-chat-fab');
		if (chatFab) {
			chatFab.onclick = () => {
				const api = (window as any).Tawk_API;
				if (api && api.maximize) {
					if (api.showWidget) api.showWidget();
					api.maximize();
				}
			};
		}

		if (document.querySelector('#bootcamp-register')) {
			const registerationForm = document.querySelector<HTMLFormElement>('#bootcamp-register');

			registerationForm!.onsubmit = (e) => {
				e.preventDefault();

				console.log('hello');
			};
		}
		if (document.querySelector('#bootcamp--faq')) {
			handleDropDown('faq--item');
		}
	};

	// guide to events and function check: https://swup.js.org/getting-started/reloading-javascript
	// swup with astro: https://navillus.dev/blog/astro-plus-swup
	// @ts-ignore
	const swup = new Swup({
		plugins: [new SwupA11yPlugin(), new SwupHeadPlugin(), new SwupScrollPlugin()],
		linkSelector: 'a[href]',
		animationSelector: '.transition-main',
	});
	// expose so the view picker can navigate home when a world is chosen off-home
	(window as any).swup = swup;

	if (document.readyState === 'complete') {
		init();
	} else {
		document.addEventListener('DOMContentLoaded', () => init());
	}

	// run after every additional navigation by swup
	swup.on('contentReplaced', init);

	// Themed animated custom cursor (attached once; element lives outside #swup)
	const swizelCursor = document.getElementById('swizel-cursor');
	if (swizelCursor && window.matchMedia('(pointer: fine)').matches) {
		let idleTimer = 0;
		let lastX = -1;
		let lastY = -1;

		const applyZone = (el: Element | null) => {
			const zone = el && el.closest('.hero-view, .view-body, .view-worlds');
			swizelCursor.classList.toggle('is-active', !!zone);
			const cz = el && el.closest('[data-cursor]');
			const icon = cz && cz.getAttribute('data-cursor');
			if (icon) swizelCursor.setAttribute('data-icon', icon);
			else swizelCursor.removeAttribute('data-icon');
		};

		window.addEventListener(
			'pointermove',
			(e) => {
				lastX = e.clientX;
				lastY = e.clientY;
				swizelCursor.style.transform = `translate3d(${e.clientX}px, ${e.clientY}px, 0)`;
				applyZone(e.target instanceof Element ? e.target : null);
				swizelCursor.classList.remove('is-idle');
				window.clearTimeout(idleTimer);
				idleTimer = window.setTimeout(
					() => swizelCursor.classList.add('is-idle'),
					700
				);
			},
			{ passive: true }
		);
		// scrolling moves the page under a stationary pointer — re-check the
		// zone so the cursor never disappears between sections
		window.addEventListener(
			'scroll',
			() => {
				if (lastX < 0) return;
				applyZone(document.elementFromPoint(lastX, lastY));
			},
			{ passive: true }
		);
		document.addEventListener('mouseleave', () =>
			swizelCursor.classList.remove('is-active')
		);
	}
</script>
