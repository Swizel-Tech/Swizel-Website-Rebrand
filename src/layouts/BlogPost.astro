---
import type { CollectionEntry } from 'astro:content';
import MainLayout from './MainLayout.astro';
import FooterCTA from '../components/blocks/FooterCTA.astro';
import Section from '../components/HTML/Section.astro';
import Link from '../components/Link.astro';
import Heading from '../components/HTML/Heading.astro';
import { Icon } from 'astro-icon';
import OurBlogSection from '../components/sections/OurBlogSection.astro';

interface Props {
	post: CollectionEntry<'blog'>;
	prev: CollectionEntry<'blog'> | null;
	next: CollectionEntry<'blog'> | null;
	related: CollectionEntry<'blog'>[];
}
const { post, prev, next, related } = Astro.props;
const { title, description, pubDate, updatedDate, heroImage, category, author } = post.data;

const readTime = Math.max(1, Math.round((post.body?.trim().split(/\s+/).length || 0) / 200));
const fmtDate = (d: Date) =>
	new Date(d).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
const initials = (author || 'Swizel Team')
	.split(/\s+/)
	.map((w) => w[0])
	.slice(0, 2)
	.join('')
	.toUpperCase();

const catColor: Record<string, string> = {
	EdTech: '#2bb3c0',
	Fintech: '#6366f1',
	Marketing: '#ec4899',
	Technology: '#28a6ec',
	Insights: '#28a6ec',
};
const c = catColor[category] ?? '#28a6ec';

const shareUrl = new URL(`/blog/${post.slug}`, Astro.site ?? 'https://swizel.co').href;
const tw = `https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(shareUrl)}`;
const li = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(shareUrl)}`;
const wa = `https://wa.me/?text=${encodeURIComponent(title + ' ' + shareUrl)}`;
---

<MainLayout title={`${title} | Swizel Technologies`} description={description} image={heroImage}>
	<!-- Reading progress -->
	<div class="br-progress" aria-hidden="true"><span></span></div>

	<!-- ══ Boardroom reading world ══ -->
	<article
		class="bdbody bd-services bd-reader view-body view-body-boardroom"
		style={`--c:${c}`}
		data-cursor="book"
	>
		<a href="/blog" class="br-back" data-cursor="book">
			<Icon width={16} name="mdi:arrow-left" /> The Swizel journal
		</a>

		<header class="br-hero bd-reveal">
			<span class="br-cat">{category}</span>
			<h1 class="br-title">{title}</h1>
			<p class="br-lead">{description}</p>
			<div class="br-meta">
				<span class="br-avatar" aria-hidden="true">{initials}</span>
				<span class="br-by"><strong>{author}</strong><em>Swizel Technologies</em></span>
				<span class="br-meta-sep"></span>
				<span class="br-meta-bit"><Icon width={15} name="mdi:calendar-blank-outline" /> {fmtDate(pubDate)}</span>
				<span class="br-meta-bit"><Icon width={15} name="mdi:clock-outline" /> {readTime} min read</span>
			</div>
		</header>

		{heroImage && (
			<figure class="br-figure bd-reveal">
				<img src={heroImage} alt={title} loading="eager" />
			</figure>
		)}

		<div class="br-body bd-reveal">
			<div class="bd-prose">
				<slot />
				{updatedDate && (
					<p class="br-updated">Last updated on {fmtDate(updatedDate)}.</p>
				)}
			</div>
		</div>

		<!-- Share -->
		<div class="br-share bd-reveal">
			<span class="br-share-label">Found this useful? Share it</span>
			<div class="br-share-row">
				<a class="br-share-btn" href={tw} target="_blank" rel="noopener" aria-label="Share on X"><Icon width={18} name="mdi:twitter" /></a>
				<a class="br-share-btn" href={li} target="_blank" rel="noopener" aria-label="Share on LinkedIn"><Icon width={18} name="mdi:linkedin" /></a>
				<a class="br-share-btn" href={wa} target="_blank" rel="noopener" aria-label="Share on WhatsApp"><Icon width={18} name="mdi:whatsapp" /></a>
				<button class="br-share-btn br-copy" type="button" data-url={shareUrl} aria-label="Copy link"><Icon width={18} name="mdi:link-variant" /></button>
			</div>
		</div>

		<!-- Author card -->
		<aside class="br-author bd-reveal">
			<span class="br-author-avatar" aria-hidden="true">{initials}</span>
			<div class="br-author-body">
				<span class="br-author-kicker">Written by</span>
				<strong class="br-author-name">{author}</strong>
				<p class="br-author-bio">We’re a Lagos-born product studio shipping web platforms, mobile apps and AI for teams across Africa and beyond. When we’re not building, we’re writing about it.</p>
				<a class="br-author-cta" href="/about" data-cursor="book">Meet the team <Icon width={15} name="mdi:arrow-right" /></a>
			</div>
		</aside>

		<!-- Related -->
		{related.length > 0 && (
			<section class="br-related bd-reveal">
				<div class="br-related-head">
					<span class="bd-kicker">Keep reading</span>
					<h2 class="br-related-h">More from the journal</h2>
				</div>
				<div class="br-related-grid">
					{related.map((p) => (
						<a class="br-rcard" href={`/blog/${p.slug}`} style={`--c:${catColor[p.data.category] ?? '#28a6ec'}`} data-cursor="book">
							<span class="br-rcard-media"><img src={p.data.heroImage} alt={p.data.title} loading="lazy" /><span class="br-rcard-cat">{p.data.category}</span></span>
							<span class="br-rcard-body">
								<strong>{p.data.title}</strong>
								<span class="br-rcard-meta">{fmtDate(p.data.pubDate)}</span>
							</span>
						</a>
					))}
				</div>
			</section>
		)}

		<!-- Prev / next -->
		{(prev || next) && (
			<nav class="br-nav bd-reveal" aria-label="More articles">
				{prev ? (
					<a class="br-nav-link br-nav-prev" href={`/blog/${prev.slug}`} data-cursor="book">
						<span class="br-nav-dir"><Icon width={15} name="mdi:arrow-left" /> Newer</span>
						<strong>{prev.data.title}</strong>
					</a>
				) : <span></span>}
				{next ? (
					<a class="br-nav-link br-nav-next" href={`/blog/${next.slug}`} data-cursor="book">
						<span class="br-nav-dir">Older <Icon width={15} name="mdi:arrow-right" /></span>
						<strong>{next.data.title}</strong>
					</a>
				) : <span></span>}
			</nav>
		)}
	</article>

	<!-- ══ Fallback for the other worlds (legacy reading page) ══ -->
	<div class="alt-view-only">
		<Section divClass="py-20 blog--post">
			<div class="max-w-2xl mx-auto space-y-6 md:pb-16">
				<Link href="/blog" class="flex items-center gap-4 text-darker uppercase text-xs font-bold">
					<Icon name="arrow-left" size={18} />
					<span class="text-darker">Back to blog</span>
				</Link>
				<Heading className="!leading-tight" type="h2">{title}</Heading>
				<div class="flex items-center flex-wrap justify-between text-base text-darker/60">
					<p class="flex gap-2">
						In <span class="text-darker font-medium">{category}</span> by
						<span class="text-darker font-medium">{author}</span>
					</p>
					<span>{pubDate?.toDateString() ?? pubDate}</span>
				</div>
			</div>
			{heroImage && (
				<div class="mb-10">
					<img class="md:w-3/4 max-h-[500px] object-cover" src={heroImage} alt={title} />
				</div>
			)}
			<div class="max-w-2xl mx-auto markdown--content">
				<slot />
			</div>
			<div class="text-swizelBrown mt-16 -mb-24 border-b border-swizelBrown"></div>
		</Section>
		<OurBlogSection pageTitle="Recent Articles" hideButton hideTitle />
		<FooterCTA />
	</div>
</MainLayout>

<script is:inline>
	(function () {
		// Reading progress + copy-link — bound once to the persistent window so it
		// survives swup navigations; re-run on each load to re-point at the article.
		var upd = function () {
			var bar = document.querySelector('.br-progress span');
			var art = document.querySelector('.bd-reader .bd-prose');
			if (!bar || !art) return;
			var start = art.getBoundingClientRect().top + window.scrollY - window.innerHeight * 0.5;
			var end = art.getBoundingClientRect().bottom + window.scrollY - window.innerHeight * 0.5;
			var p = (window.scrollY - start) / Math.max(1, end - start);
			bar.style.transform = 'scaleX(' + Math.min(1, Math.max(0, p)) + ')';
		};
		if (!window.__brReader) {
			window.__brReader = true;
			window.addEventListener('scroll', upd, { passive: true });
			window.addEventListener('resize', upd);
			document.addEventListener('click', function (e) {
				var btn = e.target.closest && e.target.closest('.br-copy');
				if (!btn) return;
				var url = btn.getAttribute('data-url') || location.href;
				navigator.clipboard && navigator.clipboard.writeText(url);
				btn.classList.add('is-copied');
				setTimeout(function () { btn.classList.remove('is-copied'); }, 1400);
			});
		}
		upd();
	})();
</script>

<style>
	/* Reading progress bar */
	.br-progress { position: fixed; top: 0; left: 0; right: 0; height: 3px; z-index: 60; background: transparent; pointer-events: none; }
	.br-progress span { display: block; height: 100%; transform: scaleX(0); transform-origin: 0 50%; background: linear-gradient(90deg, #8dfeea, #18debe, #28a6ec); box-shadow: 0 0 14px rgba(40, 166, 236, 0.6); transition: transform 0.08s linear; }

	/* ════ Boardroom reader base ════ */
	.bd-reader {
		--bd-accent: #28a6ec;
		--bd-ink: #f4f6fb;
		--bd-muted: rgba(244, 246, 251, 0.62);
		--bd-glass: linear-gradient(160deg, rgba(255, 255, 255, 0.07), rgba(255, 255, 255, 0.02) 55%);
		--bd-glass-border: rgba(255, 255, 255, 0.1);
		--bd-shadow: 0 34px 80px -34px rgba(0, 0, 0, 0.8);
		font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
		position: relative; isolation: isolate; overflow: hidden;
		background:
			radial-gradient(1100px 540px at 80% -6%, color-mix(in srgb, var(--c) 14%, transparent), transparent 62%),
			radial-gradient(900px 520px at 4% 30%, rgba(58, 90, 200, 0.1), transparent 60%),
			linear-gradient(180deg, #070910 0%, #0a0d1c 45%, #05060d 100%);
		color: var(--bd-ink);
		padding: clamp(2rem, 5vw, 3.5rem) clamp(1rem, 4vw, 2rem) clamp(3rem, 6vw, 5rem);
	}
	:global(html:not(.dark)) .bd-reader {
		--bd-ink: #0f1120;
		--bd-muted: rgba(28, 32, 52, 0.82);
		--bd-glass: linear-gradient(160deg, #ffffff, #f3f6fb 60%);
		--bd-glass-border: rgba(18, 22, 45, 0.16);
		--bd-shadow: 0 26px 60px -32px rgba(20, 28, 60, 0.4);
		background:
			radial-gradient(1100px 540px at 80% -6%, color-mix(in srgb, var(--c) 12%, transparent), transparent 62%),
			linear-gradient(180deg, #e4eaf2 0%, #dbe3ee 50%, #e4eaf2 100%);
	}
	.bd-reader::before { content: ''; position: absolute; inset: -12%; z-index: -2; pointer-events: none; background: radial-gradient(420px 420px at 12% 12%, color-mix(in srgb, var(--c) 20%, transparent), transparent 60%), radial-gradient(380px 380px at 88% 30%, rgba(139, 92, 246, 0.16), transparent 60%); filter: blur(60px); opacity: 0.6; animation: br-bg 28s ease-in-out infinite; }
	:global(html:not(.dark)) .bd-reader::before { opacity: 0.4; }
	@keyframes br-bg { 0%,100%{ transform: translate3d(0,0,0) scale(1);} 50%{ transform: translate3d(3%,-2%,0) scale(1.08);} }
	.bd-reader::after { content: ''; position: absolute; inset: 0; z-index: -2; pointer-events: none; opacity: 0.4; background-image: radial-gradient(circle, color-mix(in srgb, var(--c) 28%, transparent) 1px, transparent 1px); background-size: 38px 38px; -webkit-mask-image: radial-gradient(1200px 700px at 50% 0%, #000, transparent 70%); mask-image: radial-gradient(1200px 700px at 50% 0%, #000, transparent 70%); animation: br-pan 50s linear infinite; }
	:global(html:not(.dark)) .bd-reader::after { opacity: 0.24; }
	@keyframes br-pan { to { background-position: 380px 200px; } }

	.bd-kicker { display: inline-block; font-size: 0.78rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--c); margin-bottom: 0.7rem; }
	:global(html:not(.dark)) .bd-kicker { color: color-mix(in srgb, var(--c) 55%, #14162a); }

	/* Back link */
	.br-back { display: inline-flex; align-items: center; gap: 0.5rem; max-width: 46rem; margin: 0 auto; width: 100%; font-size: 0.82rem; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase; color: var(--bd-muted); transition: color 0.2s ease, gap 0.2s ease; }
	.br-back:hover { color: var(--c); gap: 0.7rem; }

	/* Hero */
	.br-hero { max-width: 46rem; margin: clamp(1.4rem, 3vw, 2.2rem) auto 0; }
	.br-cat { display: inline-block; font-size: 0.72rem; font-weight: 800; letter-spacing: 0.1em; text-transform: uppercase; color: #fff; background: color-mix(in srgb, var(--c) 88%, transparent); padding: 0.32rem 0.7rem; border-radius: 9999px; margin-bottom: 1.1rem; box-shadow: 0 8px 22px -10px color-mix(in srgb, var(--c) 70%, transparent); }
	.br-title { font-size: clamp(2rem, 5vw, 3.4rem); font-weight: 700; letter-spacing: -0.025em; line-height: 1.08; margin: 0 0 1rem; }
	.br-lead { font-size: clamp(1.05rem, 2vw, 1.3rem); line-height: 1.55; color: var(--bd-muted); margin: 0 0 1.6rem; }
	.br-meta { display: flex; flex-wrap: wrap; align-items: center; gap: 0.7rem 0.9rem; padding-top: 1.2rem; border-top: 1px solid var(--bd-glass-border); }
	.br-avatar, .br-author-avatar { flex-shrink: 0; display: grid; place-items: center; border-radius: 9999px; font-weight: 800; color: #06121a; background: linear-gradient(135deg, #8dfeea, #18debe, #28a6ec); }
	.br-avatar { width: 38px; height: 38px; font-size: 0.82rem; }
	.br-by { display: flex; flex-direction: column; line-height: 1.25; }
	.br-by strong { font-size: 0.92rem; font-weight: 700; }
	.br-by em { font-style: normal; font-size: 0.78rem; color: var(--bd-muted); }
	.br-meta-sep { flex: 1; }
	.br-meta-bit { display: inline-flex; align-items: center; gap: 0.35rem; font-size: 0.84rem; color: var(--bd-muted); }

	/* Hero image */
	.br-figure { max-width: 60rem; margin: clamp(1.6rem, 4vw, 2.6rem) auto 0; border-radius: 1.4rem; overflow: hidden; border: 1px solid var(--bd-glass-border); box-shadow: var(--bd-shadow); }
	.br-figure img { width: 100%; display: block; max-height: 540px; object-fit: cover; }

	/* Body / prose */
	.br-body { max-width: 46rem; margin: clamp(2rem, 5vw, 3.2rem) auto 0; }
	.bd-prose { font-size: 1.1rem; line-height: 1.8; color: color-mix(in srgb, var(--bd-ink) 92%, transparent); }
	.bd-prose :global(p) { margin: 0 0 1.4rem; }
	.bd-prose :global(h2) { font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 700; letter-spacing: -0.02em; line-height: 1.2; margin: 2.4rem 0 1rem; }
	.bd-prose :global(h3) { font-size: clamp(1.25rem, 2.4vw, 1.5rem); font-weight: 700; margin: 2rem 0 0.8rem; }
	.bd-prose :global(h2)::after { content: ''; display: block; width: 3rem; height: 3px; margin-top: 0.7rem; border-radius: 3px; background: linear-gradient(90deg, var(--c), transparent); }
	.bd-prose :global(a) { color: var(--c); text-decoration: underline; text-underline-offset: 3px; text-decoration-thickness: 1px; transition: color 0.2s ease; }
	:global(html:not(.dark)) .bd-prose :global(a) { color: color-mix(in srgb, var(--c) 60%, #14162a); }
	.bd-prose :global(a:hover) { color: color-mix(in srgb, var(--c) 70%, #fff); }
	.bd-prose :global(ul), .bd-prose :global(ol) { margin: 0 0 1.4rem; padding-left: 1.4rem; }
	.bd-prose :global(li) { margin: 0 0 0.6rem; }
	.bd-prose :global(li::marker) { color: var(--c); }
	.bd-prose :global(img) { width: 100%; border-radius: 1rem; margin: 1.6rem 0; border: 1px solid var(--bd-glass-border); }
	.bd-prose :global(blockquote) { margin: 1.8rem 0; padding: 0.6rem 0 0.6rem 1.4rem; border-left: 3px solid var(--c); font-size: 1.2rem; font-style: italic; color: var(--bd-ink); }
	.bd-prose :global(code) { font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 0.92em; padding: 0.12em 0.4em; border-radius: 0.4rem; background: color-mix(in srgb, var(--c) 14%, transparent); }
	.bd-prose :global(pre) { padding: 1.1rem 1.3rem; border-radius: 0.9rem; overflow: auto; background: rgba(0, 0, 0, 0.4); border: 1px solid var(--bd-glass-border); margin: 0 0 1.4rem; }
	.bd-prose :global(pre code) { background: none; padding: 0; }
	.bd-prose :global(hr) { border: none; border-top: 1px solid var(--bd-glass-border); margin: 2.2rem 0; }
	.bd-prose :global(strong) { font-weight: 700; color: var(--bd-ink); }
	.br-updated { font-size: 0.86rem; color: var(--bd-muted); font-style: italic; margin-top: 2rem; }

	/* Share */
	.br-share { max-width: 46rem; margin: clamp(2rem, 4vw, 3rem) auto 0; display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 1rem; padding: 1.1rem 1.3rem; border-radius: 1.1rem; background: var(--bd-glass); border: 1px solid var(--bd-glass-border); box-shadow: var(--bd-shadow); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); }
	.br-share-label { font-size: 0.92rem; font-weight: 700; }
	.br-share-row { display: flex; gap: 0.55rem; }
	.br-share-btn { display: grid; place-items: center; width: 42px; height: 42px; border-radius: 9999px; color: var(--bd-ink); background: color-mix(in srgb, var(--bd-ink) 8%, transparent); border: 1px solid var(--bd-glass-border); cursor: pointer; transition: transform 0.2s ease, background 0.2s ease, color 0.2s ease, border-color 0.2s ease; }
	.br-share-btn:hover { transform: translateY(-3px); color: #fff; background: var(--c); border-color: transparent; }
	.br-copy.is-copied { color: #fff; background: #18c08a; border-color: transparent; }

	/* Author card */
	.br-author { max-width: 46rem; margin: clamp(2rem, 4vw, 3rem) auto 0; display: flex; gap: 1.2rem; align-items: flex-start; padding: clamp(1.3rem, 3vw, 1.8rem); border-radius: 1.3rem; background: var(--bd-glass); border: 1px solid var(--bd-glass-border); box-shadow: var(--bd-shadow); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); }
	.br-author-avatar { width: 60px; height: 60px; font-size: 1.2rem; }
	.br-author-kicker { font-size: 0.74rem; font-weight: 800; letter-spacing: 0.1em; text-transform: uppercase; color: var(--c); }
	:global(html:not(.dark)) .br-author-kicker { color: color-mix(in srgb, var(--c) 55%, #14162a); }
	.br-author-name { display: block; font-size: 1.2rem; font-weight: 700; margin: 0.15rem 0 0.5rem; }
	.br-author-bio { font-size: 0.95rem; line-height: 1.6; color: var(--bd-muted); margin: 0 0 0.7rem; }
	.br-author-cta { display: inline-flex; align-items: center; gap: 0.4rem; font-size: 0.9rem; font-weight: 700; color: var(--c); transition: gap 0.2s ease; }
	:global(html:not(.dark)) .br-author-cta { color: color-mix(in srgb, var(--c) 55%, #14162a); }
	.br-author-cta:hover { gap: 0.65rem; }

	/* Related */
	.br-related { max-width: 60rem; margin: clamp(3rem, 6vw, 4.5rem) auto 0; }
	.br-related-head { text-align: center; margin-bottom: 1.6rem; }
	.br-related-h { font-size: clamp(1.5rem, 3vw, 2.1rem); font-weight: 700; letter-spacing: -0.02em; margin: 0; }
	.br-related-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: clamp(0.9rem, 2vw, 1.3rem); }
	@media (max-width: 820px) { .br-related-grid { grid-template-columns: 1fr; } }
	.br-rcard { display: flex; flex-direction: column; border-radius: 1.1rem; overflow: hidden; background: var(--bd-glass); border: 1px solid var(--bd-glass-border); box-shadow: var(--bd-shadow); backdrop-filter: blur(14px); -webkit-backdrop-filter: blur(14px); transition: transform 0.35s cubic-bezier(0.22,1,0.36,1), border-color 0.35s ease; }
	.br-rcard:hover { transform: translateY(-6px); border-color: color-mix(in srgb, var(--c) 50%, var(--bd-glass-border)); }
	.br-rcard-media { position: relative; display: block; aspect-ratio: 16/9; overflow: hidden; }
	.br-rcard-media img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease; }
	.br-rcard:hover .br-rcard-media img { transform: scale(1.06); }
	.br-rcard-cat { position: absolute; top: 0.6rem; left: 0.6rem; font-size: 0.62rem; font-weight: 800; letter-spacing: 0.06em; text-transform: uppercase; padding: 0.25rem 0.55rem; border-radius: 9999px; color: #fff; background: color-mix(in srgb, var(--c) 85%, transparent); }
	.br-rcard-body { padding: 0.9rem 1rem 1.1rem; display: flex; flex-direction: column; gap: 0.4rem; }
	.br-rcard-body strong { font-size: 1rem; font-weight: 700; line-height: 1.3; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
	.br-rcard-meta { font-size: 0.78rem; color: var(--bd-muted); }

	/* Prev / next */
	.br-nav { max-width: 60rem; margin: clamp(2rem, 4vw, 3rem) auto 0; display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
	@media (max-width: 640px) { .br-nav { grid-template-columns: 1fr; } }
	.br-nav-link { display: flex; flex-direction: column; gap: 0.5rem; padding: 1.1rem 1.3rem; border-radius: 1.1rem; background: var(--bd-glass); border: 1px solid var(--bd-glass-border); box-shadow: var(--bd-shadow); transition: transform 0.3s ease, border-color 0.3s ease; }
	.br-nav-link:hover { transform: translateY(-4px); border-color: color-mix(in srgb, var(--c) 45%, var(--bd-glass-border)); }
